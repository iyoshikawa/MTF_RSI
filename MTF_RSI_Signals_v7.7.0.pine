//@version=5
indicator("MTF RSI Signals [v7.7.0]", overlay=true, max_labels_count=500)

// Clean ticker for request.security (avoids session/extended hours issues)
cleanTicker = ticker.new(syminfo.prefix, syminfo.ticker)

// ==========================================
// --- CHART TYPE DETECTION ---
// ==========================================
is_renko = chart.is_renko
is_range_chart = chart.is_range
is_standard = chart.is_standard
is_ha_chart = chart.is_heikinashi
is_nonstandard = is_renko or is_range_chart or chart.is_linebreak or chart.is_kagi or chart.is_pnf
chart_type_label = is_renko ? "RENKO" : is_range_chart ? "RANGE" : is_ha_chart ? "HA CHART" : chart.is_linebreak ? "LINEBRK" : chart.is_kagi ? "KAGI" : chart.is_pnf ? "P&F" : "CANDLE"

// Renko brick size (high - low = 1 brick on Renko)
brick_size = is_renko ? (high - low) : 0.0

// Time-based cooldown for non-standard charts (bricks/bars are irregular)
// timeframe.in_seconds() returns 0 for Renko/Range, so we track elapsed time directly
bar_time_seconds = time - time[1]  // actual time between this bar and last
var int elapsed_since_signal_ms = 999999999

// ==========================================
// --- ⚡ QUICK INSTRUMENT PRESETS ---
// ==========================================
grp_preset = "⚡ Quick Instrument Presets"
instrument_preset = input.string("DEFAULT", "Instrument", options=["DEFAULT", "🛢️ CL (Crude Oil)", "📈 NQ/MNQ (NASDAQ)", "📊 ES/MES (S&P 500)", "🔷 YM/MYM (Dow)"], group=grp_preset, tooltip="Select your instrument to auto-configure EMA, DStoch, ADX, session, and volume settings.")

// Derive booleans from dropdown for use throughout the script
use_cl_preset = instrument_preset == "🛢️ CL (Crude Oil)"
use_nq_preset = instrument_preset == "📈 NQ/MNQ (NASDAQ)"
use_es_preset = instrument_preset == "📊 ES/MES (S&P 500)"
use_ym_preset = instrument_preset == "🔷 YM/MYM (Dow)"

// ==========================================
// --- CORE CONFIGURATION ---
// ==========================================
grp_core = "Core Settings"
ema_length_in = input.int(34, "EMA Length", group=grp_core, tooltip="Primary EMA for trend direction. Price above = bullish bias, below = bearish. Overridden by instrument preset. Default: 34.")
show_vwap = input.bool(true, "Show VWAP", group=grp_core, tooltip="Plots the session VWAP line. Used in A+ grade requirement — price must be on the right side of VWAP.")
show_ny_vwap = input.bool(true, "Show NY Session Anchored VWAP", group=grp_core, tooltip="Plots a VWAP anchored to the NY session open (0930 ET). Useful for tracking institutional fair value during RTH.")
show_prev_ny_vwap = input.bool(true, "Show Previous NY VWAP Level", group=grp_core, tooltip="Shows the prior NY session's closing VWAP as a horizontal reference level.")

// RSI Settings
grp_rsi = "RSI Configuration"
rsi_speed = input.string("Standard", "RSI Speed", options=["Standard", "Fast", "Ultra-Fast"], group=grp_rsi, tooltip="Preset that overrides all RSI settings below for quicker or slower direction detection.Standard (5/13, smooth 2/3, zone 1.0): Balanced — fewest false signals.Fast (4/10, smooth 1/2, zone 0.75): ~2-3 bars earlier reversals. Good for most sessions.Ultra-Fast (3/8, smooth 1/1, zone 0.5, hlc3 source): Earliest possible signals. Best in strong trends — enable 'Gray Ribbon During Consolidation' to reduce chop whipsaws.Must match between Signals and Management indicators.")
shortLen    = input.int(5, "Short RSI Period", group=grp_rsi, tooltip="Lookback for the fast RSI. Lower = more responsive but noisier. Range: 3-7. Overridden by RSI Speed preset.")
longLen     = input.int(13, "Long RSI Period", group=grp_rsi, tooltip="Lookback for the slow RSI anchor. Lower = faster crossovers but less trend stability. Range: 8-21. Keep at least 2x Short RSI Period. Overridden by RSI Speed preset.")
shortSmooth = input.int(2, "Short Smoothing", group=grp_rsi, tooltip="EMA smoothing on the Short RSI. 1 = no smoothing (raw RSI). Higher = smoother but more lag. Range: 1-5. Overridden by RSI Speed preset.")
longSmooth  = input.int(3, "Long Smoothing", group=grp_rsi, tooltip="EMA smoothing on the Long RSI. 1 = no smoothing. Higher = more stable anchor but slower reversals. Range: 1-5. Overridden by RSI Speed preset.")
threshold   = input.float(1.0, "RSI Neutral Zone", group=grp_rsi, tooltip="Min RSI diff (short minus long) to register a direction. Lower = more sensitive to weak momentum, higher = only strong moves trigger. Range: 0.3-2.0. If you shorten RSI periods, keep this at 0.75+ to filter noise. Overridden by RSI Speed preset.")

// Stochastic Settings
grp_stoch = "Stochastic Configuration"
stochLen  = input.int(10, "Stoch Period", group=grp_stoch, tooltip="Lookback period for the Double Stochastic. Lower = more responsive. Default: 10.")
stochSmth = input.int(3, "Stoch Smoothing", group=grp_stoch, tooltip="Double-EMA smoothing applied to the stochastic. Lower = faster but noisier. Default: 3.")
stoch_os_in  = input.float(35, "Oversold Level", group=grp_stoch, tooltip="DStoch below this = oversold / bearish momentum. Used in grade logic — stoch must confirm direction. Overridden by instrument preset.")
stoch_ob_in  = input.float(60, "Overbought Level", group=grp_stoch, tooltip="DStoch above this = overbought / bullish momentum. Used in grade logic — stoch must confirm direction. Overridden by instrument preset.")

// DStoch Crossover Signals
grp_stoch_signals = "DStoch Crossover Signals"
show_stoch_signals = input.bool(true, "Show DStoch Crossover Signals", group=grp_stoch_signals, tooltip="Plots DS arrow markers when DStoch crosses above the buy level or below the sell level.")
stoch_sell_level_in = input.float(85, "Sell Signal Level (cross down)", group=grp_stoch_signals, tooltip="When DStoch crosses down through this level, a sell arrow appears. Higher = fewer but more extreme signals. Overridden by instrument preset.")
stoch_buy_level = input.float(12, "Buy Signal Level (cross up)", group=grp_stoch_signals, tooltip="When DStoch crosses up through this level, a buy arrow appears. Lower = fewer but more extreme signals.")
brighten_on_confluence = input.bool(true, "Brighten Background When DStoch + RSI Align", group=grp_stoch_signals, tooltip="When the RSI ribbon direction and DStoch momentum agree, the ribbon background brightens (transparency drops by 20). Helps visually spot high-conviction zones.")
ds_buy_color = input.color(color.aqua, "Buy Marker Color", group=grp_stoch_signals, inline="dsc1", tooltip="Background color of the DS▲ buy label on the chart.")
ds_sell_color = input.color(color.fuchsia, "Sell Marker Color", group=grp_stoch_signals, inline="dsc1", tooltip="Background color of the DS▼ sell label on the chart.")
ds_buy_text_color = input.color(color.white, "Buy Text", group=grp_stoch_signals, inline="dsc2", tooltip="Text color inside the DS▲ buy label.")
ds_sell_text_color = input.color(color.white, "Sell Text", group=grp_stoch_signals, inline="dsc2", tooltip="Text color inside the DS▼ sell label.")
ds_marker_size = input.string("tiny", "Marker Size", options=["tiny", "small", "normal", "large"], group=grp_stoch_signals, tooltip="Size of the DStoch crossover markers on the chart.\n\ntiny (default): minimal, won't crowd grade labels.\nsmall: slightly more visible.\nnormal/large: high visibility if DStoch signals are primary to your workflow.")

// Volume Settings
grp_vol = "Volume Filter"
vol_ma_len = input.int(20, "Volume MA Length", group=grp_vol, tooltip="SMA period for the volume baseline. Current bar volume must exceed this average × multiplier. Default: 20.")
vol_mult_in   = input.float(1.1, "Volume Multiplier", group=grp_vol, tooltip="Volume must be at least this × the MA to qualify. 1.0 = average volume, 1.5 = 50% above average. Lower = more signals, higher = only high-volume bars. Overridden by instrument preset.")
use_vol_filter = input.bool(true, "Enable Volume Filter", group=grp_vol, tooltip="When enabled, A+ grades require above-average volume. Disable if your instrument has unreliable volume data.")

// Volume Analysis
grp_vol_adv = "📊 Volume Analysis"
enable_vol_analysis = input.bool(true, "Enable Volume Analysis", group=grp_vol_adv, tooltip="Tracks volume expansion/contraction, detects spikes, and flags volume-price divergence. Adds dashboard rows and optional chart markers.")
vol_fast_len = input.int(5, "Fast Vol MA", group=grp_vol_adv, minval=2, maxval=20, tooltip="Short-term volume MA. When above slow MA, volume is expanding. Default 5.")
vol_slow_len = input.int(20, "Slow Vol MA", group=grp_vol_adv, minval=10, maxval=50, tooltip="Long-term volume baseline. Default 20 (same as volume filter MA).")
vol_spike_mult = input.float(2.0, "Spike Threshold (std dev)", group=grp_vol_adv, minval=1.0, maxval=5.0, step=0.5, tooltip="Volume spike = current bar > mean + this × standard deviation. 2.0 = catches major spikes, 1.5 = more sensitive. Default 2.0.")
vol_spike_lookback = input.int(50, "Spike Lookback", group=grp_vol_adv, minval=20, maxval=200, tooltip="Bars to calculate volume mean and std dev over. 50 = ~50 min on 1-min chart.")
show_vol_spikes = input.bool(true, "Show Spike Markers on Chart", group=grp_vol_adv, tooltip="Plots markers on bars with volume spikes. Color indicates context: green = confirming trend, orange = potential exhaustion.")
vol_spike_confirm_col = input.color(#00FF88, "Spike Confirm Color", group=grp_vol_adv, inline="vsc1", tooltip="Color for volume spikes that confirm the current move (early in signal).")
vol_spike_exhaust_col = input.color(#FF6B00, "Spike Exhaust Color", group=grp_vol_adv, inline="vsc1", tooltip="Color for volume spikes that suggest exhaustion (late in signal).")
vol_spike_neutral_col = input.color(#FFFFFF, "Spike Neutral Color", group=grp_vol_adv, inline="vsc2", tooltip="Color for volume spikes with no directional context.")
show_vol_div = input.bool(true, "Show Vol-Price Divergence Markers", group=grp_vol_adv, tooltip="Plots flag markers when price trend and volume trend diverge. Bearish = price rising but volume fading. Bullish = price falling but volume fading.")
vol_div_bear_col = input.color(#FF4444, "Vol Div Bearish", group=grp_vol_adv, inline="vdc1", tooltip="Color for bearish volume-price divergence markers (price up, volume down).")
vol_div_bull_col = input.color(#4488FF, "Vol Div Bullish", group=grp_vol_adv, inline="vdc1", tooltip="Color for bullish volume-price divergence markers (price down, volume down).")
vol_div_lookback = input.int(10, "Divergence Lookback (bars)", group=grp_vol_adv, minval=3, maxval=30, tooltip="Number of bars to compare price trend vs volume trend for divergence detection. Default 10.")
vol_ribbon_dim = input.bool(true, "Dim Ribbon on Volume Contraction", group=grp_vol_adv, tooltip="Makes the RSI ribbon more transparent when volume is contracting. Visual cue that momentum may lack conviction.")

// ADX Settings
grp_adx = "ADX Trend Strength Filter"
use_adx = input.bool(true, "Enable ADX Filter", group=grp_adx, tooltip="When enabled, A+ and A grades require ADX above their thresholds, confirming trend strength. Disable for instruments where ADX is unreliable.")
adx_length = input.int(14, "ADX Length", group=grp_adx, tooltip="Lookback period for the ADX calculation. Standard is 14. Lower = more responsive to trend changes.")
adx_threshold_a_plus_in = input.float(25, "ADX Threshold for A+", group=grp_adx, tooltip="ADX must be above this for A+ grade. Higher = only fire in strong trends. Overridden by instrument preset. CL: 28, NQ/YM: 23.")
adx_threshold_a_in = input.float(20, "ADX Threshold for A", group=grp_adx, tooltip="ADX must be above this for A grade. Lower than A+ since A is a slightly weaker signal. Overridden by instrument preset. CL: 22, NQ/YM: 18.")

// MTF Timeframe Selection
grp_mtf = "🕐 MTF Timeframe Selection"
mtf_speed = input.string("Conservative", "MTF Speed", options=["Conservative", "Moderate", "Aggressive", "Custom"], group=grp_mtf, tooltip="Controls which higher timeframes are used for multi-timeframe RSI alignment.\n\nConservative (default): Widest timeframe spread. Slowest to confirm A+ but highest conviction. Best for swing-style entries and holding through pullbacks.\n  1-min chart: 5 / 15 / 60\n  3-min chart: 5 / 15 / 60\n  5-min chart: 15 / 60 / 240\n\nModerate: Faster A+ signals by using 30-min instead of 60-min as slow TF. Ideal for session-based NY futures trading where you don't need hourly confirmation.\n  1-min chart: 5 / 15 / 30\n  3-min chart: 5 / 15 / 30\n  5-min chart: 15 / 60 / 120\n\nAggressive: Tightest spread. Fastest signals but lower conviction on the slow TF. Best in strong trending sessions; enable anti-chop filters to compensate.\n  1-min chart: 5 / 9 / 15\n  3-min chart: 5 / 9 / 15\n  5-min chart: 9 / 15 / 60\n\nCustom: Enter your own three timeframes in the fields below.\n\nMust match between Signals and Management indicators.")
custom_tf_fast = input.timeframe("5", "Custom Fast TF", group=grp_mtf, tooltip="Only used when MTF Speed is set to 'Custom'.\n\nThe fastest (lowest) higher timeframe. This drives B-grade (1 TF) and contributes to all higher grades.\n\nMust be higher than your chart timeframe.\nCommon values: 3, 5, 9, 15\n\nExamples by chart TF:\n  1-min chart: 5\n  3-min chart: 5 or 9\n  5-min chart: 15")
custom_tf_mid  = input.timeframe("15", "Custom Mid TF", group=grp_mtf, tooltip="Only used when MTF Speed is set to 'Custom'.\n\nThe middle timeframe. Combined with Fast TF, this drives A-/B+ grades (2 TF alignment).\n\nMust be higher than Custom Fast TF.\nCommon values: 9, 15, 30, 60\n\nExamples by chart TF:\n  1-min chart: 15 or 30\n  3-min chart: 15 or 30\n  5-min chart: 60")
custom_tf_slow = input.timeframe("30", "Custom Slow TF", group=grp_mtf, tooltip="Only used when MTF Speed is set to 'Custom'.\n\nThe slowest (highest) higher timeframe. All three TFs aligned drives A/A+ grades (3 TF alignment). This is the main bottleneck for A+ signal speed — lower values = faster A+ signals but less macro confirmation.\n\nMust be higher than Custom Mid TF.\nCommon values: 15, 30, 60, 240, D\n\nExamples by chart TF:\n  1-min chart: 30 or 60\n  3-min chart: 30 or 60\n  5-min chart: 120 or 240")

// Time & Session Settings
grp_time = "⏰ Time & Session Filters"
sessionConfig = input.string("0930-1145,1330-1600:23456", "Session Config", group=grp_time, tooltip="Format: TIME1,TIME2,TIME3:DAYSDays: 1=Sun 2=Mon 3=Tue 4=Wed 5=Thu 6=Fri")

// Algo Windows
grp_algo = "🤖 Algo Windows"
algo_mode = input.string("OFF", "Algo Window Mode", options=["OFF", "TRADE WITH", "AVOID"], group=grp_algo, tooltip="OFF: Algo windows ignored. TRADE WITH: Only show signals during selected windows. AVOID: Suppress signals during selected windows (dodge algo manipulation).")
show_algo_bg = input.bool(true, "Highlight Algo Windows on Chart", group=grp_algo, tooltip="Shades the chart background during active algo windows so you can see when they are in effect.")
use_london     = input.bool(true, "London Open (0200-0500 ET)", group=grp_algo, inline="a1", tooltip="London session open — high volatility from European institutional flow.")
use_ny_open    = input.bool(true, "NY Open (0830-1000 ET)", group=grp_algo, inline="a1", tooltip="NY open / news window — highest volume period for US futures.")
use_ny_pm      = input.bool(true, "NY Afternoon (1330-1500 ET)", group=grp_algo, inline="a2", tooltip="Afternoon session — often sees trend continuation or reversals after lunch.")
use_ny_close   = input.bool(false, "NY Close (1500-1600 ET)", group=grp_algo, inline="a2", tooltip="Final hour — MOC orders and rebalancing. Often choppy, disabled by default.")
use_asia       = input.bool(false, "Asia Session (2000-0000 ET)", group=grp_algo, inline="a3", tooltip="Asia session — low volume, tight ranges on US futures. Disabled by default.")
use_globex_open = input.bool(false, "Globex Open (1800-1900 ET)", group=grp_algo, inline="a3", tooltip="Globex open — initial electronic session. Often gappy and thin. Disabled by default.")

// ADR (filter only — dashboard is in Management indicator)
grp_adr = "📏 ADR Filter"
enable_adr_filter = input.bool(false, "Enable ADR Exhaustion Filter", group=grp_adr, tooltip="When enabled, suppresses new signals if today's range has already consumed this % of the average daily range. Prevents entries when the day's move is likely exhausted.")
adr_length = input.int(10, "ADR Lookback (days)", group=grp_adr, minval=1, maxval=50, tooltip="Number of trading days to average for the daily range. 10 = ~2 weeks. Lower = more responsive to recent volatility changes.")
adr_exhaust_pct = input.float(85.0, "Exhaustion Threshold (%)", group=grp_adr, minval=50, maxval=100, tooltip="If today's high-low range exceeds this % of ADR, signals are suppressed. 85% = conservative, 95% = permissive.")

// Dashboard Settings
grp_dash = "Dashboard & Visuals"
showDash    = input.bool(true, "Show Grade Dashboard", group=grp_dash, tooltip="Shows the grade table (A+/A/A-/B+/B) with direction, MTF alignment, ADX, and stochastic info.")
dashPos     = input.string("Top Right", "Dashboard Position", options=["Top Right", "Bottom Right", "Top Left", "Bottom Left"], group=grp_dash, tooltip="Corner of the chart where the grade dashboard is placed.")
colorCandles = input.bool(true, "Color Candles by Grade", group=grp_dash, tooltip="Colors candle bodies based on the current grade. Green shades for long grades, red/purple shades for short grades, gray for no signal.")
useHAOutline = input.bool(true, "Heikin Ashi Outline Color", group=grp_dash, tooltip="Body = grade color, border/wicks = HA direction. Hide default candles.")
ha_bull_color_in = input.color(#26A69A, "HA Bullish Outline", group=grp_dash, inline="ha1", tooltip="Wick/border color when Heikin Ashi candle direction is bullish.")
ha_bear_color_in = input.color(#EF5350, "HA Bearish Outline", group=grp_dash, inline="ha1", tooltip="Wick/border color when Heikin Ashi candle direction is bearish.")
showStopLevels = input.bool(true, "Show Suggested Stop Levels", group=grp_dash, tooltip="Plots horizontal stop-loss reference levels based on fixed distance from entry price for the current grade.")
showTPLevels = input.bool(true, "Show Suggested Take Profit Levels", group=grp_dash, tooltip="Plots horizontal take-profit reference levels. Fixed-point targets per grade — use ATR TP in Management indicator for adaptive targets.")
ha_exit_warn = input.bool(true, "HA Momentum Exit Warning", group=grp_dash, tooltip="Shows an HA X marker when Heikin Ashi candles flip direction against your trade for N consecutive bars. Early exit warning.")
ha_exit_bars = input.int(2, "HA Bars to Confirm Flip", group=grp_dash, minval=1, maxval=5, tooltip="Number of consecutive HA candles in the opposite direction before the exit warning triggers. 1 = very sensitive, 3+ = more patient.")
ha_exit_color = input.color(#FF6B00, "HA Exit Marker Color", group=grp_dash, inline="hae1", tooltip="Color of the HA exit warning marker and its text on the chart.")
ha_exit_text_color = input.color(#FF6B00, "HA Exit Text", group=grp_dash, inline="hae1", tooltip="Text color of the HA✗ marker. Default matches marker color for a unified look.")
ha_exit_size = input.string("small", "HA Exit Marker Size", options=["tiny", "small", "normal", "large"], group=grp_dash, tooltip="Size of the HA exit warning markers.\n\nsmall (default): visible but subordinate to grade labels.\ntiny: minimal footprint.\nnormal/large: high visibility if exit warnings are critical to your workflow.")
ribbon_bull_color = input.color(#00ffbb, "Ribbon Bullish Color", group=grp_dash, inline="rib1", tooltip="Background ribbon color when RSI diff is bullish (above threshold).")
ribbon_bear_color = input.color(#ff0055, "Ribbon Bearish Color", group=grp_dash, inline="rib1", tooltip="Background ribbon color when RSI diff is bearish (below negative threshold).")
ribbon_transparency = input.int(85, "Ribbon Transparency", group=grp_dash, minval=0, maxval=95, step=5, tooltip="0 = fully opaque, 95 = barely visible. Default 85. Brightens to 65 when DStoch + RSI align.")
ribbon_consol_color = input.color(#000000, "Ribbon Consolidation Color", group=grp_dash, tooltip="Color the ribbon changes to during sideways consolidation. Default black.")
ribbon_time_config = input.string("0800-1600:23456", "Ribbon Visible Hours", group=grp_dash, tooltip="Independent time window for the RSI ribbon. Format: TIME1,TIME2:DAYS. The ribbon only appears during these hours. Separate from the signal session config.")

grp_sig_colors = "🎨 Signal Colors"
sig_long_color_aplus  = input.color(#00FF00, "A+ Long",  group=grp_sig_colors, inline="ca+", tooltip="Label color for each grade's long/short signal. Pair on each row: left = long, right = short.")
sig_short_color_aplus = input.color(#FF00FF, "A+ Short", group=grp_sig_colors, inline="ca+")
sig_long_color_a      = input.color(#00CC00, "A Long",   group=grp_sig_colors, inline="ca")
sig_short_color_a     = input.color(#FF0000, "A Short",  group=grp_sig_colors, inline="ca")
sig_long_color_aminus = input.color(#90EE90, "A- Long",  group=grp_sig_colors, inline="ca-")
sig_short_color_aminus= input.color(#FF6347, "A- Short", group=grp_sig_colors, inline="ca-")
sig_long_color_bplus  = input.color(#FFFF00, "B+ Long",  group=grp_sig_colors, inline="cb+")
sig_short_color_bplus = input.color(#4169E1, "B+ Short", group=grp_sig_colors, inline="cb+")
sig_long_color_b      = input.color(#FFA500, "B Long",   group=grp_sig_colors, inline="cb")
sig_short_color_b     = input.color(#9370DB, "B Short",  group=grp_sig_colors, inline="cb")
sig_long_text_color   = input.color(color.white, "Long Text Color",  group=grp_sig_colors, inline="ct", tooltip="Text color inside long/short signal labels (the A+, A, A-, B+, B letters).")
sig_short_text_color  = input.color(color.white, "Short Text Color", group=grp_sig_colors, inline="ct")

// Line Colors & Widths
grp_lines = "🎨 Line Colors & Widths"
ema_bull_color = input.color(color.green, "EMA Bullish", group=grp_lines, inline="ema1", tooltip="EMA line color when price is above the EMA (bullish bias).")
ema_bear_color = input.color(color.red, "EMA Bearish", group=grp_lines, inline="ema1", tooltip="EMA line color when price is below the EMA (bearish bias).")
ema_line_width = input.int(2, "EMA Width", group=grp_lines, minval=1, maxval=4, tooltip="Thickness of the EMA line.\n\n1: subtle.\n2 (default): standard.\n3-4: high visibility.\n\nSuggested range: 1-3.")
vwap_color = input.color(color.yellow, "VWAP", group=grp_lines, inline="vw1", tooltip="Color of the session VWAP line (plotted as circles).")
vwap_line_width = input.int(2, "VWAP Width", group=grp_lines, inline="vw1", tooltip="Thickness of the session VWAP circles.\n\nSuggested range: 1-3.")
ny_vwap_color = input.color(color.white, "NY Anchored VWAP", group=grp_lines, inline="vw2", tooltip="Color of the NY session anchored VWAP line (0930 ET).")
ny_vwap_line_width = input.int(2, "NY VWAP Width", group=grp_lines, inline="vw2", tooltip="Thickness of the NY anchored VWAP line.\n\nSuggested range: 1-3.")
prev_ny_vwap_color = input.color(color.gray, "Prev NY VWAP", group=grp_lines, inline="vw3", tooltip="Color of the previous day's NY session closing VWAP level.")
prev_ny_vwap_width = input.int(1, "Prev VWAP Width", group=grp_lines, inline="vw3", tooltip="Thickness of the previous NY VWAP line.\n\n1 (default): subtle reference.\n2: more prominent.\n\nSuggested range: 1-2.")
stop_long_color = input.color(color.red, "Stop Long", group=grp_lines, inline="sl1", tooltip="Color of the suggested stop-loss level for long positions.")
stop_short_color = input.color(color.green, "Stop Short", group=grp_lines, inline="sl1", tooltip="Color of the suggested stop-loss level for short positions.")
stop_line_width = input.int(2, "Stop Width", group=grp_lines, tooltip="Thickness of the stop-loss level crosses.\n\nSuggested range: 1-3.")
tp_long_color = input.color(#00BFFF, "TP Long", group=grp_lines, inline="tp1", tooltip="Color of the suggested take-profit level for long positions.")
tp_short_color = input.color(#00BFFF, "TP Short", group=grp_lines, inline="tp1", tooltip="Color of the suggested take-profit level for short positions.")
tp_line_width = input.int(2, "TP Width", group=grp_lines, tooltip="Thickness of the take-profit level crosses.\n\nSuggested range: 1-3.")

// Anti-Chop Filters
grp_chop = "🔇 Anti-Chop Filters"
cooldown_bars = input.int(5, "Signal Cooldown (bars)", group=grp_chop, minval=1, maxval=30, tooltip="After a signal fires, suppress new signals for this many bars. Prevents rapid-fire signals in choppy conditions. 5 = default, increase if seeing too many signals. On Renko/Range charts, the time-based cooldown below is used instead.")
persist_bars = input.int(2, "Grade Persistence (bars)", group=grp_chop, minval=1, maxval=5, tooltip="Once a grade appears, hold it for at least this many bars even if conditions briefly lapse. Prevents grade flickering. 1 = no persistence, 3+ = very sticky.")
cooldown_seconds = input.int(60, "Renko/Range Cooldown (seconds)", group=grp_chop, minval=10, maxval=600, step=10, tooltip="Time-based cooldown for Renko, Range, and other non-time-based chart types. Since bars form irregularly, this uses elapsed wall-clock time instead of bar count. 10s minimum, 60s default. Only applies on non-standard charts — candle charts use bar-based cooldown above.")
adx_floor_bb = input.float(15.0, "ADX Floor for B/B+", group=grp_chop, minval=0, tooltip="Minimum ADX required for B and B+ grades to fire. Filters out scalp signals in dead/ranging markets. 0 = disabled.")
suppress_low_vol_bb = input.bool(false, "Suppress B/B+ During LOW Volatility", group=grp_chop, tooltip="Blocks B/B+ signals when volume is below average. Prevents weak scalp signals in thin markets. Auto-enabled for CL preset.")
macro_trend_filter = input.bool(true, "Block Counter-Trend on B/B+/A-", group=grp_chop, tooltip="Prevents B, B+, and A- grades from firing against the slow timeframe (233 EMA) trend. Only allows these weaker grades in the macro direction.")
require_ribbon_bb = input.bool(false, "Require RSI Ribbon for B/B+", group=grp_chop, tooltip="When enabled, B and B+ signals only fire if the RSI ribbon is actively colored (not gray/neutral). Extra confirmation layer for scalp grades.")
enable_consol_filter = input.bool(false, "Gray Ribbon During Consolidation", group=grp_chop, tooltip="Turns the RSI ribbon gray when price stays within a tight range for N bars. Prevents false directional signals during sideways chop.")
consol_range_pts = input.float(10.0, "Consolidation Range (pts)", group=grp_chop, minval=1.0, tooltip="If the highest high minus lowest low over the lookback period is less than this, price is consolidating. NQ: 48, ES: 8")
consol_bars = input.int(20, "Consolidation Lookback (bars)", group=grp_chop, minval=5, maxval=100, tooltip="Number of bars to measure the price range over.")

// Consolidation Filter (Range vs ATR)
grp_consol_filter = "📊 Consolidation Filter (Range vs ATR)"
enable_consol_regime = input.bool(true, "Enable Consolidation Regime Detection", group=grp_consol_filter, tooltip="Classifies the current session as Tight Consolidation, Mild Consolidation, Normal, or Expansion based on developing range vs daily ATR. Shows regime in dashboard.")
consol_atr_length = input.int(14, "ATR Length", group=grp_consol_filter, minval=1, maxval=50, tooltip="Daily ATR lookback period for range classification. 14 = standard.")
consol_tight_thresh = input.float(0.50, "Tight Consolidation (x ATR)", group=grp_consol_filter, minval=0.1, maxval=1.0, step=0.05, tooltip="Range below this fraction of ATR = tight consolidation. Fade or sit out.")
consol_mild_thresh = input.float(0.75, "Mild Consolidation (x ATR)", group=grp_consol_filter, minval=0.1, maxval=1.5, step=0.05, tooltip="Range between tight and this = mild consolidation. Lean mean-revert.")
consol_expansion_thresh = input.float(1.00, "Expansion (x ATR)", group=grp_consol_filter, minval=0.5, maxval=2.0, step=0.05, tooltip="Range above this fraction = expansion/trend day. Lean into trend continuation.")

consol_cp1_hour = input.int(10, "Checkpoint 1 Hour (ET)", group=grp_consol_filter, minval=0, maxval=23, tooltip="First intraday checkpoint (ET hour, 24hr). Default 10 = 10:00 AM.")
consol_cp2_hour = input.int(12, "Checkpoint 2 Hour (ET)", group=grp_consol_filter, minval=0, maxval=23)
consol_cp3_hour = input.int(14, "Checkpoint 3 Hour (ET)", group=grp_consol_filter, minval=0, maxval=23)
consol_cp1_expect = input.float(0.30, "Expected Range % by CP1", group=grp_consol_filter, minval=0.05, maxval=1.0, step=0.05, tooltip="If range is below this fraction of ATR at checkpoint 1, session is likely consolidating.")
consol_cp2_expect = input.float(0.45, "Expected Range % by CP2", group=grp_consol_filter, minval=0.05, maxval=1.0, step=0.05)
consol_cp3_expect = input.float(0.60, "Expected Range % by CP3", group=grp_consol_filter, minval=0.05, maxval=1.0, step=0.05)

enable_prior_compress = input.bool(true, "Highlight Prior Day Compression", group=grp_consol_filter, tooltip="Flags when prior day(s) had tight range, signaling potential expansion today.")
compress_days = input.int(2, "Consecutive Compression Days", group=grp_consol_filter, minval=1, maxval=5, tooltip="Number of consecutive tight-range days to flag expansion potential.")
suppress_on_tight_consol = input.bool(false, "Suppress B/B+ in Tight Consolidation", group=grp_consol_filter, tooltip="Blocks B and B+ signals when the session regime is Tight Consolidation. Prevents scalps in dead range.")
suppress_all_tight_consol = input.bool(false, "Suppress ALL Grades in Tight Consolidation", group=grp_consol_filter, tooltip="Blocks ALL signals (A+, A, A-, B+, B) when the session regime is Tight Consolidation. Full sit-out mode for dead range days.")
show_consol_bg = input.bool(true, "Show Regime Background Shading", group=grp_consol_filter, tooltip="Tints the chart background based on consolidation regime: blue = tight, yellow = mild, red = expansion.")

// RSI Divergence Detection
grp_div = "🔀 RSI Divergence"
enable_divergence = input.bool(true, "Enable RSI Divergence Detection", group=grp_div, tooltip="Detects regular (classic) divergence between price swings and the short RSI oscillator.\n\nBearish divergence: price prints a higher high but RSI prints a lower high — momentum is weakening even as price pushes up. Warns that a long position may be losing steam.\n\nBullish divergence: price prints a lower low but RSI prints a higher low — selling pressure is fading even as price drops. Warns that a short position may be losing steam.\n\nThis is a WARNING overlay — it does not gate entries or modify grades. It adds a dashboard row, optional chart markers, and feeds into the Late Trend flag.")
div_lookback = input.int(5, "Pivot Lookback (bars)", group=grp_div, minval=2, maxval=15, tooltip="Number of bars required on EACH side of a swing point to confirm it as a pivot high or low.\n\nLower (2-3): detects more pivots, faster signals, but more noise — best in strong trends.\nDefault (5): balanced — ~15 min confirmation on a 3-min chart, ~25 min on 5-min.\nHigher (8-15): fewer but higher-conviction pivots — best for swing-style or 15-min charts.\n\nSuggested range: 3-10. Must match the tempo of your chart timeframe.")
div_max_bars = input.int(50, "Max Bars Between Pivots", group=grp_div, minval=10, maxval=100, tooltip="Maximum distance (in bars) between two consecutive pivots to form a valid divergence pair. Prevents ancient/stale pivots from triggering false divergence signals.\n\nLower (15-25): only very recent pivot pairs count — tighter, fewer signals.\nDefault (50): ~2.5 hours on a 3-min chart — covers a full session move.\nHigher (75-100): catches slower-developing divergence — better for 15-min+ charts.\n\nSuggested range: 20-80.")
show_div_markers = input.bool(true, "Show Divergence Markers on Chart", group=grp_div, tooltip="Plots a small labeled marker (DIV▼ or DIV▲) on the bar where divergence is first detected. Appears above price for bearish, below for bullish.")
show_div_lines = input.bool(true, "Draw Divergence Lines on Price", group=grp_div, tooltip="Draws a dashed line connecting the two price pivot points that form the divergence. Bearish line connects two swing highs, bullish line connects two swing lows. Lines are deleted when a new divergence of the same type is detected.")

// Divergence Visual Customization
grp_div_vis = "🔀 Divergence Visuals"
div_bear_color = input.color(color.new(#FF4444, 20), "Bearish Divergence Color", group=grp_div_vis, inline="dc1", tooltip="Color for bearish divergence markers and price lines. Used when price makes a higher high but RSI makes a lower high.")
div_bull_color = input.color(color.new(#44BBFF, 20), "Bullish Divergence Color", group=grp_div_vis, inline="dc1", tooltip="Color for bullish divergence markers and price lines. Used when price makes a lower low but RSI makes a higher low.")
div_marker_size = input.string("small", "Marker Size", options=["tiny", "small", "normal", "large"], group=grp_div_vis, tooltip="Size of the DIV▼ / DIV▲ chart markers.\n\ntiny: minimal footprint, won't crowd other signals.\nsmall (default): visible but subordinate to grade labels.\nnormal: same prominence as grade A signals.\nlarge: maximum visibility.\n\nSuggested: small or tiny if you have many other overlays.")
div_line_width = input.int(2, "Divergence Line Width", group=grp_div_vis, minval=1, maxval=4, tooltip="Thickness of the dashed line connecting divergence pivot points.\n\n1: subtle, blends with other chart elements.\n2 (default): clearly visible without dominating.\n3-4: high visibility, useful on busy charts.\n\nSuggested range: 1-3.")
div_line_style_in = input.string("Dashed", "Divergence Line Style", options=["Solid", "Dashed", "Dotted"], group=grp_div_vis, tooltip="Line style for divergence connection lines.\n\nDashed (default): distinguishable from EMA/VWAP solid lines.\nDotted: very subtle, minimal visual weight.\nSolid: maximum visibility.")

// ==========================================
// --- PRESET OVERRIDES ---
// ==========================================
ema_length = use_cl_preset ? 21 : use_ym_preset ? 34 : use_nq_preset ? 34 : ema_length_in
stoch_ob = use_cl_preset ? 72.0 : use_ym_preset ? 62.0 : use_nq_preset ? 65.0 : stoch_ob_in
stoch_os = use_cl_preset ? 30.0 : use_ym_preset ? 38.0 : use_nq_preset ? 35.0 : stoch_os_in
stoch_sell_level = use_cl_preset ? 80.0 : use_ym_preset ? 82.0 : stoch_sell_level_in
vol_mult = use_cl_preset ? 1.4 : use_ym_preset ? 1.2 : use_nq_preset ? 1.2 : vol_mult_in
adx_threshold_a_plus = use_cl_preset ? 28.0 : use_ym_preset ? 23.0 : use_nq_preset ? 23.0 : adx_threshold_a_plus_in
adx_threshold_a = use_cl_preset ? 22.0 : use_ym_preset ? 18.0 : use_nq_preset ? 18.0 : adx_threshold_a_in
use_low_vol_suppress = use_cl_preset ? true : suppress_low_vol_bb
preset_label = use_cl_preset ? "🛢️ CL" : use_nq_preset ? "📈 NQ" : use_es_preset ? "📊 ES" : use_ym_preset ? "🔷 YM" : "DEFAULT"
use_cl = use_cl_preset
use_nq = use_nq_preset

// RSI Speed overrides
rsi_short_len = rsi_speed == "Ultra-Fast" ? 3 : rsi_speed == "Fast" ? 4 : shortLen
rsi_long_len  = rsi_speed == "Ultra-Fast" ? 8 : rsi_speed == "Fast" ? 10 : longLen
rsi_short_sm  = rsi_speed == "Ultra-Fast" ? 1 : rsi_speed == "Fast" ? 1 : shortSmooth
rsi_long_sm   = rsi_speed == "Ultra-Fast" ? 1 : rsi_speed == "Fast" ? 2 : longSmooth
rsi_thresh    = rsi_speed == "Ultra-Fast" ? 0.5 : rsi_speed == "Fast" ? 0.75 : threshold
rsi_src       = rsi_speed == "Ultra-Fast" ? hlc3 : close

// ==========================================
// --- SESSION & ALGO PARSING ---
// ==========================================
config_parts = str.split(sessionConfig, ":")
times_str = array.get(config_parts, 0)
days_str = array.size(config_parts) > 1 ? array.get(config_parts, 1) : "23456"
time_windows = str.split(times_str, ",")
num_windows = array.size(time_windows)
day_suffix = ":" + days_str
in_w1 = num_windows >= 1 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 0)) + day_suffix, "America/New_York")) : false
in_w2 = num_windows >= 2 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 1)) + day_suffix, "America/New_York")) : false
in_w3 = num_windows >= 3 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 2)) + day_suffix, "America/New_York")) : false
in_w4 = num_windows >= 4 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 3)) + day_suffix, "America/New_York")) : false
in_w5 = num_windows >= 5 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 4)) + day_suffix, "America/New_York")) : false
in_w6 = num_windows >= 6 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 5)) + day_suffix, "America/New_York")) : false
inSession_multi = in_w1 or in_w2 or in_w3 or in_w4 or in_w5 or in_w6
active_win_label = in_w1 ? "W1" : in_w2 ? "W2" : in_w3 ? "W3" : in_w4 ? "W4" : in_w5 ? "W5" : in_w6 ? "W6" : ""
inSession_cl = not na(time(timeframe.period, "0900-1430:23456", "America/New_York"))
inSession_override = use_cl_preset ? inSession_cl : inSession_multi

in_algo_london     = use_london     and not na(time(timeframe.period, "0200-0500:23456", "America/New_York"))
in_algo_ny_open    = use_ny_open    and not na(time(timeframe.period, "0830-1000:23456", "America/New_York"))
in_algo_ny_pm      = use_ny_pm      and not na(time(timeframe.period, "1330-1500:23456", "America/New_York"))
in_algo_ny_close   = use_ny_close   and not na(time(timeframe.period, "1500-1600:23456", "America/New_York"))
in_algo_asia       = use_asia       and not na(time(timeframe.period, "2000-0000:23456", "America/New_York"))
in_algo_globex     = use_globex_open and not na(time(timeframe.period, "1800-1900:123456", "America/New_York"))
in_any_algo = in_algo_london or in_algo_ny_open or in_algo_ny_pm or in_algo_ny_close or in_algo_asia or in_algo_globex
algo_window_label = in_algo_london ? "LONDON" : in_algo_ny_open ? "NY OPEN" : in_algo_ny_pm ? "NY PM" : in_algo_ny_close ? "NY CLOSE" : in_algo_asia ? "ASIA" : in_algo_globex ? "GLOBEX" : "—"
algo_filter = algo_mode == "OFF" ? true : algo_mode == "TRADE WITH" ? in_any_algo : algo_mode == "AVOID" ? not in_any_algo : true

// ==========================================
// --- ADR FILTER ---
// ==========================================
// Developing RTH session high/low — tracks bar-by-bar during 0930-1600 ET
// Replaces request.security("D", high/low) which only returns completed daily bars
rth_is_open = not na(time(timeframe.period, "0930-1600:23456", "America/New_York"))
rth_just_opened = rth_is_open and not rth_is_open[1]

var float daily_high = na
var float daily_low = na

if rth_just_opened
    daily_high := high
    daily_low  := low
else if rth_is_open
    daily_high := math.max(nz(daily_high, high), high)
    daily_low  := math.min(nz(daily_low, low), low)

// ADR baseline — average of prior completed daily ranges (unchanged, correctly uses [1])
adr_val = request.security(cleanTicker, "D", ta.sma(high - low, adr_length)[1], lookahead = barmerge.lookahead_on)
today_range = not na(daily_high) and not na(daily_low) ? daily_high - daily_low : 0.0
adr_pct_used = adr_val > 0 ? (today_range / adr_val) * 100 : 0
adr_ok = not enable_adr_filter or adr_pct_used < adr_exhaust_pct

// ==========================================
// --- CONSOLIDATION REGIME (Range vs ATR) ---
// ==========================================
// Daily ATR for consolidation (uses configurable length)
consol_daily_atr = request.security(cleanTicker, "D", ta.rma(ta.tr, consol_atr_length), lookahead=barmerge.lookahead_on)

// Developing session range (reuses daily_high/daily_low from ADR section)
consol_session_range = daily_high - daily_low
consol_range_ratio = consol_daily_atr > 0 ? consol_session_range / consol_daily_atr : 0.0

// Previous day ranges for compression detection
consol_prev_high = request.security(cleanTicker, "D", high[1], lookahead=barmerge.lookahead_on)
consol_prev_low  = request.security(cleanTicker, "D", low[1], lookahead=barmerge.lookahead_on)
consol_prev_range = consol_prev_high - consol_prev_low
consol_prev_ratio = consol_daily_atr > 0 ? consol_prev_range / consol_daily_atr : 0.0

consol_prev2_high = request.security(cleanTicker, "D", high[2], lookahead=barmerge.lookahead_on)
consol_prev2_low  = request.security(cleanTicker, "D", low[2], lookahead=barmerge.lookahead_on)
consol_prev2_range = consol_prev2_high - consol_prev2_low
consol_prev2_ratio = consol_daily_atr > 0 ? consol_prev2_range / consol_daily_atr : 0.0

// Day classification
is_tight_consol = enable_consol_regime and consol_range_ratio < consol_tight_thresh
is_mild_consol  = enable_consol_regime and consol_range_ratio >= consol_tight_thresh and consol_range_ratio < consol_mild_thresh
is_normal_range = enable_consol_regime and consol_range_ratio >= consol_mild_thresh and consol_range_ratio < consol_expansion_thresh
is_expansion_day = enable_consol_regime and consol_range_ratio >= consol_expansion_thresh

consol_regime = is_tight_consol ? "TIGHT CONSOL" : is_mild_consol ? "MILD CONSOL" : is_expansion_day ? "EXPANSION" : is_normal_range ? "NORMAL" : "OFF"

// Time-based intraday checkpoints (ET)
consol_et_hour = hour(time, "America/New_York")

consol_passed_cp1 = consol_et_hour >= consol_cp1_hour
consol_passed_cp2 = consol_et_hour >= consol_cp2_hour
consol_passed_cp3 = consol_et_hour >= consol_cp3_hour

cp1_consolidating = consol_passed_cp1 and consol_range_ratio < consol_cp1_expect
cp2_consolidating = consol_passed_cp2 and consol_range_ratio < consol_cp2_expect
cp3_consolidating = consol_passed_cp3 and consol_range_ratio < consol_cp3_expect

consol_score = (cp1_consolidating ? 1 : 0) + (cp2_consolidating ? 1 : 0) + (cp3_consolidating ? 1 : 0)

// Prior day compression detection
prev_day_was_tight = consol_prev_ratio < consol_tight_thresh
prev2_day_was_tight = consol_prev2_ratio < consol_tight_thresh
consol_compression_alert = enable_prior_compress and (compress_days >= 2 ? (prev_day_was_tight and prev2_day_was_tight) : prev_day_was_tight)

// Consolidation guidance text
consol_guidance = is_tight_consol ? "FADE / SIT OUT" : is_mild_consol ? "CAUTION - MEAN REVERT" : is_expansion_day ? "TREND CONTINUATION" : "NORMAL SETUPS OK"

// ==========================================
// --- HELPER FUNCTIONS ---
// ==========================================
calc_double_rsi(src, short_len, long_len, short_smooth, long_smooth) =>
    rsiS = ta.ema(ta.rsi(src, short_len), short_smooth)
    rsiL = ta.ema(ta.rsi(src, long_len), long_smooth)
    diff = rsiS - rsiL
    [rsiS, rsiL, diff]

// Diff-only version — avoids 3-element tuple through request.security (saves 2 outputs per call)
calc_rsi_diff(src, short_len, long_len, short_smooth, long_smooth) =>
    rsiS = ta.ema(ta.rsi(src, short_len), short_smooth)
    rsiL = ta.ema(ta.rsi(src, long_len), long_smooth)
    rsiS - rsiL

calc_double_stoch(len, smooth) =>
    raw_stoch = ta.stoch(close, high, low, len)
    db_stoch = ta.ema(ta.ema(raw_stoch, smooth), smooth)
    db_stoch

get_rsi_direction(diff, thresh) =>
    diff > thresh ? 1 : diff < -thresh ? -1 : 0

// ==========================================
// --- CURRENT TIMEFRAME CALCULATIONS ---
// ==========================================
[rsiS_curr, rsiL_curr, diff_curr] = calc_double_rsi(rsi_src, rsi_short_len, rsi_long_len, rsi_short_sm, rsi_long_sm)
rsi_dir_curr = get_rsi_direction(diff_curr, rsi_thresh)

db_stoch_curr = calc_double_stoch(stochLen, stochSmth)
stoch_momentum_bull = db_stoch_curr > 50
stoch_momentum_bear = db_stoch_curr < 50
stoch_sell_signal = ta.crossunder(db_stoch_curr, stoch_sell_level)
stoch_buy_signal = ta.crossover(db_stoch_curr, stoch_buy_level)
stoch_signal_dir = stoch_sell_signal ? -1 : stoch_buy_signal ? 1 : 0
dstoch_rsi_confluence = (stoch_signal_dir == 1 and rsi_dir_curr == 1) or (stoch_signal_dir == -1 and rsi_dir_curr == -1)
dstoch_status = stoch_momentum_bull ? "BULL" : stoch_momentum_bear ? "BEAR" : "NEUTRAL"

ema_34 = ta.ema(close, ema_length)
ema_bull = close > ema_34
ema_bear = close < ema_34

// HMA Trend
hma_21 = ta.hma(close, 21)
hma_34 = ta.hma(close, 34)
hma_50 = ta.hma(close, 50)
hma_primary_bull = (close > hma_21) and (hma_21 > hma_34)
hma_primary_bear = (close < hma_21) and (hma_21 < hma_34)
hma_50_confirms_bull = hma_34 > hma_50
hma_50_confirms_bear = hma_34 < hma_50
hma_trend = hma_primary_bull and hma_50_confirms_bull ? "STRONG LONG" :hma_primary_bull ? "LONG" :hma_primary_bear and hma_50_confirms_bear ? "STRONG SHORT" :hma_primary_bear ? "SHORT" : "NEUTRAL"

// VWAP
vwap_val = ta.vwap(close)
vwap_bull = close > vwap_val
vwap_bear = close < vwap_val

// NY Anchored VWAP
ny_session_start = not na(time(timeframe.period, "0930-0930:23456", "America/New_York"))
in_ny_session = not na(time(timeframe.period, "0930-1600:23456", "America/New_York"))
ny_session_end = not na(time(timeframe.period, "1600-1600:23456", "America/New_York"))
var float sum_pv = 0.0
var float sum_v = 0.0
var float prev_ny_vwap_close = na
if ny_session_start
    sum_pv := 0.0
    sum_v := 0.0

// Volume Filter
hasVolume = not na(volume) and volume > 0
vol_ma = ta.sma(hasVolume ? volume : 1, vol_ma_len)
vol_above_avg = hasVolume ? (volume / vol_ma > vol_mult) : true
vol_filter = use_vol_filter ? vol_above_avg : true

// ==========================================
// --- VOLUME ANALYSIS (base calculations) ---
// ==========================================
// Expansion/Contraction: fast vol MA vs slow vol MA
vol_src = hasVolume ? volume : 0.0
vol_fast_ma = ta.sma(vol_src, vol_fast_len)
vol_slow_ma = ta.sma(vol_src, vol_slow_len)
vol_expanding = enable_vol_analysis and hasVolume and vol_fast_ma > vol_slow_ma and vol_fast_ma > vol_fast_ma[1]
vol_contracting = enable_vol_analysis and hasVolume and vol_fast_ma < vol_slow_ma and vol_fast_ma < vol_fast_ma[1]
vol_ratio_fast_slow = vol_slow_ma > 0 ? vol_fast_ma / vol_slow_ma : 1.0
vol_trend = vol_expanding ? "EXPANDING" : vol_contracting ? "CONTRACTING" : "STEADY"

// Spike Detection: current bar vs mean + N × stddev
vol_mean = ta.sma(vol_src, vol_spike_lookback)
vol_stdev = ta.stdev(vol_src, vol_spike_lookback)
vol_spike_threshold = vol_mean + vol_spike_mult * vol_stdev
vol_is_spike = enable_vol_analysis and hasVolume and volume > vol_spike_threshold and vol_stdev > 0
vol_spike_ratio = vol_mean > 0 ? volume / vol_mean : 0

// Price trend for divergence (uses only price data, no grade dependency)
price_rising = close > close[vol_div_lookback]
price_falling = close < close[vol_div_lookback]
vol_declining = vol_fast_ma < vol_fast_ma[vol_div_lookback] and vol_fast_ma < vol_slow_ma

// Accumulate BEFORE reading VWAP so current bar is included
if in_ny_session and hasVolume
    typical_price = (high + low + close) / 3
    sum_pv := sum_pv + (typical_price * volume)
    sum_v := sum_v + volume

ny_vwap = sum_v > 0 ? sum_pv / sum_v : na
if ny_session_end and not na(ny_vwap)
    prev_ny_vwap_close := ny_vwap

// ADX
[diPlus, diMinus, adx_value] = ta.dmi(adx_length, adx_length)
adx_filter_a_plus = not use_adx or adx_value >= adx_threshold_a_plus
adx_filter_a = not use_adx or adx_value >= adx_threshold_a
adx_falling = adx_value < adx_value[1]

// ATR (for volatility class only — sizing is in Management indicator)
atr_val = ta.atr(14)
atr_sma = ta.sma(atr_val, 50)
atr_ratio = atr_val / (atr_sma > 0 ? atr_sma : atr_val)
vol_class = atr_ratio >= 2.0 ? "EXTREME" : atr_ratio >= 1.4 ? "HIGH" : atr_ratio >= 0.8 ? "NORMAL" : "LOW"

// ==========================================
// --- RSI DIVERGENCE DETECTION ---
// ==========================================
// Regular divergence: price vs short RSI (rsiS_curr) using pivot-based detection.
// Bearish: price higher high + RSI lower high = momentum weakening, caution on longs.
// Bullish: price lower low + RSI higher low = selling exhausted, caution on shorts.
// Pivots are confirmed div_lookback bars after they form.

// Detect pivots on price and RSI
rsi_ph = enable_divergence ? ta.pivothigh(rsiS_curr, div_lookback, div_lookback) : na
rsi_pl = enable_divergence ? ta.pivotlow(rsiS_curr, div_lookback, div_lookback) : na
price_ph = enable_divergence ? ta.pivothigh(high, div_lookback, div_lookback) : na
price_pl = enable_divergence ? ta.pivotlow(low, div_lookback, div_lookback) : na

// Track the two most recent pivot highs (for bearish divergence)
var float prev_price_ph = na
var float prev_rsi_ph = na
var int   prev_ph_bar = na
var float curr_price_ph = na
var float curr_rsi_ph = na
var int   curr_ph_bar = na

if not na(price_ph) and not na(rsi_ph)
    prev_price_ph := curr_price_ph
    prev_rsi_ph   := curr_rsi_ph
    prev_ph_bar   := curr_ph_bar
    curr_price_ph := price_ph
    curr_rsi_ph   := rsi_ph
    curr_ph_bar   := bar_index - div_lookback

// Track the two most recent pivot lows (for bullish divergence)
var float prev_price_pl = na
var float prev_rsi_pl = na
var int   prev_pl_bar = na
var float curr_price_pl = na
var float curr_rsi_pl = na
var int   curr_pl_bar = na

if not na(price_pl) and not na(rsi_pl)
    prev_price_pl := curr_price_pl
    prev_rsi_pl   := curr_rsi_pl
    prev_pl_bar   := curr_pl_bar
    curr_price_pl := price_pl
    curr_rsi_pl   := rsi_pl
    curr_pl_bar   := bar_index - div_lookback

// Bearish divergence: new price high > previous, but RSI high < previous
ph_pair_valid = not na(prev_price_ph) and not na(curr_price_ph) and not na(curr_ph_bar) and not na(prev_ph_bar)
ph_not_stale = ph_pair_valid and (curr_ph_bar - prev_ph_bar) <= div_max_bars
raw_bear_div = ph_not_stale and (curr_price_ph > prev_price_ph) and (curr_rsi_ph < prev_rsi_ph)

// Bullish divergence: new price low < previous, but RSI low > previous
pl_pair_valid = not na(prev_price_pl) and not na(curr_price_pl) and not na(curr_pl_bar) and not na(prev_pl_bar)
pl_not_stale = pl_pair_valid and (curr_pl_bar - prev_pl_bar) <= div_max_bars
raw_bull_div = pl_not_stale and (curr_price_pl < prev_price_pl) and (curr_rsi_pl > prev_rsi_pl)

// NOTE: Divergence persistence flags, lines, and position-awareness are computed
// after the grading system (they depend on grade/direction/is_long_setup).

// ==========================================
// --- MULTI-TIMEFRAME ANALYSIS ---
// ==========================================
chart_minutes = timeframe.in_seconds() / 60

// Conservative: original wide spread — maximum conviction, slowest A+ confirmation
mtf_cons_fast = chart_minutes <= 3 ? "5"  : chart_minutes <= 5 ? "15" : chart_minutes <= 15 ? "60"  : "240"
mtf_cons_mid  = chart_minutes <= 3 ? "15" : chart_minutes <= 5 ? "60" : chart_minutes <= 15 ? "240" : "D"
mtf_cons_slow = chart_minutes <= 3 ? "60" : chart_minutes <= 5 ? "240": chart_minutes <= 15 ? "D"   : "W"

// Moderate: 30-min slow TF instead of 60 — faster A+ for session trading
mtf_mod_fast = chart_minutes <= 3 ? "5"  : chart_minutes <= 5 ? "15" : chart_minutes <= 15 ? "60"  : "120"
mtf_mod_mid  = chart_minutes <= 3 ? "15" : chart_minutes <= 5 ? "60" : chart_minutes <= 15 ? "120" : "240"
mtf_mod_slow = chart_minutes <= 3 ? "30" : chart_minutes <= 5 ? "120": chart_minutes <= 15 ? "240" : "D"

// Aggressive: tightest spread — fastest signals, use with anti-chop filters
mtf_agg_fast = chart_minutes <= 3 ? "5" : chart_minutes <= 5 ? "9"  : chart_minutes <= 15 ? "30" : "60"
mtf_agg_mid  = chart_minutes <= 3 ? "9" : chart_minutes <= 5 ? "15" : chart_minutes <= 15 ? "60" : "120"
mtf_agg_slow = chart_minutes <= 3 ? "15": chart_minutes <= 5 ? "60" : chart_minutes <= 15 ? "120": "240"

// Select active timeframes based on MTF Speed setting
// Custom uses input.timeframe() fields which return 'input string' — compatible with request.security()
mtf_fast = mtf_speed == "Moderate" ? mtf_mod_fast : mtf_speed == "Aggressive" ? mtf_agg_fast : mtf_speed == "Custom" ? custom_tf_fast : mtf_cons_fast
mtf_mid  = mtf_speed == "Moderate" ? mtf_mod_mid  : mtf_speed == "Aggressive" ? mtf_agg_mid  : mtf_speed == "Custom" ? custom_tf_mid  : mtf_cons_mid
mtf_slow = mtf_speed == "Moderate" ? mtf_mod_slow : mtf_speed == "Aggressive" ? mtf_agg_slow : mtf_speed == "Custom" ? custom_tf_slow : mtf_cons_slow

get_mtf_rsi_dir(tf) =>
    diff_raw = request.security(cleanTicker, tf, calc_rsi_diff(rsi_src, rsi_short_len, rsi_long_len, rsi_short_sm, rsi_long_sm), lookahead = barmerge.lookahead_on)
    get_rsi_direction(diff_raw[1], rsi_thresh)

rsi_dir_fast = get_mtf_rsi_dir(mtf_fast)
rsi_dir_mid  = get_mtf_rsi_dir(mtf_mid)
rsi_dir_slow = get_mtf_rsi_dir(mtf_slow)

mtf_3tf_bull = (rsi_dir_fast == 1) and (rsi_dir_mid == 1) and (rsi_dir_slow == 1)
mtf_3tf_bear = (rsi_dir_fast == -1) and (rsi_dir_mid == -1) and (rsi_dir_slow == -1)
mtf_2tf_bull = (rsi_dir_fast == 1) and (rsi_dir_mid == 1)
mtf_2tf_bear = (rsi_dir_fast == -1) and (rsi_dir_mid == -1)
mtf_1tf_bull = (rsi_dir_fast == 1)
mtf_1tf_bear = (rsi_dir_fast == -1)

// ==========================================
// --- GRADING SYSTEM ---
// ==========================================
is_a_plus_long = mtf_3tf_bull and (rsi_dir_curr == 1) and ema_bull and vwap_bull and stoch_momentum_bull and vol_filter and adx_filter_a_plus
is_a_plus_short = mtf_3tf_bear and (rsi_dir_curr == -1) and ema_bear and vwap_bear and stoch_momentum_bear and vol_filter and adx_filter_a_plus

is_a_long = mtf_3tf_bull and (rsi_dir_curr == 1) and ema_bull and stoch_momentum_bull and adx_filter_a and not is_a_plus_long
is_a_short = mtf_3tf_bear and (rsi_dir_curr == -1) and ema_bear and stoch_momentum_bear and adx_filter_a and not is_a_plus_short

// Macro trend filter
hma_macro_long = hma_trend == "LONG" or hma_trend == "STRONG LONG"
hma_macro_short = hma_trend == "SHORT" or hma_trend == "STRONG SHORT"
macro_ok_long = not macro_trend_filter or not hma_macro_short
macro_ok_short = not macro_trend_filter or not hma_macro_long

is_a_minus_long = mtf_2tf_bull and (rsi_dir_curr == 1) and ema_bull and stoch_momentum_bull and macro_ok_long and not is_a_long and not is_a_plus_long
is_a_minus_short = mtf_2tf_bear and (rsi_dir_curr == -1) and ema_bear and stoch_momentum_bear and macro_ok_short and not is_a_short and not is_a_plus_short

// Anti-chop + ribbon filter for B/B+
adx_floor_ok = adx_floor_bb <= 0 or adx_value >= adx_floor_bb
low_vol_ok = not use_low_vol_suppress or vol_class != "LOW"
consol_ok_bb = not suppress_on_tight_consol or not is_tight_consol
bb_chop_filter = adx_floor_ok and low_vol_ok and consol_ok_bb
ribbon_ok_long = not require_ribbon_bb or rsi_dir_curr == 1
ribbon_ok_short = not require_ribbon_bb or rsi_dir_curr == -1

// HMA 34 trend for B/B+ (smoother than EMA, better for quick scalps)
hma_bull = close > hma_34
hma_bear = close < hma_34

is_b_plus_long = mtf_2tf_bull and hma_bull and bb_chop_filter and macro_ok_long and ribbon_ok_long and not is_a_minus_long and not is_a_long and not is_a_plus_long
is_b_plus_short = mtf_2tf_bear and hma_bear and bb_chop_filter and macro_ok_short and ribbon_ok_short and not is_a_minus_short and not is_a_short and not is_a_plus_short

is_b_long = mtf_1tf_bull and hma_bull and bb_chop_filter and macro_ok_long and ribbon_ok_long and not is_b_plus_long and not is_a_minus_long and not is_a_long and not is_a_plus_long
is_b_short = mtf_1tf_bear and hma_bear and bb_chop_filter and macro_ok_short and ribbon_ok_short and not is_b_plus_short and not is_a_minus_short and not is_a_short and not is_a_plus_short

grade = is_a_plus_long or is_a_plus_short ? "A+" :is_a_long or is_a_short ? "A" :is_a_minus_long or is_a_minus_short ? "A-" :is_b_plus_long or is_b_plus_short ? "B+" :is_b_long or is_b_short ? "B" : "NONE"

is_long_setup = is_a_plus_long or is_a_long or is_a_minus_long or is_b_plus_long or is_b_long
is_short_setup = is_a_plus_short or is_a_short or is_a_minus_short or is_b_plus_short or is_b_short
direction = is_long_setup ? "LONG" : is_short_setup ? "SHORT" : "NEUTRAL"

// ==========================================
// --- RSI DIVERGENCE (Part 2: Persistence & Position Awareness) ---
// ==========================================
// Fires on the bar the second pivot is confirmed, then persists until:
// direction flips, grade goes NONE, or a new same-type pivot without divergence.
var bool div_bear_active = false
var bool div_bull_active = false

bear_cleared = not na(price_ph) and not na(rsi_ph) and not raw_bear_div
bull_cleared = not na(price_pl) and not na(rsi_pl) and not raw_bull_div

if raw_bear_div and not raw_bear_div[1]
    div_bear_active := true
if bear_cleared or direction == "SHORT" or grade == "NONE"
    div_bear_active := false

if raw_bull_div and not raw_bull_div[1]
    div_bull_active := true
if bull_cleared or direction == "LONG" or grade == "NONE"
    div_bull_active := false

// Divergence visual resolvers
div_lstyle = div_line_style_in == "Solid" ? line.style_solid : div_line_style_in == "Dotted" ? line.style_dotted : line.style_dashed
div_msize = div_marker_size == "tiny" ? size.tiny : div_marker_size == "normal" ? size.normal : div_marker_size == "large" ? size.large : size.small
ds_msize = ds_marker_size == "tiny" ? size.tiny : ds_marker_size == "normal" ? size.normal : ds_marker_size == "large" ? size.large : size.small
ha_exit_msize = ha_exit_size == "tiny" ? size.tiny : ha_exit_size == "normal" ? size.normal : ha_exit_size == "large" ? size.large : size.small

// Divergence is working against current position direction
div_against_position = (div_bear_active and is_long_setup) or (div_bull_active and is_short_setup)

// Divergence lines on price chart (connecting the two pivot swing points)
var line div_bear_line = na
var line div_bull_line = na

if raw_bear_div and not raw_bear_div[1] and show_div_lines and enable_divergence
    line.delete(div_bear_line)
    div_bear_line := line.new(prev_ph_bar, prev_price_ph, curr_ph_bar, curr_price_ph, color=div_bear_color, width=div_line_width, style=div_lstyle)

if raw_bull_div and not raw_bull_div[1] and show_div_lines and enable_divergence
    line.delete(div_bull_line)
    div_bull_line := line.new(prev_pl_bar, prev_price_pl, curr_pl_bar, curr_price_pl, color=div_bull_color, width=div_line_width, style=div_lstyle)

// Late-trend warning (includes divergence against position)
late_trend_flag = (grade == "A+" or grade == "A") and (adx_falling or adr_pct_used > 70 or div_against_position)

// SL values (NQ: backtested CONS-TIGHT | YM: 1pt = 1tick)
sl_aplus = use_cl_preset ? 0.40 : use_nq_preset ? 13.0 : use_ym_preset ? 15.0 : 15.0
sl_a     = use_cl_preset ? 0.40 : use_nq_preset ? 13.0 : use_ym_preset ? 15.0 : 15.0
sl_aminus = use_cl_preset ? 0.30 : use_nq_preset ? 10.0 : use_ym_preset ? 12.0 : 15.0
sl_bplus  = use_cl_preset ? 0.30 : use_nq_preset ? 10.0 : use_ym_preset ? 10.0 : 15.0
sl_b      = use_cl_preset ? 0.30 : use_nq_preset ? 8.0 : use_ym_preset ? 8.0 : 15.0

// TP values (NQ: backtested CONS-TIGHT | YM: wider targets for runners)
tp_aplus = use_cl_preset ? 0.20 : use_nq_preset ? 25.0 : use_ym_preset ? 35.0 : 6.0
tp_a     = use_cl_preset ? 0.20 : use_nq_preset ? 20.0 : use_ym_preset ? 25.0 : 6.0
tp_aminus = use_cl_preset ? 0.15 : use_nq_preset ? 15.0 : use_ym_preset ? 18.0 : 4.0
tp_bplus  = use_cl_preset ? 0.10 : use_nq_preset ? 15.0 : use_ym_preset ? 15.0 : 3.0
tp_b      = use_cl_preset ? 0.08 : use_nq_preset ? 12.0 : use_ym_preset ? 10.0 : 2.0

// ==========================================
// --- TIME & SESSION FILTER ---
// ==========================================
inSession = inSession_override
consol_all_ok = not suppress_all_tight_consol or not is_tight_consol
tradeAllowed = inSession and algo_filter and adr_ok and consol_all_ok

// ==========================================
// --- PERSISTENCE & COOLDOWN ---
// ==========================================
var int persist_count = 0

// Grade numeric ranking for upgrade detection
grade_num_persist = grade == "A+" ? 5 : grade == "A" ? 4 : grade == "A-" ? 3 : grade == "B+" ? 2 : grade == "B" ? 1 : 0
prev_grade_num_persist = nz(grade_num_persist[1], 0)

// Detect upgrade vs downgrade vs direction flip
direction_flipped = direction != direction[1] and direction != "NEUTRAL" and direction[1] != "NEUTRAL"
is_upgrade = grade_num_persist > prev_grade_num_persist and not direction_flipped and grade != "NONE" and grade[1] != "NONE"
grade_changed = grade != grade[1] or direction != direction[1]

// Upgrades skip persistence — conditions got STRONGER, that's confirmation
// Downgrades and direction flips reset persistence — need to re-confirm
persist_count := is_upgrade ? persist_bars : (grade_changed ? 1 : (grade != "NONE" ? persist_count + 1 : 0))
grade_persisted = persist_count >= persist_bars

var int bars_since_signal = 999
var bool prev_filtered_signal = false  // stores prior bar's signal state
raw_new_signal = grade_persisted and grade != "NONE" and (grade_changed or not grade_persisted[1])

// Cooldown: time-based for Renko/Range, bar-based for candles
cooldown_ms = cooldown_seconds * 1000
elapsed_since_signal_ms := prev_filtered_signal ? 0 : elapsed_since_signal_ms + nz(bar_time_seconds, 60000)
cooldown_ok = is_nonstandard ? (elapsed_since_signal_ms >= cooldown_ms) : (bars_since_signal >= cooldown_bars)

filtered_new_signal = raw_new_signal and cooldown_ok
bars_since_signal := filtered_new_signal ? 0 : bars_since_signal + 1
if filtered_new_signal
    elapsed_since_signal_ms := 0
prev_filtered_signal := filtered_new_signal  // store for next bar

var int signal_duration = 0
signal_duration := grade == "NONE" ? 0 : (filtered_new_signal ? 1 : signal_duration + 1)

// Reminder repeat: ~10 min between reminders (time-aware for Renko)
tf_seconds = timeframe.in_seconds()
bars_per_minute = tf_seconds > 0 ? 60.0 / tf_seconds : 1.0  // fallback 1 bar/min for Renko
reminder_bars = math.max(1, math.round(10 * bars_per_minute))
is_reminder = grade != "NONE" and signal_duration > 1 and signal_duration % reminder_bars == 0
show_signal = (filtered_new_signal or is_reminder) and tradeAllowed

// Signal duration in minutes (handles Renko where timeframe.in_seconds() = 0)
var int signal_start_time = 0
if filtered_new_signal
    signal_start_time := time
signal_dur_minutes = is_nonstandard ? math.max(0, (time - signal_start_time) / 60000.0) : signal_duration * (tf_seconds / 60.0)

// Reset age counter when reminder confirms same grade is still active
// Dashboard now shows "time since last confirmation" instead of total signal age
if is_reminder
    signal_duration := 1

signal_dur_text = signal_dur_minutes >= 60 ? str.tostring(math.floor(signal_dur_minutes / 60)) + "h " + str.tostring(math.round(signal_dur_minutes % 60)) + "m" : str.tostring(signal_dur_minutes, "0") + "m"

// Filtered signal flags (fire on initial signal + repeat reminders)
sig_a_plus_long  = is_a_plus_long and show_signal and direction == "LONG"
sig_a_plus_short = is_a_plus_short and show_signal and direction == "SHORT"
sig_a_long       = is_a_long and show_signal and direction == "LONG"
sig_a_short      = is_a_short and show_signal and direction == "SHORT"
sig_a_minus_long = is_a_minus_long and show_signal and direction == "LONG"
sig_a_minus_short = is_a_minus_short and show_signal and direction == "SHORT"
sig_b_plus_long  = is_b_plus_long and show_signal and direction == "LONG"
sig_b_plus_short = is_b_plus_short and show_signal and direction == "SHORT"
sig_b_long       = is_b_long and show_signal and direction == "LONG"
sig_b_short      = is_b_short and show_signal and direction == "SHORT"

// ==========================================
// --- VOLUME ANALYSIS (contextual — needs grade/direction) ---
// ==========================================
// Spike context: confirming vs exhaustion
vol_spike_early = vol_is_spike and signal_duration <= 5
vol_spike_late = vol_is_spike and signal_duration > 10
vol_spike_context = vol_spike_early ? "CONFIRM" : vol_spike_late ? "EXHAUST" : vol_is_spike ? "SPIKE" : "—"

// Volume-Price Divergence
// Bearish: price up + volume fading during a long = exhaustion warning
vol_div_bearish = enable_vol_analysis and price_rising and vol_declining and is_long_setup
// Bullish: price down + volume fading during a short = exhaustion warning
vol_div_bullish = enable_vol_analysis and price_falling and vol_declining and is_short_setup
vol_div_active = vol_div_bearish or vol_div_bullish

// ==========================================
// --- ENTRY TRACKING & TP/SL HIT DETECTION ---
// ==========================================
// Lock entry price and levels on new signal for alert purposes
var float sig_entry_price = na
var int sig_entry_dir = 0  // 1=long, -1=short
var float sig_sl_level = na
var float sig_tp_level = na
var bool sig_tp_hit = false
var bool sig_sl_hit = false

// Calculate current grade's SL/TP distance
current_sl_dist = grade == "A+" ? sl_aplus : grade == "A" ? sl_a : grade == "A-" ? sl_aminus : grade == "B+" ? sl_bplus : grade == "B" ? sl_b : 0.0
current_tp_dist = grade == "A+" ? tp_aplus : grade == "A" ? tp_a : grade == "A-" ? tp_aminus : grade == "B+" ? tp_bplus : grade == "B" ? tp_b : 0.0

// New signal → lock entry + levels
if filtered_new_signal and grade != "NONE"
    sig_entry_price := close
    sig_entry_dir := direction == "LONG" ? 1 : -1
    sig_tp_hit := false
    sig_sl_hit := false
    sig_sl_level := direction == "LONG" ? close - current_sl_dist : close + current_sl_dist
    sig_tp_level := direction == "LONG" ? close + current_tp_dist : close - current_tp_dist

// Grade gone → reset
if grade == "NONE" and grade[1] != "NONE"
    sig_entry_price := na
    sig_entry_dir := 0
    sig_sl_level := na
    sig_tp_level := na
    sig_tp_hit := false
    sig_sl_hit := false

// TP hit detection (fire once per trade)
sig_tp_just_hit = false
if not sig_tp_hit and not na(sig_tp_level) and sig_entry_dir != 0
    if sig_entry_dir == 1 and high >= sig_tp_level
        sig_tp_hit := true
        sig_tp_just_hit := true
    if sig_entry_dir == -1 and low <= sig_tp_level
        sig_tp_hit := true
        sig_tp_just_hit := true

// SL hit detection (fire once per trade)
sig_sl_just_hit = false
if not sig_sl_hit and not na(sig_sl_level) and sig_entry_dir != 0
    if sig_entry_dir == 1 and low <= sig_sl_level
        sig_sl_hit := true
        sig_sl_just_hit := true
    if sig_entry_dir == -1 and high >= sig_sl_level
        sig_sl_hit := true
        sig_sl_just_hit := true



// ==========================================
// --- VISUAL ELEMENTS ---
// ==========================================
// EMA
plot(ema_34, "34 EMA", color=ema_bull ? ema_bull_color : ema_bear_color, linewidth=ema_line_width)

// VWAP
plot(show_vwap ? vwap_val : na, "VWAP", color=color.new(vwap_color, 20), linewidth=vwap_line_width, style=plot.style_circles)
plot(show_ny_vwap and in_ny_session ? ny_vwap : na, "NY Anchored VWAP", color=color.new(ny_vwap_color, 30), linewidth=ny_vwap_line_width, style=plot.style_line)
plot(show_prev_ny_vwap ? prev_ny_vwap_close : na, "Prev NY VWAP", color=color.new(prev_ny_vwap_color, 70), linewidth=prev_ny_vwap_width, style=plot.style_line)

// RSI Background Ribbon
// Consolidation detection: resets after 4 consecutive bars outside range
// Prevents false breakouts that whipsaw back into the range
var int consol_count = 0
var float consol_hi = na
var float consol_lo = na
var int breakout_count = 0

if consol_count == 0 or na(consol_hi)
    consol_hi := high
    consol_lo := low
    consol_count := 1
    breakout_count := 0
else
    new_hi = math.max(consol_hi, high)
    new_lo = math.min(consol_lo, low)
    new_range = new_hi - new_lo
    if new_range >= consol_range_pts
        // Range exceeded — count consecutive bars outside
        breakout_count := breakout_count + 1
        if breakout_count >= 4
            // Confirmed breakout — reset everything
            consol_hi := high
            consol_lo := low
            consol_count := 1
            breakout_count := 0
        else
            // Not confirmed yet — keep tracking but don't reset
            consol_hi := new_hi
            consol_lo := new_lo
            consol_count := consol_count + 1
    else
        // Back inside range — reset breakout counter
        breakout_count := 0
        consol_hi := new_hi
        consol_lo := new_lo
        consol_count := consol_count + 1

is_consolidating = enable_consol_filter and consol_count >= consol_bars

// Parse ribbon time window (independent from signal session)
rib_parts = str.split(ribbon_time_config, ":")
rib_times_str = array.get(rib_parts, 0)
rib_days_str = array.size(rib_parts) > 1 ? array.get(rib_parts, 1) : "23456"
rib_windows = str.split(rib_times_str, ",")
rib_num_win = array.size(rib_windows)
rib_day_sfx = ":" + rib_days_str
rib_in_w1 = rib_num_win >= 1 ? not na(time(timeframe.period, str.trim(array.get(rib_windows, 0)) + rib_day_sfx, "America/New_York")) : false
rib_in_w2 = rib_num_win >= 2 ? not na(time(timeframe.period, str.trim(array.get(rib_windows, 1)) + rib_day_sfx, "America/New_York")) : false
rib_in_w3 = rib_num_win >= 3 ? not na(time(timeframe.period, str.trim(array.get(rib_windows, 2)) + rib_day_sfx, "America/New_York")) : false
ribbonVisible = rib_in_w1 or rib_in_w2 or rib_in_w3

// Volume-aware ribbon transparency: brighten on expansion, dim on contraction
vol_ribbon_adjust = (vol_ribbon_dim and vol_contracting) ? 15 : (vol_expanding and ribbonVisible) ? -10 : 0
bg_transparency_base = (brighten_on_confluence and dstoch_rsi_confluence and ribbonVisible) ? math.max(0, ribbon_transparency - 20) : ribbon_transparency
bg_transparency = math.max(0, math.min(95, bg_transparency_base + vol_ribbon_adjust))
bg_color = not ribbonVisible ? na : is_consolidating ? color.new(ribbon_consol_color, 90) : diff_curr > rsi_thresh ? color.new(ribbon_bull_color, bg_transparency) : diff_curr < -rsi_thresh ? color.new(ribbon_bear_color, bg_transparency) : color.new(color.gray, 90)
bgcolor(bg_color, title="RSI Momentum Ribbon")

// Algo Window Background (info on dashboard only — removed bgcolor to save plot output)

// Consolidation Regime (info on dashboard only — removed bgcolor to save plot output)

// DStoch Crossover Markers
// DStoch Crossover Markers (using label.new — saves plot outputs)
if show_stoch_signals and stoch_buy_signal and tradeAllowed
    label.new(bar_index, low, "DS▲", style=label.style_label_up, color=ds_buy_color, textcolor=ds_buy_text_color, size=ds_msize, yloc=yloc.belowbar)
if show_stoch_signals and stoch_sell_signal and tradeAllowed
    label.new(bar_index, high, "DS▼", style=label.style_label_down, color=ds_sell_color, textcolor=ds_sell_text_color, size=ds_msize, yloc=yloc.abovebar)

// Heikin Ashi Calculation
haClose = (open + high + low + close) / 4
var float haOpen = na
haOpen := na(haOpen[1]) ? (open + close) / 2 : (nz(haOpen[1]) + nz(haClose[1])) / 2
ha_bull = haClose >= haOpen
ha_color = ha_bull ? color.new(ha_bull_color_in, 0) : color.new(ha_bear_color_in, 0)

// HA Momentum Exit Warning
var int ha_against_count = 0
ha_against = (is_long_setup and not ha_bull) or (is_short_setup and ha_bull)
ha_against_count := grade == "NONE" ? 0 : ha_against ? ha_against_count + 1 : 0
ha_exit_signal = ha_exit_warn and ha_against_count == ha_exit_bars and ha_against_count[1] < ha_exit_bars

// Candle Coloring
candle_color = not colorCandles or not tradeAllowed ? na : is_a_plus_long ? sig_long_color_aplus : is_a_plus_short ? sig_short_color_aplus : is_a_long ? sig_long_color_a : is_a_short ? sig_short_color_a : is_a_minus_long ? sig_long_color_aminus : is_a_minus_short ? sig_short_color_aminus : is_b_plus_long ? sig_long_color_bplus : is_b_plus_short ? sig_short_color_bplus : is_b_long ? sig_long_color_b : is_b_short ? sig_short_color_b : color.new(#080808, 0)

plotcandle(useHAOutline ? open : na, useHAOutline ? high : na, useHAOutline ? low : na, useHAOutline ? close : na, title="Grade + HA Candles", color=colorCandles ? candle_color : (ha_bull ? color.new(ha_bull_color_in, 0) : color.new(ha_bear_color_in, 0)), wickcolor=ha_color, bordercolor=ha_color)
barcolor(not useHAOutline ? candle_color : na)

// Signal Labels (using label.new — doesn't count toward 64 plot limit)
// Grade sizes: A+=large, A=normal, A-=small, B+=small, B=tiny
// Mapped to label sizes: A+=size.large, A=size.normal, A-=size.small, B+=size.small, B=size.tiny
if sig_a_plus_long
    label.new(bar_index, low, "A+", style=label.style_label_up, color=sig_long_color_aplus, textcolor=sig_long_text_color, size=size.large, yloc=yloc.belowbar)
if sig_a_plus_short
    label.new(bar_index, high, "A+", style=label.style_label_down, color=sig_short_color_aplus, textcolor=sig_short_text_color, size=size.large, yloc=yloc.abovebar)
if sig_a_long
    label.new(bar_index, low, "A", style=label.style_label_up, color=sig_long_color_a, textcolor=sig_long_text_color, size=size.normal, yloc=yloc.belowbar)
if sig_a_short
    label.new(bar_index, high, "A", style=label.style_label_down, color=sig_short_color_a, textcolor=sig_short_text_color, size=size.normal, yloc=yloc.abovebar)
if sig_a_minus_long
    label.new(bar_index, low, "A-", style=label.style_label_up, color=sig_long_color_aminus, textcolor=sig_long_text_color, size=size.small, yloc=yloc.belowbar)
if sig_a_minus_short
    label.new(bar_index, high, "A-", style=label.style_label_down, color=sig_short_color_aminus, textcolor=sig_short_text_color, size=size.small, yloc=yloc.abovebar)
if sig_b_plus_long
    label.new(bar_index, low, "B+", style=label.style_label_up, color=sig_long_color_bplus, textcolor=sig_long_text_color, size=size.small, yloc=yloc.belowbar)
if sig_b_plus_short
    label.new(bar_index, high, "B+", style=label.style_label_down, color=sig_short_color_bplus, textcolor=sig_short_text_color, size=size.small, yloc=yloc.abovebar)
if sig_b_long
    label.new(bar_index, low, "B", style=label.style_label_up, color=sig_long_color_b, textcolor=sig_long_text_color, size=size.tiny, yloc=yloc.belowbar)
if sig_b_short
    label.new(bar_index, high, "B", style=label.style_label_down, color=sig_short_color_b, textcolor=sig_short_text_color, size=size.tiny, yloc=yloc.abovebar)

// HA Exit Warning
// HA Exit Warning (using label.new — saves plot outputs)
if ha_exit_signal and is_long_setup and tradeAllowed
    label.new(bar_index, high, "HA✗", style=label.style_xcross, color=ha_exit_color, textcolor=ha_exit_text_color, size=ha_exit_msize, yloc=yloc.abovebar)
if ha_exit_signal and is_short_setup and tradeAllowed
    label.new(bar_index, low, "HA✗", style=label.style_xcross, color=ha_exit_color, textcolor=ha_exit_text_color, size=ha_exit_msize, yloc=yloc.belowbar)

// RSI Divergence Markers (using label.new — does not count toward 64 plot limit)
div_bear_cond = show_div_markers and enable_divergence and raw_bear_div and not raw_bear_div[1] and tradeAllowed
div_bull_cond = show_div_markers and enable_divergence and raw_bull_div and not raw_bull_div[1] and tradeAllowed

if div_bear_cond
    label.new(bar_index, high, "DIV▼", style=label.style_triangledown, color=div_bear_color, textcolor=div_bear_color, size=div_msize, yloc=yloc.abovebar)
if div_bull_cond
    label.new(bar_index, low, "DIV▲", style=label.style_triangleup, color=div_bull_color, textcolor=div_bull_color, size=div_msize, yloc=yloc.belowbar)

// Stop Loss Levels (merged long/short into single plot)
stop_level_long = is_a_plus_long ? close - sl_aplus : is_a_long ? close - sl_a : is_a_minus_long ? close - sl_aminus : is_b_plus_long ? close - sl_bplus : is_b_long ? close - sl_b : na
stop_level_short = is_a_plus_short ? close + sl_aplus : is_a_short ? close + sl_a : is_a_minus_short ? close + sl_aminus : is_b_plus_short ? close + sl_bplus : is_b_short ? close + sl_b : na
stop_level = showStopLevels and tradeAllowed ? (is_long_setup ? stop_level_long : is_short_setup ? stop_level_short : na) : na
stop_color = is_long_setup ? color.new(stop_long_color, 30) : color.new(stop_short_color, 30)
plot(stop_level, "Stop Level", color=stop_color, linewidth=stop_line_width, style=plot.style_cross)

// Take Profit Levels (merged long/short into single plot)
tp_level_long = is_a_plus_long ? close + tp_aplus : is_a_long ? close + tp_a : is_a_minus_long ? close + tp_aminus : is_b_plus_long ? close + tp_bplus : is_b_long ? close + tp_b : na
tp_level_short = is_a_plus_short ? close - tp_aplus : is_a_short ? close - tp_a : is_a_minus_short ? close - tp_aminus : is_b_plus_short ? close - tp_bplus : is_b_short ? close - tp_b : na
tp_level = showTPLevels and tradeAllowed ? (is_long_setup ? tp_level_long : is_short_setup ? tp_level_short : na) : na
tp_color = is_long_setup ? color.new(tp_long_color, 20) : color.new(tp_short_color, 20)
plot(tp_level, "TP Level", color=tp_color, linewidth=tp_line_width, style=plot.style_cross)

// Volume Spike Markers (using label.new — doesn't count toward 64 plot limit)
vol_spike_confirm_color = color.new(vol_spike_confirm_col, 0)
vol_spike_exhaust_color = color.new(vol_spike_exhaust_col, 0)
vol_spike_neutral_color = color.new(vol_spike_neutral_col, 30)
if show_vol_spikes and vol_is_spike and tradeAllowed and vol_spike_early
    label.new(bar_index, low, "V+", style=label.style_diamond, color=vol_spike_confirm_color, textcolor=vol_spike_confirm_color, size=size.tiny, yloc=yloc.belowbar)
if show_vol_spikes and vol_is_spike and tradeAllowed and vol_spike_late
    label.new(bar_index, high, "V!", style=label.style_diamond, color=vol_spike_exhaust_color, textcolor=vol_spike_exhaust_color, size=size.tiny, yloc=yloc.abovebar)
if show_vol_spikes and vol_is_spike and tradeAllowed and not vol_spike_early and not vol_spike_late
    label.new(bar_index, low, "V", style=label.style_diamond, color=vol_spike_neutral_color, textcolor=vol_spike_neutral_color, size=size.tiny, yloc=yloc.belowbar)

// Volume-Price Divergence Markers (using label.new)
if show_vol_div and vol_div_bearish and tradeAllowed and enable_vol_analysis
    label.new(bar_index, high, "VD▼", style=label.style_flag, color=color.new(vol_div_bear_col, 20), textcolor=color.new(vol_div_bear_col, 0), size=size.tiny, yloc=yloc.abovebar)
if show_vol_div and vol_div_bullish and tradeAllowed and enable_vol_analysis
    label.new(bar_index, low, "VD▲", style=label.style_flag, color=color.new(vol_div_bull_col, 20), textcolor=color.new(vol_div_bull_col, 0), size=size.tiny, yloc=yloc.belowbar)

// ==========================================
// --- MAIN DASHBOARD ---
// ==========================================
t_pos = switch dashPos
    "Top Right"    => position.top_right
    "Bottom Right" => position.bottom_right
    "Top Left"     => position.top_left
    "Bottom Left"  => position.bottom_left
    => position.top_right

var table dash_table = table.new(t_pos, 2, 17, border_width=1, frame_color=color.new(color.white, 80), border_color=color.new(color.gray, 80))

if showDash and barstate.islast
    // Preset
    // Preset + Chart Type
    preset_bg = use_cl_preset ? color.new(#FF6B00, 70) : use_nq_preset ? color.new(#818cf8, 70) : use_es_preset ? color.new(#f59e0b, 70) : color.new(color.gray, 85)
    chart_info = is_renko ? chart_type_label + " " + str.tostring(brick_size, use_cl_preset ? "0.02" : "0") + (use_cl_preset ? "" : "pt") : chart_type_label
    renko_warn = is_nonstandard ? " ⚡" : ""
    table.cell(dash_table, 0, 0, "PRESET", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(dash_table, 1, 0, preset_label + " | " + chart_info + renko_warn, bgcolor=preset_bg, text_color=color.white, text_size=size.small)

    // Grade
    grade_display = late_trend_flag ? grade + " ⚠ LATE" : grade
    grade_color = late_trend_flag ? color.new(#FF9800, 40) : grade == "A+" ? color.new(#00ff00, 50) : grade == "A" ? color.new(#00cc00, 50) : grade == "A-" ? color.new(#66ff66, 50) : grade == "B+" ? color.new(#ffaa00, 50) : grade == "B" ? color.new(#ff6600, 50) : color.new(color.gray, 80)
    dir_color = direction == "LONG" ? color.new(color.green, 65) :direction == "SHORT" ? color.new(color.red, 65) :color.new(color.gray, 80)
    table.cell(dash_table, 0, 1, "SETUP GRADE", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.normal)
    table.cell(dash_table, 1, 1, grade_display, bgcolor=grade_color, text_color=color.white, text_size=size.large)
    table.cell(dash_table, 0, 2, "DIRECTION", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.normal)
    table.cell(dash_table, 1, 2, direction, bgcolor=dir_color, text_color=color.white, text_size=size.normal)

    // Signal Age
    bar_unit = is_renko ? " bricks" : " bars"
    dur_text = grade != "NONE" ? signal_dur_text + " (" + str.tostring(signal_duration) + bar_unit + ")" : "—"
    dur_col = signal_duration <= 3 ? color.new(color.green, 65) : signal_duration <= 10 ? color.new(color.yellow, 65) : color.new(color.orange, 65)
    table.cell(dash_table, 0, 3, "SIGNAL AGE", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(dash_table, 1, 3, dur_text, bgcolor=grade != "NONE" ? dur_col : color.new(color.gray, 85), text_color=color.white, text_size=size.small)

    // Volume Flow
    vol_flow_text = not enable_vol_analysis or not hasVolume ? "—" : vol_trend + " " + str.tostring(vol_ratio_fast_slow, "0.0") + "x"
    vol_flow_col = not enable_vol_analysis ? color.new(color.gray, 90) : vol_expanding ? color.new(color.green, 55) : vol_contracting ? color.new(color.red, 60) : color.new(color.gray, 80)
    table.cell(dash_table, 0, 4, "VOL FLOW", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(dash_table, 1, 4, vol_flow_text, bgcolor=vol_flow_col, text_color=color.white, text_size=size.small)

    // Volume Spike
    vol_spike_text = not enable_vol_analysis ? "—" : vol_is_spike ? vol_spike_context + " " + str.tostring(vol_spike_ratio, "0.0") + "x avg" : vol_filter ? "✓ ACTIVE" : "✗ LOW"
    vol_spike_col = not enable_vol_analysis ? color.new(color.gray, 90) : vol_spike_early ? color.new(color.green, 45) : vol_spike_late ? color.new(#FF6B00, 45) : vol_is_spike ? color.new(color.yellow, 55) : vol_filter ? color.new(color.green, 70) : color.new(color.red, 65)
    table.cell(dash_table, 0, 5, "VOL SPIKE", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(dash_table, 1, 5, vol_spike_text, bgcolor=vol_spike_col, text_color=color.white, text_size=size.small)

    // Volume-Price Divergence
    vol_div_text = not enable_vol_analysis ? "—" : vol_div_bearish ? "⚠ PRICE ▲ VOL ▼" : vol_div_bullish ? "⚠ PRICE ▼ VOL ▼" : "✓ ALIGNED"
    vol_div_col = not enable_vol_analysis ? color.new(color.gray, 90) : vol_div_active ? color.new(#FF6B00, 50) : color.new(color.green, 75)
    table.cell(dash_table, 0, 6, "VOL DIVG", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(dash_table, 1, 6, vol_div_text, bgcolor=vol_div_col, text_color=color.white, text_size=size.small)

    // Session (approximate on Renko — brick timestamps may span session boundaries)
    session_prefix = is_nonstandard ? "~" : ""
    session_status = use_cl_preset and inSession_cl ? "✓ CL PIT" : tradeAllowed ? "✓ " + session_prefix + active_win_label : "✗ OUTSIDE"
    session_col = tradeAllowed ? color.new(color.green, 65) : color.new(color.orange, 65)
    table.cell(dash_table, 0, 7, is_nonstandard ? "SESSION ~" : "SESSION", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(dash_table, 1, 7, session_status, bgcolor=session_col, text_color=color.white, text_size=size.small)

    // Algo
    algo_display = algo_mode == "OFF" ? "OFF" : in_any_algo ? algo_window_label : "—"
    algo_col = algo_mode == "OFF" ? color.new(color.gray, 90) : in_any_algo and algo_mode == "TRADE WITH" ? color.new(#00E5FF, 55) : in_any_algo and algo_mode == "AVOID" ? color.new(#FF6B00, 55) : color.new(color.gray, 85)
    algo_prefix = algo_mode == "TRADE WITH" and in_any_algo ? "🤖 " : algo_mode == "AVOID" and in_any_algo ? "⚠ " : ""
    table.cell(dash_table, 0, 8, "ALGO", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(dash_table, 1, 8, algo_prefix + algo_display, bgcolor=algo_col, text_color=color.white, text_size=size.small)

    // ADX
    adx_display = str.tostring(adx_value, "0.0")
    adx_status = adx_value >= adx_threshold_a_plus ? "🔥 STRONG" : adx_value >= adx_threshold_a ? "✓ GOOD" : "⚠ WEAK"
    adx_col = adx_value >= adx_threshold_a_plus ? color.new(color.green, 65) : adx_value >= adx_threshold_a ? color.new(color.yellow, 65) : color.new(color.red, 65)
    table.cell(dash_table, 0, 9, "ADX TREND", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(dash_table, 1, 9, adx_display + " " + adx_status, bgcolor=adx_col, text_color=color.white, text_size=size.small)

    // DStoch
    dstoch_display = str.tostring(db_stoch_curr, "0.0")
    dstoch_col = dstoch_status == "BULL" ? color.new(color.green, 65) : dstoch_status == "BEAR" ? color.new(color.red, 65) : color.new(color.gray, 80)
    table.cell(dash_table, 0, 10, "DSTOCH", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(dash_table, 1, 10, dstoch_display + " " + dstoch_status, bgcolor=dstoch_col, text_color=color.white, text_size=size.small)

    // EMA Trend
    ema_trend_col = hma_trend == "STRONG LONG" ? color.new(color.green, 55) :hma_trend == "LONG" ? color.new(color.green, 70) :hma_trend == "STRONG SHORT" ? color.new(color.red, 55) :hma_trend == "SHORT" ? color.new(color.red, 70) :color.new(color.gray, 80)
    table.cell(dash_table, 0, 11, "HMA TREND", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(dash_table, 1, 11, hma_trend, bgcolor=ema_trend_col, text_color=color.white, text_size=size.small)

    // MTF Timeframes
    mtf_display = mtf_fast + " / " + mtf_mid + " / " + mtf_slow
    mtf_speed_col = mtf_speed == "Aggressive" ? color.new(#FF6B00, 60) : mtf_speed == "Moderate" ? color.new(#00BFFF, 60) : mtf_speed == "Custom" ? color.new(#E040FB, 60) : color.new(color.gray, 80)
    table.cell(dash_table, 0, 12, "MTF (" + mtf_speed + ")", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(dash_table, 1, 12, mtf_display, bgcolor=mtf_speed_col, text_color=color.white, text_size=size.small)

    // Consolidation Regime
    if enable_consol_regime
        regime_col = is_tight_consol ? color.new(#4488FF, 40) : is_mild_consol ? color.new(#FFD700, 50) : is_expansion_day ? color.new(#FF4444, 40) : color.new(color.gray, 80)
        range_pct_display = str.tostring(math.round(consol_range_ratio * 100)) + "% ATR"
        table.cell(dash_table, 0, 13, "REGIME", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
        table.cell(dash_table, 1, 13, consol_regime + " (" + range_pct_display + ")", bgcolor=regime_col, text_color=color.white, text_size=size.small)

        // Checkpoint score
        score_col = consol_score >= 2 ? color.new(#4488FF, 50) : consol_score == 1 ? color.new(#FFD700, 60) : color.new(color.green, 65)
        table.cell(dash_table, 0, 14, "CP SCORE", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
        table.cell(dash_table, 1, 14, str.tostring(consol_score) + "/3", bgcolor=score_col, text_color=color.white, text_size=size.small)

        // Compression alert
        compress_text = consol_compression_alert ? "LOADED" : prev_day_was_tight ? "1-DAY TIGHT" : "—"
        compress_col = consol_compression_alert ? color.new(#FFD700, 40) : prev_day_was_tight ? color.new(#FF9F43, 55) : color.new(color.gray, 85)
        table.cell(dash_table, 0, 15, "COMPRESS", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
        table.cell(dash_table, 1, 15, compress_text, bgcolor=compress_col, text_color=color.white, text_size=size.small)

    // RSI Divergence
    if enable_divergence
        div_text = div_bear_active ? "⚠ BEAR DIV" : div_bull_active ? "⚠ BULL DIV" : "—"
        div_col = div_bear_active ? color.new(#FF4444, 45) : div_bull_active ? color.new(#44BBFF, 45) : color.new(color.gray, 85)
        div_warn = div_against_position ? " ✗ COUNTER" : ""
        table.cell(dash_table, 0, 16, "RSI DIV", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
        table.cell(dash_table, 1, 16, div_text + div_warn, bgcolor=div_col, text_color=color.white, text_size=size.small)

// ==========================================
// --- ALERTS (split long/short + TP/SL) ---
// ==========================================
// Grade signals — separate LONG and SHORT
alertcondition(sig_a_plus_long, title="🔥 A+ LONG", message="A+ LONG: All systems aligned — full size runner!")
alertcondition(sig_a_plus_short, title="🔥 A+ SHORT", message="A+ SHORT: All systems aligned — full size runner!")
alertcondition(sig_a_long, title="⚡ A LONG", message="A LONG: Strong confluence — runner candidate!")
alertcondition(sig_a_short, title="⚡ A SHORT", message="A SHORT: Strong confluence — runner candidate!")
alertcondition(sig_a_minus_long, title="✓ A- LONG", message="A- LONG: Good setup — standard exit at TP")
alertcondition(sig_a_minus_short, title="✓ A- SHORT", message="A- SHORT: Good setup — standard exit at TP")
alertcondition(sig_b_plus_long, title="💨 B+ LONG SCALP", message="B+ LONG: Trend scalp — in and out!")
alertcondition(sig_b_plus_short, title="💨 B+ SHORT SCALP", message="B+ SHORT: Trend scalp — in and out!")
alertcondition(sig_b_long, title="⚡ B LONG SCALP", message="B LONG: Quick scalp — tight leash!")
alertcondition(sig_b_short, title="⚡ B SHORT SCALP", message="B SHORT: Quick scalp — tight leash!")

// TP and SL hit alerts
alertcondition(sig_tp_just_hit, title="🎯 TP HIT", message="TP HIT: Take profit level reached — take partials or exit!")
alertcondition(sig_sl_just_hit, title="🛑 SL HIT", message="SL HIT: Stop loss level reached — exit position!")

// Warning alerts
alertcondition(ha_exit_signal and tradeAllowed, title="⚠ HA MOMENTUM FLIP", message="HA flipped against your position!")
isNewDay_consol = ta.change(time("D")) != 0
alertcondition((is_tight_consol and not is_tight_consol[1]) or (is_expansion_day and not is_expansion_day[1]) or (isNewDay_consol and consol_compression_alert), title="📊 REGIME CHANGE", message="Consolidation regime changed — check dashboard for tight/expansion/compression status.")
alertcondition(enable_divergence and ((raw_bear_div and not raw_bear_div[1]) or (raw_bull_div and not raw_bull_div[1]) or (div_against_position and not div_against_position[1])), title="🔀 RSI DIVERGENCE", message="RSI divergence detected — check dashboard for bear/bull status and counter-position warning.")
alertcondition(vol_is_spike and tradeAllowed, title="📊 VOLUME SPIKE", message="Volume spike detected — check dashboard for confirm/exhaust context.")
