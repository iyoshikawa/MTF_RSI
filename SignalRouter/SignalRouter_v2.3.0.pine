// Signal Router v2.3.0 - Single Contract + Trailing Stop Entry for QuantLynk/Tradovate

//@version=6
strategy("Signal Router [QuantLynk]", overlay=true, 
     initial_capital=1000000, 
     default_qty_type=strategy.fixed, 
     default_qty_value=1,
     pyramiding=0,
     calc_on_every_tick=true,
     process_orders_on_close=false)

// ══════════════════════════════════════════════════════════════════════════════
// VERSION
// ══════════════════════════════════════════════════════════════════════════════
var VERSION = "2.3.0"

// ══════════════════════════════════════════════════════════════════════════════
// SIGNAL TYPE & PRICE RELATION FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════

eval_signal_type(float src, string sig_type) =>
    bool result = false
    if sig_type == "any"
        result := src > 0
    else if sig_type == "cross"
        result := ta.cross(src, 0)
    else if sig_type == "cross_up"
        result := ta.crossover(src, 0)
    else if sig_type == "cross_down"
        result := ta.crossunder(src, 0)
    else if sig_type == "gt_zero"
        result := src > 0
    else if sig_type == "lt_zero"
        result := src < 0
    else if sig_type == "rising"
        result := src > nz(src[1])
    else if sig_type == "falling"
        result := src < nz(src[1])
    else if sig_type == "ignore"
        result := true
    result

update_price_state(bool current_state, float src, string price_rel) =>
    bool new_state = current_state
    if price_rel == "price_cross_up"
        if close > src
            new_state := true
        else if close < src
            new_state := false
    else if price_rel == "price_cross_down"
        if close < src
            new_state := true
        else if close > src
            new_state := false
    new_state

get_price_result(float src, string price_rel, bool state) =>
    bool result = true
    if price_rel == "ignore"
        result := true
    else if price_rel == "price_above"
        result := close > src
    else if price_rel == "price_below"
        result := close < src
    else if price_rel == "price_cross_up" or price_rel == "price_cross_down"
        result := state
    result

