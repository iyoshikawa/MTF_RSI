use_ug_1 = input.bool(false, "U1 Enable", group=grp_ug, inline="ug1a")
ug_1_src = input.source(close, "Source", group=grp_ug, inline="ug1a")
ug_1_sig = input.string("any", "Signal", options=["any", "cross", "cross_up", "cross_down", "gt_zero", "lt_zero", "rising", "falling", "ignore"], group=grp_ug, inline="ug1b")
ug_1_price = input.string("ignore", "Price", options=["ignore", "price_above", "price_below", "price_cross_up", "price_cross_down"], group=grp_ug, inline="ug1b")
ug_1_name = input.string("U1", "Label", group=grp_ug, inline="ug1c")

use_ug_2 = input.bool(false, "U2 Enable", group=grp_ug, inline="ug2a")
ug_2_src = input.source(close, "Source", group=grp_ug, inline="ug2a")
ug_2_sig = input.string("any", "Signal", options=["any", "cross", "cross_up", "cross_down", "gt_zero", "lt_zero", "rising", "falling", "ignore"], group=grp_ug, inline="ug2b")
ug_2_price = input.string("ignore", "Price", options=["ignore", "price_above", "price_below", "price_cross_up", "price_cross_down"], group=grp_ug, inline="ug2b")
