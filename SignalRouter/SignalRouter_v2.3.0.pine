sg_6_sig = input.string("any", "Signal", options=["any", "cross", "cross_up", "cross_down", "gt_zero", "lt_zero", "rising", "falling", "ignore"], group=grp_sg, inline="sg6b")
sg_6_price = input.string("ignore", "Price", options=["ignore", "price_above", "price_below", "price_cross_up", "price_cross_down"], group=grp_sg, inline="sg6b")
