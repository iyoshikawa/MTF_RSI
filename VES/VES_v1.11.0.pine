// ============================================================================
// Volume Exhaustion Strategy [VES v1.11.0]
// Mean-reversion on volume exhaustion with CVD + Z-Score hybrid detection
// Optimized for Renko charts, works on any chart type
// ============================================================================
//@version=5
strategy("Volume Exhaustion Strategy [VES v1.11.0]",
     overlay          = true,
     pyramiding       = 2,
     default_qty_type = strategy.fixed,
     default_qty_value= 1,
     initial_capital  = 25000,
     commission_type  = strategy.commission.cash_per_contract,
     commission_value = 2.25,
     slippage         = 1,
     calc_on_every_tick = true,
     max_labels_count = 500,
     max_bars_back    = 5000)

// ============================================================================
// INSTRUMENT PRESETS
// ============================================================================
grp_preset = "⚡ Instrument Preset"
preset = input.string("🔷 YM (Dow)", "Instrument",
     options=["🔷 YM (Dow)", "📈 NQ (NASDAQ)", "📊 ES (S&P)", "🛢️ CL (Crude)", "🟤 HG (Copper)", "⚙️ CUSTOM"],
     group=grp_preset,
     tooltip="Auto-configures TP and Trail distances for the selected instrument.\n\nYM/MYM: 40pt TP, 40pt Trail\nNQ/MNQ: 40pt TP, 40pt Trail\nES/MES: 8pt TP, 8pt Trail\nCL/MCL: 0.20 TP, 0.20 Trail\nHG: 0.0050 TP, 0.0050 Trail\nCUSTOM: Uses manual TP/Trail inputs below.")

is_ym = preset == "🔷 YM (Dow)"
is_nq = preset == "📈 NQ (NASDAQ)"
is_es = preset == "📊 ES (S&P)"
is_cl = preset == "🛢️ CL (Crude)"
is_hg = preset == "🟤 HG (Copper)"

// ============================================================================
// CORE CONFIGURATION
// ============================================================================
grp_tp = "💰 TP & Trail"
tp_pts_in    = input.float(40.0, "Take Profit (points)", group=grp_tp, tooltip="Distance in price points from entry to TP. Each position exits independently when its TP is hit.")
trail_pts_in = input.float(40.0, "Trailing Stop (points)", group=grp_tp, tooltip="Trail distance in points from the best price reached. Activates after 1 tick in favor.")
be_enable    = input.bool(true, "Enable Breakeven Stop", group=grp_tp, tooltip="Once price moves N Renko bricks in favor, the stop is moved to entry + offset ticks. Protects capital on trades that initially work then reverse.")
be_boxes     = input.int(3, "Bricks to Trigger BE", group=grp_tp, minval=1, maxval=20, tooltip="Number of Renko bricks price must move in your favor before the breakeven stop activates. 3 = default.")
be_ticks     = input.int(3, "BE Offset (ticks profit)", group=grp_tp, minval=0, maxval=20, tooltip="Once BE triggers, stop is placed at entry + this many ticks. 0 = true breakeven. 3 = lock in 3 ticks profit.")

// Preset overrides for TP/Trail
tp_pts    = is_cl ? 0.20 : is_hg ? 0.0050 : is_es ? 8.0 : tp_pts_in
trail_pts = is_cl ? 0.20 : is_hg ? 0.0050 : is_es ? 8.0 : trail_pts_in

grp_vol = "📊 Volume Exhaustion Detection"
vol_method = input.string("Wave Compare", "Detection Method", 
     options=["Wave Compare", "Volume ROC", "Z-Score", "OFF (flip + BB only)"], group=grp_vol,
     tooltip="Wave Compare: Compares cumulative volume of the ending wave vs prior same-direction wave. Exhaustion = declining wave volume while price extends. Best for Renko.\n\nVolume ROC: Detects volume acceleration/deceleration. Exhaustion = volume decelerating on the current wave while price pushes further. Good for Renko.\n\nZ-Score: Per-brick volume spike detection. Works poorly on Renko (uniform brick volume). Better on time-based charts.\n\nOFF: No volume gate — fires on every Renko flip that meets BB condition.")
vol_lookback = input.int(20, "Volume Lookback (bars)", group=grp_vol, minval=5, maxval=200,
     tooltip="Rolling window for volume calculations. 20 = default.")
wave_decline_pct = input.float(0.0, "Wave Volume Decline % (0=any decline)", group=grp_vol, minval=0.0, maxval=50.0, step=5.0,
     tooltip="For Wave Compare: minimum % decline in wave volume vs prior same-direction wave to flag exhaustion. 0 = any decline counts. 20 = wave must be 20%+ weaker.")
vol_roc_len = input.int(5, "ROC Smoothing (bars)", group=grp_vol, minval=2, maxval=20,
     tooltip="For Volume ROC: SMA smoothing on the volume rate-of-change. Lower = more responsive.")
z_threshold = input.float(0.3, "Z-Score Threshold", group=grp_vol, minval=0.1, maxval=4.0, step=0.1,
     tooltip="For Z-Score method only. 0.3 = permissive, 1.5 = selective.")

grp_ema = "📈 Moving Averages (OHLC4)"
ema_fast_len  = input.int(9,   "EMA Fast",  group=grp_ema, tooltip="Fast EMA on OHLC4 source. Used in EMA alignment confluence (9 > 15 > 34 = bullish stack). Default 9.")
ema_mid_len   = input.int(15,  "EMA Mid",   group=grp_ema, tooltip="Mid EMA on OHLC4 source. Middle of the alignment stack. Default 15.")
ema_slow_len  = input.int(34,  "EMA Slow",  group=grp_ema, tooltip="Slow EMA on OHLC4 source. Primary trend direction reference. Default 34.")
ema_macro_len = input.int(233, "EMA Macro",  group=grp_ema, tooltip="Fibonacci 233 EMA on OHLC4. Long-term trend anchor used by the soft trend filter. Price below 233 + stacked bearish EMAs = strong downtrend (suppresses longs).")

grp_bb = "📉 Bollinger Bands (3-Min MTF)"
bb_length   = input.int(10, "BB Length", group=grp_bb, tooltip="Lookback period for the Bollinger Band basis. Matches TradingView standard BB: SMA of close. Calculated on 3-minute timeframe.")
bb_mult     = input.float(1.2, "BB Std Dev Multiplier", group=grp_bb, step=0.1, tooltip="Standard deviation multiplier for band width. 1.2 = tighter than default 2.0 — catches mean-reversion entries closer to the midline.")
bb_tf       = input.timeframe("3", "BB Calculation Timeframe", group=grp_bb, tooltip="Timeframe for BB calculation. Default 3-min. The BB is computed on this timeframe and projected onto your chart.")
bb_color_up = input.color(#2962FF, "Upper Band", group=grp_bb, inline="bbc1")
bb_color_lo = input.color(#2962FF, "Lower Band", group=grp_bb, inline="bbc1")
bb_color_mid = input.color(color.gray, "Midline", group=grp_bb, inline="bbc2")

grp_hma = "〰️ HMA 20 (Chart TF)"
hma_length = input.int(20, "HMA Length", group=grp_hma, tooltip="Hull Moving Average length. Calculated on chart timeframe (Renko bricks). OPTIONAL — shown on dashboard for reference, does not gate entries.")
hma_src    = input.source(close, "HMA Source", group=grp_hma)

grp_trend = "🛡️ Soft Trend Filter"
use_trend_filter = input.bool(true, "Enable Soft Trend Filter", group=grp_trend,
     tooltip="Suppresses signals that go directly into a strong stacked trend. A 'strong trend' = all 3 EMAs stacked (9<15<34) AND price below 233 EMA.\n\nWhen active: VOL BOTTOM longs blocked in strong downtrends, VOL PEAK shorts blocked in strong uptrends.\n\nThis prevents catching falling knives. Disable if you want to trade counter-trend reversals in all conditions.")

grp_session = "⏰ Session Filter"
use_session = input.bool(true, "Enable Session Filter", group=grp_session)
session_str = input.string("0930-1145,1330-1600:23456", "Session Config", group=grp_session,
     tooltip="Format: TIME1,TIME2:DAYS\nDays: 1=Sun 2=Mon 3=Tue 4=Wed 5=Thu 6=Fri 7=Sat\nExample: 0930-1145,1330-1600:23456")
flatten_outside = input.bool(false, "Flatten Positions Outside Session", group=grp_session,
     tooltip="If enabled, all open positions are closed when the session window ends. If disabled, positions ride until TP/Trail/Opposite signal.")

grp_ql = "🔗 QuantLynk Webhook"
ql_enabled  = input.bool(false, "Enable QuantLynk Alerts", group=grp_ql, tooltip="When enabled, all strategy.entry/exit/close calls include QuantLynk-formatted alert_message payloads. You must also set your TradingView alert message to: {{strategy.order.alert_message}}")
ql_user_id  = input.string("", "QuantLynk User ID", group=grp_ql, tooltip="Your qv_user_id from QuantLynk. Find it in the webhook generator on the QuantLynk dashboard.")
ql_alert_id = input.string("", "QuantLynk Alert ID", group=grp_ql, tooltip="Your alert_id from QuantLynk. Each alert target has a unique ID.")

grp_vis = "🎨 Visuals"
color_candles   = input.bool(true, "Color Candles by Direction", group=grp_vis)
show_labels     = input.bool(true, "Show VOL PEAK / VOL BOTTOM Labels", group=grp_vis)
show_wick_dots  = input.bool(true, "Show Yellow Dots on EMA Wick Touches", group=grp_vis)
wick_dot_ema    = input.string("EMA 34", "Wick Touch EMA", options=["EMA 9", "EMA 15", "EMA 34", "EMA 233"], group=grp_vis)
bull_candle_col = input.color(#00BFFF, "Bullish Candle", group=grp_vis, inline="cc1")
bear_candle_col = input.color(#FF4081, "Bearish Candle", group=grp_vis, inline="cc1")
ema9_color      = input.color(#FFFFFF, "EMA 9",   group=grp_vis, inline="ec1")
ema15_color     = input.color(#FFD700, "EMA 15",  group=grp_vis, inline="ec1")
ema34_color     = input.color(#00BFFF, "EMA 34",  group=grp_vis, inline="ec2")
ema233_color    = input.color(#FF6B00, "EMA 233", group=grp_vis, inline="ec2")

grp_dash = "📋 Dashboard"
show_dash = input.bool(true, "Show Dashboard", group=grp_dash)
dash_pos  = input.string("Top Right", "Position", options=["Top Right", "Bottom Right", "Top Left", "Bottom Left"], group=grp_dash)

// ============================================================================
// CHART TYPE DETECTION
// ============================================================================
is_renko      = chart.is_renko
is_nonstandard = chart.is_renko or chart.is_range or chart.is_linebreak or chart.is_kagi or chart.is_pnf
chart_label    = is_renko ? "RENKO" : chart.is_range ? "RANGE" : chart.is_heikinashi ? "HA" : "STD"
brick_size     = is_renko ? (high - low) : 0.0

// ============================================================================
// SESSION PARSING
// ============================================================================
config_parts  = str.split(session_str, ":")
times_str     = array.get(config_parts, 0)
days_str      = array.size(config_parts) > 1 ? array.get(config_parts, 1) : "23456"
time_windows  = str.split(times_str, ",")
num_windows   = array.size(time_windows)
day_suffix    = ":" + days_str

in_w1 = num_windows >= 1 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 0)) + day_suffix, "America/New_York")) : false
in_w2 = num_windows >= 2 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 1)) + day_suffix, "America/New_York")) : false
in_w3 = num_windows >= 3 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 2)) + day_suffix, "America/New_York")) : false
in_w4 = num_windows >= 4 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 3)) + day_suffix, "America/New_York")) : false

in_session_raw = in_w1 or in_w2 or in_w3 or in_w4
in_session     = not use_session or in_session_raw
session_just_closed = use_session and not in_session_raw and in_session_raw[1]

// ============================================================================
// MOVING AVERAGES (OHLC4 source)
// ============================================================================
ema_src  = ohlc4
ema_9    = ta.ema(ema_src, ema_fast_len)
ema_15   = ta.ema(ema_src, ema_mid_len)
ema_34   = ta.ema(ema_src, ema_slow_len)
ema_233  = ta.ema(ema_src, ema_macro_len)

// EMA trend stacking
ema_stacked_bull = ema_9 > ema_15 and ema_15 > ema_34
ema_stacked_bear = ema_9 < ema_15 and ema_15 < ema_34
above_macro      = close > ema_233
below_macro      = close < ema_233
strong_uptrend   = ema_stacked_bull and above_macro
strong_downtrend = ema_stacked_bear and below_macro

// ============================================================================
// BOLLINGER BANDS (3-Min MTF via request.security)
// ============================================================================
// Matches TradingView standard BB: SMA basis, close source
// Calculated on the specified timeframe, projected onto chart

// Clean ticker for MTF requests
cleanTicker = ticker.new(syminfo.prefix, syminfo.ticker)

// BB calculation — TV standard: SMA of close, stdev of close
bb_src_calc(len, mult) =>
    basis = ta.sma(close, len)
    dev   = mult * ta.stdev(close, len)
    [basis, basis + dev, basis - dev]

[bb_basis, bb_upper, bb_lower] = request.security(cleanTicker, bb_tf, bb_src_calc(bb_length, bb_mult), lookahead=barmerge.lookahead_on)

// Price position relative to bands
price_at_lower_bb = close <= bb_lower
price_at_upper_bb = close >= bb_upper
price_below_mid   = close < bb_basis
price_above_mid   = close > bb_basis

// BB gate: price at or beyond the band edge (strict), with 2-bar lookback
// The lookback catches the turn — price was at the band extreme recently, brick just flipped
bb_ok_long_now    = price_at_lower_bb
bb_ok_short_now   = price_at_upper_bb
bb_ok_long_recent = bb_ok_long_now or bb_ok_long_now[1] or bb_ok_long_now[2]
bb_ok_short_recent = bb_ok_short_now or bb_ok_short_now[1] or bb_ok_short_now[2]

// ============================================================================
// HMA 20 (Chart Timeframe)
// ============================================================================
hma_val  = ta.hma(hma_src, hma_length)
hma_bull = close > hma_val
hma_bear = close < hma_val
hma_rising  = hma_val > hma_val[1]
hma_falling = hma_val < hma_val[1]

// HMA 2-bar lookback (was below/above recently — catches the turn)
hma_ok_long_recent  = hma_bear or hma_bear[1] or hma_bear[2]
hma_ok_short_recent = hma_bull or hma_bull[1] or hma_bull[2]

// ============================================================================
// VOLUME EXHAUSTION DETECTION — 3 Methods + OFF
// ============================================================================

// --- Brick Direction ---
bull_brick    = close >= open
bear_brick    = close < open
flip_to_bull  = bull_brick and not bull_brick[1]
flip_to_bear  = bear_brick and not bear_brick[1]

// --- Base Volume Data ---
has_vol   = not na(volume) and volume > 0
vol_safe  = has_vol ? volume : 0.0

// ============================================================================
// METHOD 1: Wave Volume Compare (Weis Wave style)
// Accumulates volume per directional wave (consecutive same-color bricks).
// Exhaustion = the ending wave had DECLINING volume vs prior same-direction wave.
// This means the dominant side pushed but with less conviction — they're tiring out.
// ============================================================================
var float wave_cum_vol      = 0.0
var float prev_bull_wave    = 0.0
var float prev_bear_wave    = 0.0
var float prev2_bull_wave   = 0.0
var float prev2_bear_wave   = 0.0

if flip_to_bull
    // Bearish wave just ended — store its cumulative volume
    prev2_bear_wave := prev_bear_wave
    prev_bear_wave  := wave_cum_vol
    wave_cum_vol    := vol_safe
else if flip_to_bear
    // Bullish wave just ended — store its cumulative volume
    prev2_bull_wave := prev_bull_wave
    prev_bull_wave  := wave_cum_vol
    wave_cum_vol    := vol_safe
else
    wave_cum_vol += vol_safe

// Wave exhaustion: the ending wave had LESS volume than the prior same-direction wave
// Bearish wave volume declined → sellers exhausting → VOL BOTTOM (long)
// Bullish wave volume declined → buyers exhausting → VOL PEAK (short)
wave_decline_thresh = 1.0 - (wave_decline_pct / 100.0)
wave_bear_exhausted = prev2_bear_wave > 0 and prev_bear_wave < (prev2_bear_wave * wave_decline_thresh)
wave_bull_exhausted = prev2_bull_wave > 0 and prev_bull_wave < (prev2_bull_wave * wave_decline_thresh)

// Also detect climactic volume (wave had MORE than prior — blowoff top/bottom)
wave_bear_climax = prev_bear_wave > prev2_bear_wave and prev2_bear_wave > 0
wave_bull_climax = prev_bull_wave > prev2_bull_wave and prev2_bull_wave > 0

// Wave method fires on either exhaustion OR climax
wave_vol_bottom = flip_to_bull and has_vol and (wave_bear_exhausted or wave_bear_climax)
wave_vol_peak   = flip_to_bear and has_vol and (wave_bull_exhausted or wave_bull_climax)

// ============================================================================
// METHOD 2: Volume Rate of Change (ROC)
// Smoothed volume ROC detects acceleration vs deceleration.
// Exhaustion = volume is decelerating (ROC negative/falling) at the flip point.
// ============================================================================
vol_sma_fast = ta.sma(vol_safe, vol_roc_len)
vol_sma_slow = ta.sma(vol_safe, vol_lookback)
vol_roc_val  = vol_sma_slow > 0 ? ((vol_sma_fast - vol_sma_slow) / vol_sma_slow) * 100 : 0.0

// Volume is decelerating (fast MA falling relative to slow MA)
vol_decelerating = vol_roc_val < vol_roc_val[1]
// Volume is at or below average (not a fresh surge)
vol_below_avg = vol_sma_fast <= vol_sma_slow

roc_vol_bottom = flip_to_bull and has_vol and (vol_decelerating or vol_below_avg)
roc_vol_peak   = flip_to_bear and has_vol and (vol_decelerating or vol_below_avg)

// ============================================================================
// METHOD 3: Z-Score (original — kept for time-based charts)
// ============================================================================
vol_sma_z = ta.sma(vol_safe, vol_lookback)
vol_std   = ta.stdev(vol_safe, vol_lookback)
vol_z     = vol_std > 0 ? (vol_safe - vol_sma_z) / vol_std : 0.0

zscore_vol_bottom = flip_to_bull and has_vol and vol_z >= z_threshold
zscore_vol_peak   = flip_to_bear and has_vol and vol_z >= z_threshold

// ============================================================================
// METHOD SELECTOR — routes to the chosen detection method
// ============================================================================
use_wave = vol_method == "Wave Compare"
use_roc  = vol_method == "Volume ROC"
use_z    = vol_method == "Z-Score"
use_off  = vol_method == "OFF (flip + BB only)"

vol_bottom_raw = use_wave ? wave_vol_bottom : use_roc ? roc_vol_bottom : use_z ? zscore_vol_bottom : (flip_to_bull and has_vol)
vol_peak_raw   = use_wave ? wave_vol_peak   : use_roc ? roc_vol_peak   : use_z ? zscore_vol_peak   : (flip_to_bear and has_vol)

// Method label for dashboard
vol_method_label = use_wave ? "WAVE" : use_roc ? "ROC" : use_z ? "Z-SCR" : "OFF"

// --- DEBUG: Fire on every Renko flip to test if volume/BB is blocking ---
debug_mode = input.bool(false, "🔧 DEBUG: Bypass all gates (flip only)", group="🔧 Debug",
     tooltip="When ON, signals fire on every Renko direction flip. Use to verify signals display correctly, then turn OFF to re-enable gates.")
debug_require_vol = input.bool(true, "🔧 Require Volume Exhaustion", group="🔧 Debug",
     tooltip="Toggle volume exhaustion gate independently. Turn OFF to see if volume is the blocker.")
debug_require_bb  = input.bool(true, "🔧 Require BB Outside Bands", group="🔧 Debug",
     tooltip="Toggle BB band-edge gate independently. Turn OFF to see if BB is the blocker.")
debug_require_trend = input.bool(true, "🔧 Require Trend Filter", group="🔧 Debug",
     tooltip="Toggle soft trend filter independently.")
debug_require_session = input.bool(true, "🔧 Require Session Filter", group="🔧 Debug",
     tooltip="Toggle session time filter independently.")

// --- Confluence Gates ---
bb_ok_long  = bb_ok_long_recent
bb_ok_short = bb_ok_short_recent

// --- Build final gate chain with individual toggles ---
// Volume gate: uses whichever method is selected
vol_gate_long  = not debug_require_vol or vol_bottom_raw
vol_gate_short = not debug_require_vol or vol_peak_raw

// BB gate
bb_gate_long  = not debug_require_bb or bb_ok_long
bb_gate_short = not debug_require_bb or bb_ok_short

// Trend gate
trend_gate_long  = not debug_require_trend or not use_trend_filter or not strong_downtrend
trend_gate_short = not debug_require_trend or not use_trend_filter or not strong_uptrend

// Session gate
session_gate = not debug_require_session or in_session

// --- Final Signals ---
// Debug mode: fire on every Renko flip
// Normal mode: flip is implicit in vol_bottom_raw/vol_peak_raw, then BB + trend + session
vol_bottom = debug_mode ? (flip_to_bull and session_gate) : (vol_gate_long  and bb_gate_long  and trend_gate_long  and session_gate)
vol_peak   = debug_mode ? (flip_to_bear and session_gate) : (vol_gate_short and bb_gate_short and trend_gate_short and session_gate)

// Display Z-score for the signal (used in labels)
signal_z = vol_bottom ? vol_z : vol_peak ? vol_z : 0.0

// ============================================================================
// CONFLUENCE COUNTER (6 factors)
// ============================================================================
// Counts how many independent confluences agree with a long or short setup.
// Displayed on dashboard and labels. Does NOT gate entries — just information.

// 1. Renko flip (always required, always 1 if signal fires)
conf_flip_long  = flip_to_bull ? 1 : 0
conf_flip_short = flip_to_bear ? 1 : 0

// 2. Volume exhaustion (method-dependent)
conf_vol_long  = vol_bottom_raw ? 1 : 0
conf_vol_short = vol_peak_raw   ? 1 : 0

// 3. BB outside bands (within 2 bars)
conf_bb_long  = bb_ok_long_recent  ? 1 : 0
conf_bb_short = bb_ok_short_recent ? 1 : 0

// 4. Session window active
conf_session = in_session_raw ? 1 : 0

// 5. HMA position (price below for long, above for short)
conf_hma_long  = hma_bear ? 1 : 0
conf_hma_short = hma_bull ? 1 : 0

// 6. EMA alignment (9 > 15 > 34 for counter-trend longs at bottom, inverted for shorts)
// For mean-reversion: EMA stacked AGAINST you = you're buying a dip in an uptrend (strong)
// or stacked WITH the reversal direction = trend is already turning
conf_ema_long  = ema_stacked_bull ? 1 : 0  // EMAs bullish = buying dip in uptrend
conf_ema_short = ema_stacked_bear ? 1 : 0  // EMAs bearish = selling rally in downtrend

// Total confluence count
conf_total_long  = conf_flip_long  + conf_vol_long  + conf_bb_long  + conf_session + conf_hma_long  + conf_ema_long
conf_total_short = conf_flip_short + conf_vol_short + conf_bb_short + conf_session + conf_hma_short + conf_ema_short
conf_total = math.max(conf_total_long, conf_total_short)
conf_max = 6

// Exhaustion label text (method-specific value)
exhaust_val_text = use_wave ? (flip_to_bull ? (wave_bear_exhausted ? "WvDecl" : wave_bear_climax ? "WvClmx" : "") : flip_to_bear ? (wave_bull_exhausted ? "WvDecl" : wave_bull_climax ? "WvClmx" : "") : "") : use_roc ? "ROC:" + str.tostring(vol_roc_val, "0.0") + "%" : use_z ? "Z:" + str.tostring(vol_z, "0.1") : ""

// ============================================================================
// POSITION MANAGEMENT
// ============================================================================
net_pos   = strategy.position_size
is_flat   = net_pos == 0
is_long   = net_pos > 0
is_short  = net_pos < 0
num_units = math.round(math.abs(net_pos))

// Convert points to ticks for strategy.exit()
tp_ticks    = math.round(tp_pts / syminfo.mintick)
trail_ticks = math.round(trail_pts / syminfo.mintick)

// --- Track entry prices for dashboard display ---
var float entry1_price = na
var float entry2_price = na
var int   pos_dir      = 0      // 1=long, -1=short, 0=flat
var float highest_since = na
var float lowest_since  = na

// --- Breakeven Stop Tracking (per position) ---
var bool  be1_triggered = false
var bool  be2_triggered = false
be_offset_pts = be_ticks * syminfo.mintick
be_dist_pts   = is_renko ? be_boxes * brick_size : be_boxes * syminfo.mintick * 8  // fallback for non-Renko

// Reset on flat
if is_flat and not is_flat[1]
    entry1_price := na
    entry2_price := na
    pos_dir      := 0
    highest_since := na
    lowest_since  := na
    be1_triggered := false
    be2_triggered := false

// Track high/low water marks for trail display
if not is_flat
    highest_since := na(highest_since) ? high : math.max(highest_since, high)
    lowest_since  := na(lowest_since)  ? low  : math.min(lowest_since, low)

// --- Breakeven Trigger Detection ---
// Once price moves be_boxes bricks in favor, lock in BE + offset
if be_enable and not na(entry1_price) and not be1_triggered
    if is_long  and high >= entry1_price + be_dist_pts
        be1_triggered := true
    if is_short and low  <= entry1_price - be_dist_pts
        be1_triggered := true

if be_enable and not na(entry2_price) and not be2_triggered
    if is_long  and high >= entry2_price + be_dist_pts
        be2_triggered := true
    if is_short and low  <= entry2_price - be_dist_pts
        be2_triggered := true

// BE stop price levels (na when not triggered — strategy.exit ignores na stops)
be_stop_l1 = be1_triggered and is_long  ? entry1_price + be_offset_pts : na
be_stop_l2 = be2_triggered and is_long  ? entry2_price + be_offset_pts : na
be_stop_s1 = be1_triggered and is_short ? entry1_price - be_offset_pts : na
be_stop_s2 = be2_triggered and is_short ? entry2_price - be_offset_pts : na

// ============================================================================
// DAILY P&L TRACKING
// ============================================================================
// Detects new trading day via date change, snapshots equity at day open,
// calculates running daily P&L, tracks daily drawdown, and optionally
// flattens positions if daily DD limit is hit.

daily_dd_limit = input.float(3000.0, "Daily DD Limit ($)", group=grp_tp, minval=0, step=100,
     tooltip="Maximum daily drawdown in dollars. If daily P&L drops below this negative amount, all positions are flattened and no new entries until next day. 0 = disabled.")
daily_pt_limit = input.float(0.0, "Daily Profit Target ($)", group=grp_tp, minval=0, step=100,
     tooltip="Daily profit target in dollars. Once daily P&L reaches this amount, all positions are flattened and no new entries until next day. Locks in a winning day. 0 = disabled.")
daily_dd_enabled = daily_dd_limit > 0
daily_pt_enabled = daily_pt_limit > 0

// New day detection — works on both time-based and Renko charts
is_new_day = ta.change(time("D")) != 0

var float equity_at_day_open = strategy.equity
var float daily_pnl          = 0.0
var float daily_high_equity  = strategy.equity
var float daily_dd           = 0.0
var bool  daily_dd_hit       = false
var bool  daily_pt_hit       = false
var int   daily_wins         = 0
var int   daily_losses       = 0
var int   daily_trades       = 0
var float prev_day_pnl       = 0.0

// Snapshot at day open
if is_new_day
    prev_day_pnl        := daily_pnl
    equity_at_day_open  := strategy.equity
    daily_high_equity   := strategy.equity
    daily_pnl           := 0.0
    daily_dd            := 0.0
    daily_dd_hit        := false
    daily_pt_hit        := false
    daily_wins          := 0
    daily_losses        := 0
    daily_trades        := 0

// Update running daily P&L
daily_pnl := strategy.equity - equity_at_day_open

// Track daily high-water mark and drawdown
daily_high_equity := math.max(daily_high_equity, strategy.equity)
daily_dd := daily_high_equity - strategy.equity

// Track daily trade count using closed trades (increments when a new trade closes)
total_closed = strategy.closedtrades
var int prev_total_closed = 0
new_close = total_closed > prev_total_closed
if new_close
    daily_trades += total_closed - prev_total_closed
    // Check if last closed trade was a win or loss
    if total_closed > 0
        last_profit = strategy.closedtrades.profit(total_closed - 1)
        if last_profit > 0
            daily_wins += 1
        else if last_profit < 0
            daily_losses += 1
    prev_total_closed := total_closed

// Daily DD limit hit — flatten and block new entries
if daily_dd_enabled and daily_pnl <= -daily_dd_limit and not daily_dd_hit
    daily_dd_hit := true
    strategy.close_all(comment="DAILY DD LIMIT", alert_message=ql_flatten)

// Daily Profit Target hit — flatten and lock in the day
if daily_pt_enabled and daily_pnl >= daily_pt_limit and not daily_pt_hit
    daily_pt_hit := true
    strategy.close_all(comment="DAILY PT HIT", alert_message=ql_flatten)

// Block entries when either daily limit is hit
daily_ok = not daily_dd_hit and not daily_pt_hit

// ============================================================================
// QUANTLYNK WEBHOOK PAYLOADS
// ============================================================================
// Built once, attached to strategy calls via alert_message parameter.
// Customer must set TradingView alert message to: {{strategy.order.alert_message}}

ql_buy     = ql_enabled ? '{"qv_user_id": "' + ql_user_id + '", "alert_id": "' + ql_alert_id + '", "quantity": "1", "order_type": "market", "price": {{close}}, "action": "buy"}' : ''
ql_sell    = ql_enabled ? '{"qv_user_id": "' + ql_user_id + '", "alert_id": "' + ql_alert_id + '", "quantity": "1", "order_type": "market", "price": {{close}}, "action": "sell"}' : ''
ql_flatten = ql_enabled ? '{"qv_user_id": "' + ql_user_id + '", "alert_id": "' + ql_alert_id + '", "action": "flatten"}' : ''
// For exits: use {{strategy.order.action}} which resolves to buy/sell at fire time
ql_exit    = ql_enabled ? '{"qv_user_id": "' + ql_user_id + '", "alert_id": "' + ql_alert_id + '", "quantity": "1", "order_type": "market", "price": {{close}}, "action": "{{strategy.order.action}}"}' : ''

// ============================================================================
// ENTRIES
// ============================================================================

// --- VOL BOTTOM → LONG ---
if vol_bottom and daily_ok
    if is_short
        // Flatten shorts, then enter long
        strategy.close_all(comment="FLATTEN→L", alert_message=ql_flatten)
        strategy.entry("L1", strategy.long, qty=1, comment="VEB D:1/2", alert_message=ql_buy)
        entry1_price := close
        entry2_price := na
        pos_dir      := 1
        highest_since := high
        lowest_since  := low
        be1_triggered := false
        be2_triggered := false
    else if is_flat
        strategy.entry("L1", strategy.long, qty=1, comment="VEB D:1/2", alert_message=ql_buy)
        entry1_price := close
        pos_dir      := 1
        highest_since := high
        lowest_since  := low
        be1_triggered := false
        be2_triggered := false
    else if is_long and num_units < 2
        strategy.entry("L2", strategy.long, qty=1, comment="VEB D:2/2", alert_message=ql_buy)
        entry2_price := close
        be2_triggered := false

// --- VOL PEAK → SHORT ---
if vol_peak and daily_ok
    if is_long
        // Flatten longs, then enter short
        strategy.close_all(comment="FLATTEN→S", alert_message=ql_flatten)
        strategy.entry("S1", strategy.short, qty=1, comment="VEP D:1/2", alert_message=ql_sell)
        entry1_price := close
        entry2_price := na
        pos_dir      := -1
        highest_since := high
        lowest_since  := low
        be1_triggered := false
        be2_triggered := false
    else if is_flat
        strategy.entry("S1", strategy.short, qty=1, comment="VEP D:1/2", alert_message=ql_sell)
        entry1_price := close
        pos_dir      := -1
        highest_since := high
        lowest_since  := low
        be1_triggered := false
        be2_triggered := false
    else if is_short and num_units < 2
        strategy.entry("S2", strategy.short, qty=1, comment="VEP D:2/2", alert_message=ql_sell)
        entry2_price := close
        be2_triggered := false

// ============================================================================
// EXITS — TP + Trailing Stop + Breakeven per position
// ============================================================================
// Each position independently: first of TP, Trail, or BE stop closes that position.
// BE stop activates after N bricks in favor, then locks in entry + offset ticks.
// Before BE triggers, only TP and Trail manage the exit.

if is_long
    strategy.exit("XL1", from_entry="L1", profit=tp_ticks, trail_points=1, trail_offset=trail_ticks,
         stop=be_stop_l1, comment_profit="TP +" + str.tostring(tp_pts, "#.##"), comment_loss=be1_triggered ? "BE+" + str.tostring(be_ticks) + "t" : "TRL", alert_message=ql_exit)
    strategy.exit("XL2", from_entry="L2", profit=tp_ticks, trail_points=1, trail_offset=trail_ticks,
         stop=be_stop_l2, comment_profit="TP +" + str.tostring(tp_pts, "#.##"), comment_loss=be2_triggered ? "BE+" + str.tostring(be_ticks) + "t" : "TRL", alert_message=ql_exit)

if is_short
    strategy.exit("XS1", from_entry="S1", profit=tp_ticks, trail_points=1, trail_offset=trail_ticks,
         stop=be_stop_s1, comment_profit="TP +" + str.tostring(tp_pts, "#.##"), comment_loss=be1_triggered ? "BE+" + str.tostring(be_ticks) + "t" : "TRL", alert_message=ql_exit)
    strategy.exit("XS2", from_entry="S2", profit=tp_ticks, trail_points=1, trail_offset=trail_ticks,
         stop=be_stop_s2, comment_profit="TP +" + str.tostring(tp_pts, "#.##"), comment_loss=be2_triggered ? "BE+" + str.tostring(be_ticks) + "t" : "TRL", alert_message=ql_exit)

// --- Flatten outside session (optional) ---
if flatten_outside and session_just_closed and not is_flat
    strategy.close_all(comment="SESSION END", alert_message=ql_flatten)

// ============================================================================
// VISUAL ELEMENTS
// ============================================================================

// --- EMA Plots ---
plot(ema_9,   "EMA 9",   color=color.new(ema9_color, 20),   linewidth=1)
plot(ema_15,  "EMA 15",  color=color.new(ema15_color, 20),  linewidth=1)
plot(ema_34,  "EMA 34",  color=color.new(ema34_color, 10),  linewidth=2)
plot(ema_233, "EMA 233", color=color.new(ema233_color, 30), linewidth=2, style=plot.style_circles)

// --- Bollinger Bands (from 3-min MTF) ---
p_bb_upper = plot(bb_upper, "BB Upper", color=color.new(bb_color_up, 40), linewidth=1)
p_bb_lower = plot(bb_lower, "BB Lower", color=color.new(bb_color_lo, 40), linewidth=1)
plot(bb_basis, "BB Mid", color=color.new(bb_color_mid, 60), linewidth=1, style=plot.style_cross)
fill(p_bb_upper, p_bb_lower, color=color.new(bb_color_up, 92), title="BB Fill")

// --- Candle Coloring ---
candle_col = not color_candles ? na :
     bull_brick ? color.new(bull_candle_col, 0) :
     color.new(bear_candle_col, 0)
barcolor(candle_col)

// --- VOL PEAK / VOL BOTTOM Labels ---
if show_labels and vol_bottom
    units = is_short ? 1 : (is_flat ? 1 : math.min(num_units + 1, 2))
    lbl_text = "VEB " + exhaust_val_text + "\n" + str.tostring(conf_total_long) + "/" + str.tostring(conf_max)
    label.new(bar_index, low, lbl_text,
         style=label.style_label_up, color=#00E676, textcolor=color.white,
         size=size.small, yloc=yloc.belowbar,
         tooltip="VOL BOTTOM — D:" + str.tostring(units) + "/2\nTP:" + str.tostring(close + tp_pts, "#.##") + " TRL-" + str.tostring(trail_pts, "#.##") + "\nFlip:✓ Vol:" + (conf_vol_long > 0 ? "✓" : "✗") + " BB:" + (conf_bb_long > 0 ? "✓" : "✗") + " Sess:" + (conf_session > 0 ? "✓" : "✗") + " HMA:" + (conf_hma_long > 0 ? "✓" : "✗") + " EMA:" + (conf_ema_long > 0 ? "✓" : "✗"))

if show_labels and vol_peak
    units = is_long ? 1 : (is_flat ? 1 : math.min(num_units + 1, 2))
    lbl_text = "VEP " + exhaust_val_text + "\n" + str.tostring(conf_total_short) + "/" + str.tostring(conf_max)
    label.new(bar_index, high, lbl_text,
         style=label.style_label_down, color=#FF6D00, textcolor=color.white,
         size=size.small, yloc=yloc.abovebar,
         tooltip="VOL PEAK — D:" + str.tostring(units) + "/2\nTP:" + str.tostring(close - tp_pts, "#.##") + " TRL-" + str.tostring(trail_pts, "#.##") + "\nFlip:✓ Vol:" + (conf_vol_short > 0 ? "✓" : "✗") + " BB:" + (conf_bb_short > 0 ? "✓" : "✗") + " Sess:" + (conf_session > 0 ? "✓" : "✗") + " HMA:" + (conf_hma_short > 0 ? "✓" : "✗") + " EMA:" + (conf_ema_short > 0 ? "✓" : "✗"))

// --- Yellow Dots on EMA Wick Touches ---
wick_ema = wick_dot_ema == "EMA 9" ? ema_9 : wick_dot_ema == "EMA 15" ? ema_15 : wick_dot_ema == "EMA 233" ? ema_233 : ema_34

// Wick touched the EMA but price closed on the other side (bounce)
wick_touch_bull = low <= wick_ema and close > wick_ema   // dipped to EMA, closed above
wick_touch_bear = high >= wick_ema and close < wick_ema  // reached EMA, closed below

if show_wick_dots and wick_touch_bull and in_session
    label.new(bar_index, low, "•", style=label.style_none, textcolor=color.yellow, size=size.small, yloc=yloc.belowbar)
if show_wick_dots and wick_touch_bear and in_session
    label.new(bar_index, high, "•", style=label.style_none, textcolor=color.yellow, size=size.small, yloc=yloc.abovebar)

// --- Trail Level Display ---
trail_level_long  = is_long  and not na(highest_since) ? highest_since - trail_pts : na
trail_level_short = is_short and not na(lowest_since)  ? lowest_since  + trail_pts : na
plot(trail_level_long,  "Trail (Long)",  color=color.new(color.red, 50),   linewidth=1, style=plot.style_linebr)
plot(trail_level_short, "Trail (Short)", color=color.new(color.green, 50), linewidth=1, style=plot.style_linebr)

// --- TP Level Display ---
tp_level_long  = is_long  and not na(entry1_price) ? entry1_price + tp_pts : na
tp_level_short = is_short and not na(entry1_price) ? entry1_price - tp_pts : na
plot(tp_level_long,  "TP (Long)",  color=color.new(#00BFFF, 40), linewidth=1, style=plot.style_linebr)
plot(tp_level_short, "TP (Short)", color=color.new(#00BFFF, 40), linewidth=1, style=plot.style_linebr)

// --- Breakeven Level Display ---
be_level_long  = be_enable and be1_triggered and is_long  ? entry1_price + be_offset_pts : na
be_level_short = be_enable and be1_triggered and is_short ? entry1_price - be_offset_pts : na
plot(be_level_long,  "BE (Long)",  color=color.new(color.yellow, 30), linewidth=1, style=plot.style_linebr)
plot(be_level_short, "BE (Short)", color=color.new(color.yellow, 30), linewidth=1, style=plot.style_linebr)

// ============================================================================
// PERFORMANCE DASHBOARD
// ============================================================================
dash_position = switch dash_pos
    "Top Right"    => position.top_right
    "Bottom Right" => position.bottom_right
    "Top Left"     => position.top_left
    "Bottom Left"  => position.bottom_left
    => position.top_right

var table dash = table.new(dash_position, 3, 17, border_width=1,
     frame_color=color.new(color.white, 80), border_color=color.new(color.gray, 85))

if show_dash and barstate.islast
    // Colors
    bg_header = color.new(#1a1a2e, 0)
    bg_row    = color.new(#16213e, 0)
    txt       = color.white

    // Stats
    closed     = strategy.closedtrades
    wins       = strategy.wintrades
    losses     = strategy.losstrades
    win_rate   = closed > 0 ? (wins / closed) * 100 : 0.0
    net_pnl    = strategy.netprofit
    gross_win  = strategy.grossprofit
    gross_loss = math.abs(strategy.grossloss)
    pf         = gross_loss > 0 ? gross_win / gross_loss : 0.0
    expectancy = closed > 0 ? net_pnl / closed : 0.0
    avg_win    = wins > 0 ? gross_win / wins : 0.0
    avg_loss   = losses > 0 ? gross_loss / losses : 0.0
    max_dd     = math.abs(strategy.max_drawdown)

    // Position info
    pos_text = is_flat ? "FLAT" : is_long ? "LONG D:" + str.tostring(num_units) + "/2" : "SHORT D:" + str.tostring(num_units) + "/2"
    pos_col  = is_flat ? color.new(color.gray, 60) : is_long ? color.new(color.green, 50) : color.new(color.red, 50)

    // Signal state
    sig_text = vol_bottom ? "VEB" : vol_peak ? "VEP" : "scanning"
    sig_col  = vol_bottom ? color.new(#00E676, 50) : vol_peak ? color.new(#FF6D00, 50) : color.new(color.gray, 70)

    // Trail level
    trl_val  = is_long ? highest_since - trail_pts : is_short ? lowest_since + trail_pts : na
    trl_text = not na(trl_val) ? str.tostring(trl_val, "#.##") : "—"

    // Chart info
    renko_info = is_renko ? chart_label + " " + str.tostring(brick_size, "#.##") : chart_label

    // Preset label
    preset_lbl = is_ym ? "🔷 YM" : is_nq ? "📈 NQ" : is_es ? "📊 ES" : is_cl ? "🛢️ CL" : is_hg ? "🟤 HG" : "⚙️ CUSTOM"

    // Row 0: Header
    dbg_label = debug_mode ? " 🔧 DEBUG" : ""
    table.cell(dash, 0, 0, "VES v1.11.0", bgcolor=bg_header, text_color=#00BFFF, text_size=size.small)
    table.cell(dash, 1, 0, preset_lbl + " | " + renko_info + dbg_label, bgcolor=debug_mode ? color.new(#FF6B00, 30) : bg_header, text_color=txt, text_size=size.small)
    table.cell(dash, 2, 0, "", bgcolor=bg_header)

    // Row 1: TP/TRAIL
    table.cell(dash, 0, 1, "TP/TRAIL", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 1, str.tostring(tp_pts, "#.##") + "pt TP", bgcolor=bg_row, text_color=#00BFFF, text_size=size.normal)
    table.cell(dash, 2, 1, str.tostring(trail_pts, "#.##") + "pt TRAIL", bgcolor=bg_row, text_color=#00BFFF, text_size=size.normal)

    // Row 2: Signal
    table.cell(dash, 0, 2, "SIGNAL", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 2, sig_text, bgcolor=sig_col, text_color=txt, text_size=size.normal)
    table.cell(dash, 2, 2, "Z:" + str.tostring(vol_z, "0.0"), bgcolor=bg_row, text_color=color.yellow, text_size=size.small)

    // Row 3: Position
    table.cell(dash, 0, 3, "Position", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 3, pos_text, bgcolor=pos_col, text_color=txt, text_size=size.normal)
    table.cell(dash, 2, 3, "Trl:" + trl_text, bgcolor=bg_row, text_color=color.orange, text_size=size.small)

    // Row 4: Session
    sess_text = use_session ? (in_session_raw ? "✓ ACTIVE" : "✗ OUTSIDE") : "OFF"
    sess_col  = not use_session ? color.new(color.gray, 80) : in_session_raw ? color.new(color.green, 60) : color.new(color.orange, 60)
    table.cell(dash, 0, 4, "Session", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 4, sess_text, bgcolor=sess_col, text_color=txt, text_size=size.small)
    table.cell(dash, 2, 4, "", bgcolor=bg_row)

    // Row 5: Daily P&L
    dpnl_col = daily_dd_hit ? color.new(#FF0000, 30) : daily_pt_hit ? color.new(#00FF00, 30) : daily_pnl >= 0 ? color.new(color.green, 50) : daily_pnl > -daily_dd_limit * 0.5 ? color.new(color.orange, 50) : color.new(color.red, 50)
    dpnl_text = "$" + str.tostring(daily_pnl, "#,##0")
    dpnl_status = daily_dd_hit ? " ⛔ DD LIMIT" : daily_pt_hit ? " 🎯 TARGET HIT" : ""
    dpnl_limits = (daily_dd_enabled ? "-$" + str.tostring(daily_dd_limit, "#,##0") : "") + (daily_dd_enabled and daily_pt_enabled ? " / " : "") + (daily_pt_enabled ? "+$" + str.tostring(daily_pt_limit, "#,##0") : "")
    dpnl_trades_text = str.tostring(daily_trades) + "t " + str.tostring(daily_wins) + "W/" + str.tostring(daily_losses) + "L"
    table.cell(dash, 0, 5, "Daily P&L", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 5, dpnl_text + dpnl_status, bgcolor=dpnl_col, text_color=txt, text_size=size.normal)
    table.cell(dash, 2, 5, dpnl_trades_text + " " + dpnl_limits, bgcolor=bg_row, text_color=color.gray, text_size=size.small)

    // Row 6: Bollinger Bands Confluence
    bb_now_text = price_at_lower_bb ? "AT LOWER" : price_at_upper_bb ? "AT UPPER" : price_below_mid ? "LOWER HALF" : price_above_mid ? "UPPER HALF" : "MID"
    bb_gate_long  = bb_ok_long_recent ? "✓" : "✗"
    bb_gate_short = bb_ok_short_recent ? "✓" : "✗"
    bb_conf_col = (bb_ok_long_recent or bb_ok_short_recent) ? color.new(color.green, 50) : color.new(color.gray, 70)
    table.cell(dash, 0, 6, "BB (" + bb_tf + "m)", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 6, bb_now_text, bgcolor=bb_conf_col, text_color=txt, text_size=size.small)
    table.cell(dash, 2, 6, "L:" + bb_gate_long + " S:" + bb_gate_short, bgcolor=bg_row, text_color=color.gray, text_size=size.small)

    // Row 7: HMA 20 (Optional — info only)
    hma_text = hma_bear ? "PRICE < HMA" : hma_bull ? "PRICE > HMA" : "AT HMA"
    hma_slope_text = hma_rising ? "▲ RISING" : hma_falling ? "▼ FALLING" : "— FLAT"
    hma_conf_col = hma_bear ? color.new(#00E676, 60) : hma_bull ? color.new(#FF6D00, 60) : color.new(color.gray, 70)
    table.cell(dash, 0, 7, "HMA 20 ℹ", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 7, hma_text, bgcolor=hma_conf_col, text_color=txt, text_size=size.small)
    table.cell(dash, 2, 7, hma_slope_text, bgcolor=bg_row, text_color=hma_rising ? color.green : hma_falling ? color.red : color.gray, text_size=size.small)

    // Row 8: Confluence Counter
    conf_display = math.max(conf_total_long, conf_total_short)
    conf_detail_l = (conf_flip_long > 0 ? "F" : "·") + (conf_vol_long > 0 ? "V" : "·") + (conf_bb_long > 0 ? "B" : "·") + (conf_session > 0 ? "S" : "·") + (conf_hma_long > 0 ? "H" : "·") + (conf_ema_long > 0 ? "E" : "·")
    conf_detail_s = (conf_flip_short > 0 ? "F" : "·") + (conf_vol_short > 0 ? "V" : "·") + (conf_bb_short > 0 ? "B" : "·") + (conf_session > 0 ? "S" : "·") + (conf_hma_short > 0 ? "H" : "·") + (conf_ema_short > 0 ? "E" : "·")
    conf_col = conf_display >= 5 ? color.new(color.green, 40) : conf_display >= 3 ? color.new(color.yellow, 50) : color.new(color.gray, 70)
    conf_dir_text = conf_total_long > conf_total_short ? "L:" + conf_detail_l : conf_total_short > conf_total_long ? "S:" + conf_detail_s : "L:" + conf_detail_l
    table.cell(dash, 0, 8, "Confluence", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 8, str.tostring(conf_display) + "/" + str.tostring(conf_max), bgcolor=conf_col, text_color=txt, text_size=size.normal)
    table.cell(dash, 2, 8, conf_dir_text, bgcolor=bg_row, text_color=color.gray, text_size=size.small)

    // Row 9: Win Rate
    wr_col = win_rate >= 60 ? color.new(color.green, 50) : win_rate >= 50 ? color.new(color.yellow, 50) : color.new(color.red, 50)
    table.cell(dash, 0, 9, "Win Rate", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 9, str.tostring(win_rate, "0.0") + "%", bgcolor=wr_col, text_color=txt, text_size=size.normal)
    table.cell(dash, 2, 9, str.tostring(closed) + " closed", bgcolor=bg_row, text_color=color.gray, text_size=size.small)

    // Row 10: Net P&L (All-time)
    pnl_col = net_pnl >= 0 ? color.new(color.green, 50) : color.new(color.red, 50)
    table.cell(dash, 0, 10, "Net P&L", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 10, "$" + str.tostring(net_pnl, "#,##0"), bgcolor=pnl_col, text_color=txt, text_size=size.normal)
    table.cell(dash, 2, 10, "DD:$" + str.tostring(max_dd, "#,##0"), bgcolor=bg_row, text_color=color.red, text_size=size.small)

    // Row 11: Profit Factor
    pf_col = pf >= 2.0 ? color.new(color.green, 50) : pf >= 1.5 ? color.new(color.yellow, 50) : color.new(color.red, 50)
    table.cell(dash, 0, 11, "Prof Factor", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 11, str.tostring(pf, "0.00") + "x", bgcolor=pf_col, text_color=txt, text_size=size.normal)
    table.cell(dash, 2, 11, "W:" + str.tostring(wins) + " L:" + str.tostring(losses), bgcolor=bg_row, text_color=color.gray, text_size=size.small)

    // Row 12: Expectancy
    exp_col = expectancy > 0 ? color.new(color.green, 60) : color.new(color.red, 60)
    table.cell(dash, 0, 12, "Expectancy", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 12, "$" + str.tostring(expectancy, "#,##0") + "/trade", bgcolor=exp_col, text_color=txt, text_size=size.small)
    table.cell(dash, 2, 12, "per contract", bgcolor=bg_row, text_color=color.gray, text_size=size.tiny)

    // Row 13: Avg W/L
    table.cell(dash, 0, 13, "Avg W/L", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 13, "$" + str.tostring(avg_win, "#,##0"), bgcolor=color.new(color.green, 65), text_color=txt, text_size=size.small)
    table.cell(dash, 2, 13, "$" + str.tostring(avg_loss, "#,##0"), bgcolor=color.new(color.red, 65), text_color=txt, text_size=size.small)

    // Row 14: Trend
    trend_text = strong_uptrend ? "STRONG ▲" : strong_downtrend ? "STRONG ▼" : ema_stacked_bull ? "BULL" : ema_stacked_bear ? "BEAR" : "MIXED"
    trend_col  = strong_uptrend ? color.new(color.green, 50) : strong_downtrend ? color.new(color.red, 50) : ema_stacked_bull ? color.new(color.green, 70) : ema_stacked_bear ? color.new(color.red, 70) : color.new(color.gray, 70)
    table.cell(dash, 0, 14, "Trend", bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 14, trend_text, bgcolor=trend_col, text_color=txt, text_size=size.small)
    table.cell(dash, 2, 14, "", bgcolor=bg_row)

    // Row 15: Volume Method + Stats
    wave_info = use_wave ? "W:" + str.tostring(wave_cum_vol, "#,##0") + " prev:" + str.tostring(prev_bear_wave, "#,##0") : ""
    roc_info  = use_roc ? "ROC:" + str.tostring(vol_roc_val, "0.0") + "%" : ""
    z_info    = use_z ? "Z:" + str.tostring(vol_z, "0.1") : ""
    method_info = use_wave ? wave_info : use_roc ? roc_info : use_z ? z_info : "—"
    vol_pass = vol_bottom_raw or vol_peak_raw
    vol_col  = vol_pass ? color.new(color.green, 50) : color.new(color.gray, 70)
    table.cell(dash, 0, 15, "Vol " + vol_method_label, bgcolor=bg_row, text_color=color.gray, text_size=size.small)
    table.cell(dash, 1, 15, vol_pass ? "✓ EXHAUSTION" : "· scanning", bgcolor=vol_col, text_color=txt, text_size=size.small)
    table.cell(dash, 2, 15, method_info, bgcolor=bg_row, text_color=color.gray, text_size=size.tiny)

    // Row 16: Debug Gate Diagnostic
    if debug_mode
        table.cell(dash, 0, 16, "🔧 DEBUG", bgcolor=color.new(#FF6B00, 30), text_color=txt, text_size=size.small)
        table.cell(dash, 1, 16, "ALL GATES BYPASSED", bgcolor=color.new(#FF6B00, 30), text_color=txt, text_size=size.small)
        table.cell(dash, 2, 16, "flip only", bgcolor=color.new(#FF6B00, 50), text_color=txt, text_size=size.small)
    else
        flip_ok = flip_to_bull or flip_to_bear
        dbg_flip = flip_ok ? "✓" : "·"
        dbg_vol  = not debug_require_vol ? "OFF" : (vol_pass ? "✓" : "✗")
        dbg_bb   = not debug_require_bb ? "OFF" : ((bb_ok_long or bb_ok_short) ? "✓" : "✗")
        dbg_trend = not debug_require_trend ? "OFF" : ((trend_gate_long or trend_gate_short) ? "✓" : "✗")
        dbg_sess = not debug_require_session ? "OFF" : (in_session ? "✓" : "✗")
        table.cell(dash, 0, 16, "🔧 GATES", bgcolor=color.new(#1a1a2e, 0), text_color=color.orange, text_size=size.small)
        table.cell(dash, 1, 16, "F:" + dbg_flip + " V:" + dbg_vol + " BB:" + dbg_bb, bgcolor=color.new(#16213e, 0), text_color=color.orange, text_size=size.small)
        table.cell(dash, 2, 16, "TR:" + dbg_trend + " SS:" + dbg_sess, bgcolor=color.new(#16213e, 0), text_color=color.orange, text_size=size.small)

// ============================================================================
// ALERT CONDITIONS
// ============================================================================
alertcondition(vol_bottom, title="🟢 VOL BOTTOM (Long)", message="VEB — Volume Exhaustion Bottom detected. Long entry signal.")
alertcondition(vol_peak,   title="🔴 VOL PEAK (Short)",  message="VEP — Volume Exhaustion Peak detected. Short entry signal.")
alertcondition(vol_bottom and is_short, title="🔄 FLATTEN→LONG", message="Flattening shorts, entering long on VOL BOTTOM.")
alertcondition(vol_peak and is_long,    title="🔄 FLATTEN→SHORT", message="Flattening longs, entering short on VOL PEAK.")
