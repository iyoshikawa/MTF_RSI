// EMA River Strategy v1.1.5

//@version=6
strategy("EMA River Strategy v1.1.5", 
     overlay=true, 
     initial_capital=1000000,
     currency=currency.USD,
     default_qty_type=strategy.fixed, 
     default_qty_value=1,
     pyramiding=2,
     calc_on_order_fills=true,
     calc_on_every_tick=false,
     process_orders_on_close=true)

// ══════════════════════════════════════════════════════════════════════════════
// ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ INPUTS ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// ══════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────── Moving Averages ──────────────────────────────
grpMA = "═══ Moving Averages ═══"

ema9_len    = input.int(9, "9 EMA Length", minval=1, group=grpMA, 
     tooltip="ENTRY CONFLUENCE MAs\nThese MAs determine entry signals. All must align for entry.\n\n9 EMA Length: Fast signal line period. Default: 9")
ema9_src    = input.source(ohlc4, "9 EMA Source", group=grpMA, 
     tooltip="Price source for 9 EMA calculation. Default: OHLC4 (average of open, high, low, close)")

ema20_len   = input.int(20, "20 EMA River Length", minval=1, group=grpMA, 
     tooltip="EMA River period. Creates High/HL2/Low channel. Default: 20")

hma20_len   = input.int(20, "20 HMA Length", minval=1, group=grpMA, 
     tooltip="Hull Moving Average period for entry confluence. Default: 20")
hma20_src   = input.source(close, "20 HMA Source", group=grpMA, 
     tooltip="Price source for 20 HMA calculation. Default: Close")

// ─────────────────────────────── MA Line Styles ──────────────────────────────
grpMAStyle = "═══ MA Line Styles ═══"

ema9_bull_color   = input.color(color.lime, "9 EMA Bullish", group=grpMAStyle, tooltip="LINE STYLE SETTINGS\nCustomize colors, width, and line type for all MAs.\n\n9 EMA color when price is above. Default: Lime")
ema9_bear_color   = input.color(color.red, "9 EMA Bearish", group=grpMAStyle, tooltip="9 EMA color when price is below. Default: Red")
ema9_width        = input.int(2, "9 EMA Width", minval=1, maxval=5, group=grpMAStyle, tooltip="9 EMA line thickness. Default: 2")
ema9_style        = input.string("Solid", "9 EMA Style", options=["Solid", "Dashed", "Dotted"], group=grpMAStyle, tooltip="9 EMA line style. Default: Solid")

river_bull_color  = input.color(color.lime, "River Bullish", group=grpMAStyle, tooltip="EMA River color when price is above. Default: Lime")
river_bear_color  = input.color(color.red, "River Bearish", group=grpMAStyle, tooltip="EMA River color when price is below. Default: Red")
river_high_width  = input.int(1, "River High Width", minval=1, maxval=5, group=grpMAStyle, tooltip="EMA River High line thickness. Default: 1")
river_hl2_width   = input.int(2, "River HL2 Width", minval=1, maxval=5, group=grpMAStyle, tooltip="EMA River HL2 line thickness. Default: 2")
river_low_width   = input.int(1, "River Low Width", minval=1, maxval=5, group=grpMAStyle, tooltip="EMA River Low line thickness. Default: 1")
river_style       = input.string("Solid", "River Style", options=["Solid", "Dashed", "Dotted"], group=grpMAStyle, tooltip="EMA River line style. Default: Solid")

hma20_bull_color  = input.color(color.lime, "20 HMA Bullish", group=grpMAStyle, tooltip="20 HMA color when price is above. Default: Lime")
hma20_bear_color  = input.color(color.red, "20 HMA Bearish", group=grpMAStyle, tooltip="20 HMA color when price is below. Default: Red")
hma20_width       = input.int(2, "20 HMA Width", minval=1, maxval=5, group=grpMAStyle, tooltip="20 HMA line thickness. Default: 2")
hma20_style       = input.string("Solid", "20 HMA Style", options=["Solid", "Dashed", "Dotted"], group=grpMAStyle, tooltip="20 HMA line style. Default: Solid")

// ─────────────────────────────── HMA Exit Ribbon ──────────────────────────────
grpHMAExit = "═══ HMA Exit Ribbon ═══"

hmaFast_len = input.int(6, "Fast HMA Length", minval=1, group=grpHMAExit, 
     tooltip="EXIT SIGNAL MAs\nFast/Slow HMA crossover determines position exit.\n\nFast HMA period. Default: 6")
hmaSlow_len = input.int(21, "Slow HMA Length", minval=1, group=grpHMAExit, 
     tooltip="Slow HMA period. Default: 21")
hmaExit_src = input.source(close, "HMA Exit Source", group=grpHMAExit, 
     tooltip="Price source for exit HMA calculation. Default: Close")

// HMA Exit Styles
hmaExit_bull_color   = input.color(color.lime, "HMA Exit Bullish", group=grpHMAExit, tooltip="Exit HMA color when price is above. Default: Lime")
hmaExit_bear_color   = input.color(color.red, "HMA Exit Bearish", group=grpHMAExit, tooltip="Exit HMA color when price is below. Default: Red")
hmaExit_fast_width   = input.int(1, "Fast HMA Width", minval=1, maxval=5, group=grpHMAExit, tooltip="Fast HMA line thickness. Default: 1")
hmaExit_slow_width   = input.int(1, "Slow HMA Width", minval=1, maxval=5, group=grpHMAExit, tooltip="Slow HMA line thickness. Default: 1")
hmaExit_style        = input.string("Solid", "HMA Exit Style", options=["Solid", "Dashed", "Dotted"], group=grpHMAExit, tooltip="Exit HMA line style. Default: Solid")
hmaRibbon_bull_color = input.color(color.new(color.green, 70), "Ribbon Bullish", group=grpHMAExit, tooltip="Ribbon fill when Fast > Slow. Default: Green 70% transparent")
hmaRibbon_bear_color = input.color(color.new(color.red, 70), "Ribbon Bearish", group=grpHMAExit, tooltip="Ribbon fill when Fast < Slow. Default: Red 70% transparent")

// ─────────────────────────────── RSI Ribbon ───────────────────────────────────
grpRibbon = "═══ RSI Momentum Ribbon ═══"

rsi_short_len       = input.int(5, "Short RSI Period", minval=1, group=grpRibbon, 
     tooltip="RSI MOMENTUM INDICATOR\nBackground color shows momentum direction based on RSI difference.\n\nShort RSI lookback period. Default: 5")
rsi_long_len        = input.int(13, "Long RSI Period", minval=1, group=grpRibbon, 
     tooltip="Long RSI lookback period. Default: 13")
rsi_short_smooth    = input.int(2, "Short RSI Smoothing", minval=1, group=grpRibbon, 
     tooltip="EMA smoothing applied to short RSI. Default: 2")
rsi_long_smooth     = input.int(3, "Long RSI Smoothing", minval=1, group=grpRibbon, 
     tooltip="EMA smoothing applied to long RSI. Default: 3")
rsi_threshold       = input.float(1.0, "RSI Neutral Zone", minval=0.1, step=0.1, group=grpRibbon, 
     tooltip="Minimum RSI difference to register direction. Below this = neutral. Default: 1.0")
ribbon_bull_color   = input.color(#00ffbb, "Bullish Color", group=grpRibbon, 
     tooltip="Background color when RSI is bullish. Default: Cyan-green")
ribbon_bear_color   = input.color(#ff0055, "Bearish Color", group=grpRibbon, 
     tooltip="Background color when RSI is bearish. Default: Pink-red")
ribbon_transparency = input.int(85, "Transparency", minval=0, maxval=95, step=5, group=grpRibbon, 
     tooltip="Background transparency (0=opaque, 95=nearly invisible). Default: 85")

// ─────────────────────────────── Double Stochastic ────────────────────────────
grpDStoch = "═══ Double Stochastic ═══"

showDStochSignals = input.bool(true, "Show DStoch Signals", group=grpDStoch, 
     tooltip="DOUBLE STOCHASTIC INDICATOR\nShows overbought/oversold crossover signals.\n\nDisplay DS▲/DS▼ markers on chart. Default: true")
stochLen          = input.int(10, "DStoch Period", minval=1, group=grpDStoch, 
     tooltip="Stochastic lookback period. Default: 10")
stochSmth         = input.int(3, "DStoch Smoothing", minval=1, group=grpDStoch, 
     tooltip="Double-EMA smoothing applied to stochastic. Default: 3")
stoch_sell_level  = input.float(85, "Sell Level", minval=50, maxval=100, group=grpDStoch, 
     tooltip="Overbought level - cross down triggers sell signal. Default: 85")
stoch_buy_level   = input.float(12, "Buy Level", minval=0, maxval=50, group=grpDStoch, 
     tooltip="Oversold level - cross up triggers buy signal. Default: 12")
dstoch_buy_color  = input.color(color.aqua, "Buy Signal Color", group=grpDStoch, 
     tooltip="Color for DS▲ buy markers. Default: Aqua")
dstoch_sell_color = input.color(color.fuchsia, "Sell Signal Color", group=grpDStoch, 
     tooltip="Color for DS▼ sell markers. Default: Fuchsia")

// ─────────────────────────────── Chop Filter: Bollinger Bands ─────────────────
grpBB = "═══ Chop Filter: Bollinger Bands ═══"

useBBChop   = input.bool(true, "Enable BB Chop Filter", group=grpBB, 
     tooltip="BOLLINGER BAND CHOP FILTER\nBlocks entries when price is inside BB bands (choppy/ranging market).\n\nEnable/disable this filter. Default: true")
bbLength    = input.int(10, "BB Length", minval=1, group=grpBB, 
     tooltip="Bollinger Band period. Default: 10")
bbStdDev    = input.float(1.2, "BB StdDev", minval=0.1, step=0.1, group=grpBB, 
     tooltip="Standard deviation multiplier for bands. Default: 1.2")
bbTimeframe = input.timeframe("3", "BB Timeframe", group=grpBB, 
     tooltip="Timeframe for BB calculation (MTF). Default: 3 minutes")

// ─────────────────────────────── Chop Filter: T-Line 1 (20/34) ───────────────
grpTLine1 = "═══ T-Line 1 (20 EMA / 34pt) ═══"

useTLine1        = input.bool(true, "Enable T-Line 1", group=grpTLine1, 
     tooltip="T-LINE CHANNEL CHOP FILTER 1\nBlocks entries when price is inside the channel. Smaller channel for tighter filtering.\n\nEnable/disable this filter. Default: true")
tline1_period    = input.int(20, "Period", minval=1, group=grpTLine1, 
     tooltip="MA period for T-Line center. Default: 20")
tline1_maType    = input.int(0, "MA Type", minval=0, maxval=3, group=grpTLine1, 
     tooltip="0=EMA, 1=SMA, 2=VWMA, 3=WMA. Default: 0 (EMA)")
tline1_width     = input.int(34, "Channel Width (points)", minval=1, group=grpTLine1, 
     tooltip="Points above/below MA to form channel. Default: 34")
tline1_calcType  = input.int(0, "Calc Type", minval=0, maxval=6, group=grpTLine1, 
     tooltip="0=Close, 1=Open, 2=High, 3=Low, 4=HL2, 5=HLC3, 6=OHLC4. Default: 0 (Close)")
tline1_cooldown  = input.int(15, "Cooldown (seconds)", minval=0, group=grpTLine1, 
     tooltip="Wait X seconds after price exits channel before allowing entries. Default: 15")
tline1_clearance = input.int(10, "Distance Clearance (points)", minval=0, group=grpTLine1, 
     tooltip="Price must be this many points AWAY from channel edge before entry allowed. Prevents entries right at the edge. Default: 10")
tline1_reentry_lock = input.int(30, "Re-entry Lockout (seconds)", minval=0, group=grpTLine1, 
     tooltip="If price re-enters channel within X seconds of exiting, reset cooldown. Prevents whipsaw entries. Default: 30")

// T-Line 1 Styles
tline1_ma_bull    = input.color(color.lime, "MA Bullish", group=grpTLine1, tooltip="T-Line 1 MA color when price above. Default: Lime")
tline1_ma_bear    = input.color(color.red, "MA Bearish", group=grpTLine1, tooltip="T-Line 1 MA color when price below. Default: Red")
tline1_ma_width   = input.int(2, "MA Width", minval=1, maxval=5, group=grpTLine1, tooltip="T-Line 1 MA line thickness. Default: 2")
tline1_ma_style   = input.string("Solid", "MA Style", options=["Solid", "Dashed", "Dotted"], group=grpTLine1, tooltip="T-Line 1 MA line style. Default: Solid")
tline1_band_color = input.color(color.new(color.yellow, 50), "Band Color", group=grpTLine1, tooltip="T-Line 1 upper/lower band color. Default: Yellow 50%")
tline1_band_width = input.int(1, "Band Width", minval=1, maxval=5, group=grpTLine1, tooltip="T-Line 1 band line thickness. Default: 1")
tline1_fill_in    = input.color(color.new(color.yellow, 70), "Fill (Inside)", group=grpTLine1, tooltip="Channel fill when price is inside. Default: Yellow 70%")
tline1_fill_out   = input.color(color.new(color.gray, 85), "Fill (Outside)", group=grpTLine1, tooltip="Channel fill when price is outside. Default: Gray 85%")

// ─────────────────────────────── Chop Filter: T-Line 2 (50/80) ───────────────
grpTLine2 = "═══ T-Line 2 (50 EMA / 80pt) ═══"

useTLine2        = input.bool(true, "Enable T-Line 2", group=grpTLine2, 
     tooltip="T-LINE CHANNEL CHOP FILTER 2\nLarger channel for broader consolidation detection.\n\nEnable/disable this filter. Default: true")
tline2_period    = input.int(50, "Period", minval=1, group=grpTLine2, 
     tooltip="MA period for T-Line center. Default: 50")
tline2_maType    = input.int(0, "MA Type", minval=0, maxval=3, group=grpTLine2, 
     tooltip="0=EMA, 1=SMA, 2=VWMA, 3=WMA. Default: 0 (EMA)")
tline2_width     = input.int(80, "Channel Width (points)", minval=1, group=grpTLine2, 
     tooltip="Points above/below MA to form channel. Default: 80")
tline2_calcType  = input.int(0, "Calc Type", minval=0, maxval=6, group=grpTLine2, 
     tooltip="0=Close, 1=Open, 2=High, 3=Low, 4=HL2, 5=HLC3, 6=OHLC4. Default: 0 (Close)")
tline2_cooldown  = input.int(15, "Cooldown (seconds)", minval=0, group=grpTLine2, 
     tooltip="Wait X seconds after price exits channel before allowing entries. Default: 15")
tline2_clearance = input.int(15, "Distance Clearance (points)", minval=0, group=grpTLine2, 
     tooltip="Price must be this many points AWAY from channel edge before entry allowed. Prevents entries right at the edge. Default: 15")
tline2_reentry_lock = input.int(30, "Re-entry Lockout (seconds)", minval=0, group=grpTLine2, 
     tooltip="If price re-enters channel within X seconds of exiting, reset cooldown. Prevents whipsaw entries. Default: 30")

// T-Line 2 Styles
tline2_ma_bull    = input.color(color.lime, "MA Bullish", group=grpTLine2, tooltip="T-Line 2 MA color when price above. Default: Lime")
tline2_ma_bear    = input.color(color.red, "MA Bearish", group=grpTLine2, tooltip="T-Line 2 MA color when price below. Default: Red")
tline2_ma_width   = input.int(2, "MA Width", minval=1, maxval=5, group=grpTLine2, tooltip="T-Line 2 MA line thickness. Default: 2")
tline2_ma_style   = input.string("Solid", "MA Style", options=["Solid", "Dashed", "Dotted"], group=grpTLine2, tooltip="T-Line 2 MA line style. Default: Solid")
tline2_band_color = input.color(color.new(color.orange, 50), "Band Color", group=grpTLine2, tooltip="T-Line 2 upper/lower band color. Default: Orange 50%")
tline2_band_width = input.int(1, "Band Width", minval=1, maxval=5, group=grpTLine2, tooltip="T-Line 2 band line thickness. Default: 1")
tline2_fill_in    = input.color(color.new(color.orange, 70), "Fill (Inside)", group=grpTLine2, tooltip="Channel fill when price is inside. Default: Orange 70%")
tline2_fill_out   = input.color(color.new(color.gray, 85), "Fill (Outside)", group=grpTLine2, tooltip="Channel fill when price is outside. Default: Gray 85%")

// ─────────────────────────────── Session Filters ──────────────────────────────
grpSession = "═══ Session Filters ═══"

useSessionFilter = input.bool(true, "Enable Session Filter", group=grpSession, 
     tooltip="SESSION TIME FILTER\nOnly allow entries during specified trading windows.\n\nEnable/disable session filtering. Default: true")
sessionConfig    = input.string("1801-1940,0700-0815,0930-1100,1545-1600:23456", "Session Windows", group=grpSession, 
     tooltip="Format: TIME1,TIME2,TIME3:DAYS\nTimes in 24hr format (HHMM-HHMM)\nDays: 1=Sun 2=Mon 3=Tue 4=Wed 5=Thu 6=Fri 7=Sat\nExample: 0930-1100,1330-1600:23456 = Mon-Fri 9:30-11:00 and 1:30-4:00\nDefault: Globex evening, pre-market, NY AM, NY close on Mon-Fri")
sessionTZ        = input.string("America/New_York", "Timezone", group=grpSession, 
     tooltip="Timezone for session times. Default: America/New_York (ET)")

// ─────────────────────────────── Position Management ──────────────────────────
grpExit = "═══ Position Management ═══"

useSecondContract = input.bool(true, "Trade 2 Contracts", group=grpExit, 
     tooltip="MULTI-CONTRACT POSITION SIZING\nTrade 1 or 2 contracts with independent exit rules.\n\nEnable second contract for scaled exits. Default: true")

// Contract 1 (Scalp)
grpC1 = "═══ Contract 1 (Scalp) ═══"
c1_tp_ticks      = input.int(50, "Take Profit (ticks)", minval=1, group=grpC1, 
     tooltip="CONTRACT 1 EXIT RULES\nScalp contract - quick profit target.\n\nTake profit distance in ticks. Default: 50")
c1_sl_ticks      = input.int(40, "Stop Loss (ticks)", minval=1, group=grpC1, 
     tooltip="Stop loss distance in ticks. Default: 40")
c1_be_trigger    = input.int(30, "BE Trigger (ticks profit)", minval=1, group=grpC1, 
     tooltip="Move stop to breakeven when profit reaches this level. Default: 30")
c1_be_offset     = input.int(10, "BE Offset (ticks)", minval=0, group=grpC1, 
     tooltip="Ticks above entry for BE stop (locks in small profit). Default: 10")
c1_use_trail     = input.bool(false, "Use Trail", group=grpC1, 
     tooltip="Enable trailing stop for Contract 1. Default: false")
c1_trail_stop    = input.int(20, "Trail Stop (ticks)", minval=1, group=grpC1, 
     tooltip="Trailing stop distance behind price. Default: 20")
c1_trail_trigger = input.int(30, "Trail Trigger (ticks profit)", minval=1, group=grpC1, 
     tooltip="Activate trailing stop when profit reaches this level. Default: 30")

// Contract 2 (Runner)
grpC2 = "═══ Contract 2 (Runner) ═══"
c2_tp_ticks      = input.int(125, "Take Profit (ticks)", minval=1, group=grpC2, 
     tooltip="CONTRACT 2 EXIT RULES\nRunner contract - larger profit target with trail.\n\nTake profit distance in ticks. Default: 125")
c2_sl_ticks      = input.int(40, "Stop Loss (ticks)", minval=1, group=grpC2, 
     tooltip="Stop loss distance in ticks. Default: 40")
c2_be_trigger    = input.int(30, "BE Trigger (ticks profit)", minval=1, group=grpC2, 
     tooltip="Move stop to breakeven when profit reaches this level. Default: 30")
c2_be_offset     = input.int(10, "BE Offset (ticks)", minval=0, group=grpC2, 
     tooltip="Ticks above entry for BE stop (locks in small profit). Default: 10")
c2_use_trail     = input.bool(true, "Use Trail", group=grpC2, 
     tooltip="Enable trailing stop for Contract 2. Default: true")
c2_trail_stop    = input.int(20, "Trail Stop (ticks)", minval=1, group=grpC2, 
     tooltip="Trailing stop distance behind price. Default: 20")
c2_trail_trigger = input.int(30, "Trail Trigger (ticks profit)", minval=1, group=grpC2, 
     tooltip="Activate trailing stop when profit reaches this level. Default: 30")

// ─────────────────────────────── Display ──────────────────────────────────────
grpDisplay = "═══ Display ═══"

showEMA9    = input.bool(true, "Show 9 EMA", group=grpDisplay, 
     tooltip="CHART ELEMENT VISIBILITY\nToggle display of various chart elements.\n\nShow/hide 9 EMA line. Default: true")
showRiver   = input.bool(true, "Show EMA River", group=grpDisplay, 
     tooltip="Show/hide EMA River (High/HL2/Low). Default: true")
showHMA     = input.bool(true, "Show 20 HMA", group=grpDisplay, 
     tooltip="Show/hide 20 HMA line. Default: true")
showHMAExit = input.bool(true, "Show HMA Exit Ribbon", group=grpDisplay, 
     tooltip="Show/hide HMA Exit Ribbon (6/21 HMA). Default: true")
showTLine1  = input.bool(true, "Show T-Line 1", group=grpDisplay, 
     tooltip="Show/hide T-Line 1 channel (20/34). Default: true")
showTLine2  = input.bool(true, "Show T-Line 2", group=grpDisplay, 
     tooltip="Show/hide T-Line 2 channel (50/80). Default: true")
showSignals = input.bool(true, "Show Entry Arrows", group=grpDisplay, 
     tooltip="Show/hide entry signal arrows (L/S). Default: true")
showDebug   = input.bool(true, "Show Debug Table", group=grpDisplay, 
     tooltip="Show/hide debug info table in corner. Default: true")

// Entry signal styles
grpSignals = "═══ Entry Signal Styles ═══"
long_signal_color  = input.color(color.lime, "Long Signal Color", group=grpSignals, tooltip="ENTRY ARROW STYLES\n\nLong entry arrow color. Default: Lime")
short_signal_color = input.color(color.red, "Short Signal Color", group=grpSignals, tooltip="Short entry arrow color. Default: Red")

// ══════════════════════════════════════════════════════════════════════════════
// ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ FUNCTIONS ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// ══════════════════════════════════════════════════════════════════════════════

// Line style helper
f_linestyle(_style) =>
    switch _style
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

// HMA calculation
f_hma(_src, _len) =>
    _halfLen = math.floor(_len / 2)
    _sqrtLen = math.floor(math.sqrt(_len))
    _wma1 = ta.wma(_src, _halfLen)
    _wma2 = ta.wma(_src, _len)
    ta.wma(2 * _wma1 - _wma2, _sqrtLen)

// Source selector
f_src(_type) =>
    switch _type
        0 => close
        1 => open
        2 => high
        3 => low
        4 => hl2
        5 => hlc3
        6 => ohlc4
        => close

// MA type selector
f_ma(_src, _len, _type) =>
    switch _type
        0 => ta.ema(_src, _len)
        1 => ta.sma(_src, _len)
        2 => ta.vwma(_src, _len)
        3 => ta.wma(_src, _len)
        => ta.ema(_src, _len)

// ══════════════════════════════════════════════════════════════════════════════
// ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ CALCULATIONS ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// ══════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────── Moving Averages ──────────────────────────────
ema9 = ta.ema(ema9_src, ema9_len)

ema20_high = ta.ema(high, ema20_len)
ema20_hl2  = ta.ema(hl2, ema20_len)
ema20_low  = ta.ema(low, ema20_len)

hma20 = f_hma(hma20_src, hma20_len)

// ─────────────────────────────── HMA Exit Ribbon ──────────────────────────────
hmaFast = f_hma(hmaExit_src, hmaFast_len)
hmaSlow = f_hma(hmaExit_src, hmaSlow_len)

hmaBullishCross = ta.crossover(hmaFast, hmaSlow)
hmaBearishCross = ta.crossunder(hmaFast, hmaSlow)

// ─────────────────────────────── RSI Momentum ─────────────────────────────────
f_double_rsi(_src, _short_len, _long_len, _short_smooth, _long_smooth) =>
    rsiS = ta.ema(ta.rsi(_src, _short_len), _short_smooth)
    rsiL = ta.ema(ta.rsi(_src, _long_len), _long_smooth)
    rsiS - rsiL

rsi_diff = f_double_rsi(close, rsi_short_len, rsi_long_len, rsi_short_smooth, rsi_long_smooth)
rsi_bullish = rsi_diff > rsi_threshold
rsi_bearish = rsi_diff < -rsi_threshold

// ─────────────────────────────── Double Stochastic ────────────────────────────
f_double_stoch(_len, _smooth) =>
    raw_stoch = ta.stoch(close, high, low, _len)
    ta.ema(ta.ema(raw_stoch, _smooth), _smooth)

db_stoch = f_double_stoch(stochLen, stochSmth)
stoch_sell_signal = ta.crossunder(db_stoch, stoch_sell_level)
stoch_buy_signal  = ta.crossover(db_stoch, stoch_buy_level)

// ─────────────────────────────── MA Direction ─────────────────────────────────
ema9_bullish     = close > ema9
ema9_bearish     = close < ema9

hma20_bullish    = close > hma20
hma20_bearish    = close < hma20

ema20_high_bullish = close > ema20_high
ema20_low_bearish  = close < ema20_low

// ─────────────────────────────── Chop Filter: Bollinger Bands ─────────────────
[bbMiddle, bbUpper, bbLower] = request.security(syminfo.tickerid, bbTimeframe, 
     ta.bb(close, bbLength, bbStdDev), lookahead=barmerge.lookahead_off)

insideBB = close < bbUpper and close > bbLower
bbChopActive = useBBChop and insideBB

// ─────────────────────────────── Chop Filter: T-Line 1 ────────────────────────
tline1_src = f_src(tline1_calcType)
tline1_ma  = f_ma(tline1_src, tline1_period, tline1_maType)
tline1_widthPrice = tline1_width * syminfo.mintick
tline1_upper = tline1_ma + tline1_widthPrice
tline1_lower = tline1_ma - tline1_widthPrice
insideTLine1 = close < tline1_upper and close > tline1_lower

// Distance from channel edges (in points)
tline1_dist_above = (close - tline1_upper) / syminfo.mintick  // positive when above upper
tline1_dist_below = (tline1_lower - close) / syminfo.mintick  // positive when below lower
tline1_clearance_met = tline1_dist_above >= tline1_clearance or tline1_dist_below >= tline1_clearance

// Cooldown and re-entry lockout tracking
var int tline1_exitTime = 0
var int tline1_lastInsideTime = 0
tline1_cooldownMs = tline1_cooldown * 1000
tline1_reentryMs = tline1_reentry_lock * 1000

// Track when price is inside channel
if insideTLine1
    tline1_lastInsideTime := time

// Track when price exits channel
if insideTLine1[1] and not insideTLine1
    tline1_exitTime := time

// Re-entry lockout: if price re-enters within lockout window, reset exit time
if not insideTLine1[1] and insideTLine1
    // Price just re-entered - check if within lockout window
    if tline1_exitTime > 0 and (time - tline1_exitTime) < tline1_reentryMs
        tline1_exitTime := 0  // Reset - will need fresh exit and cooldown

tline1_timeSinceExit = time - tline1_exitTime
tline1_cooldownActive = tline1_exitTime > 0 and tline1_timeSinceExit < tline1_cooldownMs

// T-Line 1 blocks entry if: inside channel OR in cooldown OR distance clearance not met
tline1_chop = useTLine1 and (insideTLine1 or tline1_cooldownActive or (not insideTLine1 and not tline1_clearance_met))

// ─────────────────────────────── Chop Filter: T-Line 2 ────────────────────────
tline2_src = f_src(tline2_calcType)
tline2_ma  = f_ma(tline2_src, tline2_period, tline2_maType)
tline2_widthPrice = tline2_width * syminfo.mintick
tline2_upper = tline2_ma + tline2_widthPrice
tline2_lower = tline2_ma - tline2_widthPrice
insideTLine2 = close < tline2_upper and close > tline2_lower

// Distance from channel edges (in points)
tline2_dist_above = (close - tline2_upper) / syminfo.mintick  // positive when above upper
tline2_dist_below = (tline2_lower - close) / syminfo.mintick  // positive when below lower
tline2_clearance_met = tline2_dist_above >= tline2_clearance or tline2_dist_below >= tline2_clearance

// Cooldown and re-entry lockout tracking
var int tline2_exitTime = 0
var int tline2_lastInsideTime = 0
tline2_cooldownMs = tline2_cooldown * 1000
tline2_reentryMs = tline2_reentry_lock * 1000

// Track when price is inside channel
if insideTLine2
    tline2_lastInsideTime := time

// Track when price exits channel
if insideTLine2[1] and not insideTLine2
    tline2_exitTime := time

// Re-entry lockout: if price re-enters within lockout window, reset exit time
if not insideTLine2[1] and insideTLine2
    // Price just re-entered - check if within lockout window
    if tline2_exitTime > 0 and (time - tline2_exitTime) < tline2_reentryMs
        tline2_exitTime := 0  // Reset - will need fresh exit and cooldown

tline2_timeSinceExit = time - tline2_exitTime
tline2_cooldownActive = tline2_exitTime > 0 and tline2_timeSinceExit < tline2_cooldownMs

// T-Line 2 blocks entry if: inside channel OR in cooldown OR distance clearance not met
tline2_chop = useTLine2 and (insideTLine2 or tline2_cooldownActive or (not insideTLine2 and not tline2_clearance_met))

// ─────────────────────────────── Session Filter ───────────────────────────────
config_parts = str.split(sessionConfig, ":")
times_str = array.get(config_parts, 0)
days_str = array.size(config_parts) > 1 ? array.get(config_parts, 1) : "23456"

time_windows = str.split(times_str, ",")
num_windows = array.size(time_windows)
day_suffix = ":" + days_str

in_w1 = num_windows >= 1 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 0)) + day_suffix, sessionTZ)) : false
in_w2 = num_windows >= 2 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 1)) + day_suffix, sessionTZ)) : false
in_w3 = num_windows >= 3 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 2)) + day_suffix, sessionTZ)) : false
in_w4 = num_windows >= 4 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 3)) + day_suffix, sessionTZ)) : false
in_w5 = num_windows >= 5 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 4)) + day_suffix, sessionTZ)) : false
in_w6 = num_windows >= 6 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 5)) + day_suffix, sessionTZ)) : false

inAnyWindow = in_w1 or in_w2 or in_w3 or in_w4 or in_w5 or in_w6
inTradingSession = not useSessionFilter or inAnyWindow

// ══════════════════════════════════════════════════════════════════════════════
// ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ ENTRY CONDITIONS ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// ══════════════════════════════════════════════════════════════════════════════

longConditions = rsi_bullish and ema9_bullish and hma20_bullish and ema20_high_bullish
shortConditions = rsi_bearish and ema9_bearish and hma20_bearish and ema20_low_bearish

canTrade = inTradingSession and not bbChopActive and not tline1_chop and not tline2_chop and strategy.position_size == 0

longSignal  = canTrade and longConditions
shortSignal = canTrade and shortConditions

// ══════════════════════════════════════════════════════════════════════════════
// ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ EXIT CONDITIONS ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// ══════════════════════════════════════════════════════════════════════════════

longExitSignal  = hmaBearishCross
shortExitSignal = hmaBullishCross

// ══════════════════════════════════════════════════════════════════════════════
// ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ POSITION MANAGEMENT ░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// ══════════════════════════════════════════════════════════════════════════════

var float long1_entry = na
var float long2_entry = na
var float short1_entry = na
var float short2_entry = na

var bool long1_be_active = false
var bool long2_be_active = false
var bool short1_be_active = false
var bool short2_be_active = false

var bool long1_trail_active = false
var bool long2_trail_active = false
var bool short1_trail_active = false
var bool short2_trail_active = false

long1_open  = not na(long1_entry) and strategy.position_size > 0
long2_open  = not na(long2_entry) and strategy.position_size > 0
short1_open = not na(short1_entry) and strategy.position_size < 0
short2_open = not na(short2_entry) and strategy.position_size < 0

// ─────────────────────────────── ENTRIES ──────────────────────────────────────
if longSignal
    strategy.entry("Long1", strategy.long)
    long1_entry := close
    long1_be_active := false
    long1_trail_active := false
    
    if useSecondContract
        strategy.entry("Long2", strategy.long)
        long2_entry := close
        long2_be_active := false
        long2_trail_active := false

if shortSignal
    strategy.entry("Short1", strategy.short)
    short1_entry := close
    short1_be_active := false
    short1_trail_active := false
    
    if useSecondContract
        strategy.entry("Short2", strategy.short)
        short2_entry := close
        short2_be_active := false
        short2_trail_active := false

// ─────────────────────────────── EXIT MANAGEMENT ──────────────────────────────
long1_profit_ticks  = long1_open ? (close - long1_entry) / syminfo.mintick : 0
long2_profit_ticks  = long2_open ? (close - long2_entry) / syminfo.mintick : 0
short1_profit_ticks = short1_open ? (short1_entry - close) / syminfo.mintick : 0
short2_profit_ticks = short2_open ? (short2_entry - close) / syminfo.mintick : 0

if long1_open and long1_profit_ticks >= c1_be_trigger
    long1_be_active := true
if long2_open and long2_profit_ticks >= c2_be_trigger
    long2_be_active := true
if short1_open and short1_profit_ticks >= c1_be_trigger
    short1_be_active := true
if short2_open and short2_profit_ticks >= c2_be_trigger
    short2_be_active := true

if c1_use_trail and long1_open and long1_profit_ticks >= c1_trail_trigger
    long1_trail_active := true
if c2_use_trail and long2_open and long2_profit_ticks >= c2_trail_trigger
    long2_trail_active := true
if c1_use_trail and short1_open and short1_profit_ticks >= c1_trail_trigger
    short1_trail_active := true
if c2_use_trail and short2_open and short2_profit_ticks >= c2_trail_trigger
    short2_trail_active := true

// ─────────────────────────────── CONTRACT 1 EXITS ─────────────────────────────
if long1_open
    if long1_trail_active
        strategy.exit("Long1 Exit", "Long1", profit=c1_tp_ticks, trail_points=c1_trail_trigger, trail_offset=c1_trail_stop)
    else if long1_be_active
        strategy.exit("Long1 Exit", "Long1", profit=c1_tp_ticks, stop=long1_entry + c1_be_offset * syminfo.mintick)
    else
        strategy.exit("Long1 Exit", "Long1", profit=c1_tp_ticks, loss=c1_sl_ticks)

if short1_open
    if short1_trail_active
        strategy.exit("Short1 Exit", "Short1", profit=c1_tp_ticks, trail_points=c1_trail_trigger, trail_offset=c1_trail_stop)
    else if short1_be_active
        strategy.exit("Short1 Exit", "Short1", profit=c1_tp_ticks, stop=short1_entry - c1_be_offset * syminfo.mintick)
    else
        strategy.exit("Short1 Exit", "Short1", profit=c1_tp_ticks, loss=c1_sl_ticks)

// ─────────────────────────────── CONTRACT 2 EXITS ─────────────────────────────
if useSecondContract and long2_open
    if long2_trail_active
        strategy.exit("Long2 Exit", "Long2", profit=c2_tp_ticks, trail_points=c2_trail_trigger, trail_offset=c2_trail_stop)
    else if long2_be_active
        strategy.exit("Long2 Exit", "Long2", profit=c2_tp_ticks, stop=long2_entry + c2_be_offset * syminfo.mintick)
    else
        strategy.exit("Long2 Exit", "Long2", profit=c2_tp_ticks, loss=c2_sl_ticks)

if useSecondContract and short2_open
    if short2_trail_active
        strategy.exit("Short2 Exit", "Short2", profit=c2_tp_ticks, trail_points=c2_trail_trigger, trail_offset=c2_trail_stop)
    else if short2_be_active
        strategy.exit("Short2 Exit", "Short2", profit=c2_tp_ticks, stop=short2_entry - c2_be_offset * syminfo.mintick)
    else
        strategy.exit("Short2 Exit", "Short2", profit=c2_tp_ticks, loss=c2_sl_ticks)

// ─────────────────────────────── SIGNAL-BASED EXITS ───────────────────────────
if strategy.position_size > 0 and longExitSignal
    strategy.close_all("HMA Cross Exit")

if strategy.position_size < 0 and shortExitSignal
    strategy.close_all("HMA Cross Exit")

// ─────────────────────────────── RESET ON CLOSE ───────────────────────────────
if strategy.position_size == 0
    long1_entry := na
    long2_entry := na
    short1_entry := na
    short2_entry := na
    long1_be_active := false
    long2_be_active := false
    short1_be_active := false
    short2_be_active := false
    long1_trail_active := false
    long2_trail_active := false
    short1_trail_active := false
    short2_trail_active := false

// ══════════════════════════════════════════════════════════════════════════════
// ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ PLOTTING ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// ══════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────── Moving Averages ──────────────────────────────
ema9_color       = close > ema9 ? ema9_bull_color : ema9_bear_color
ema20_high_color = close > ema20_high ? river_bull_color : river_bear_color
ema20_hl2_color  = close > ema20_hl2 ? river_bull_color : river_bear_color
ema20_low_color  = close > ema20_low ? river_bull_color : river_bear_color
hma20_color      = close > hma20 ? hma20_bull_color : hma20_bear_color

plot(showEMA9 ? ema9 : na, "9 EMA", color=ema9_color, linewidth=ema9_width, style=ema9_style == "Dashed" ? plot.style_line : ema9_style == "Dotted" ? plot.style_cross : plot.style_line)

plot(showRiver ? ema20_high : na, "20 EMA High", color=ema20_high_color, linewidth=river_high_width, style=river_style == "Dashed" ? plot.style_line : river_style == "Dotted" ? plot.style_cross : plot.style_line)
plot(showRiver ? ema20_hl2 : na, "20 EMA HL2", color=ema20_hl2_color, linewidth=river_hl2_width, style=river_style == "Dashed" ? plot.style_line : river_style == "Dotted" ? plot.style_cross : plot.style_line)
plot(showRiver ? ema20_low : na, "20 EMA Low", color=ema20_low_color, linewidth=river_low_width, style=river_style == "Dashed" ? plot.style_line : river_style == "Dotted" ? plot.style_cross : plot.style_line)

plot(showHMA ? hma20 : na, "20 HMA", color=hma20_color, linewidth=hma20_width, style=hma20_style == "Dashed" ? plot.style_line : hma20_style == "Dotted" ? plot.style_cross : plot.style_line)

// ─────────────────────────────── HMA Exit Ribbon ──────────────────────────────
hmaFast_color = close > hmaFast ? hmaExit_bull_color : hmaExit_bear_color
hmaSlow_color = close > hmaSlow ? hmaExit_bull_color : hmaExit_bear_color
hmaRibbon_color = hmaFast > hmaSlow ? hmaRibbon_bull_color : hmaRibbon_bear_color

p_hmaFast = plot(showHMAExit ? hmaFast : na, "Fast HMA (Exit)", color=hmaFast_color, linewidth=hmaExit_fast_width)
p_hmaSlow = plot(showHMAExit ? hmaSlow : na, "Slow HMA (Exit)", color=hmaSlow_color, linewidth=hmaExit_slow_width)
fill(p_hmaFast, p_hmaSlow, color=showHMAExit ? hmaRibbon_color : na, title="HMA Exit Ribbon")

// ─────────────────────────────── T-Line 1 Channel ─────────────────────────────
tline1_ma_color = close > tline1_ma ? tline1_ma_bull : tline1_ma_bear
tline1_fill_color = insideTLine1 ? tline1_fill_in : tline1_fill_out

plot(showTLine1 ? tline1_ma : na, "T-Line 1 MA", color=tline1_ma_color, linewidth=tline1_ma_width)
p_tline1_upper = plot(showTLine1 ? tline1_upper : na, "T-Line 1 Upper", color=tline1_band_color, linewidth=tline1_band_width)
p_tline1_lower = plot(showTLine1 ? tline1_lower : na, "T-Line 1 Lower", color=tline1_band_color, linewidth=tline1_band_width)
fill(p_tline1_upper, p_tline1_lower, color=showTLine1 ? tline1_fill_color : na, title="T-Line 1 Fill")

// ─────────────────────────────── T-Line 2 Channel ─────────────────────────────
tline2_ma_color = close > tline2_ma ? tline2_ma_bull : tline2_ma_bear
tline2_fill_color = insideTLine2 ? tline2_fill_in : tline2_fill_out

plot(showTLine2 ? tline2_ma : na, "T-Line 2 MA", color=tline2_ma_color, linewidth=tline2_ma_width)
p_tline2_upper = plot(showTLine2 ? tline2_upper : na, "T-Line 2 Upper", color=tline2_band_color, linewidth=tline2_band_width)
p_tline2_lower = plot(showTLine2 ? tline2_lower : na, "T-Line 2 Lower", color=tline2_band_color, linewidth=tline2_band_width)
fill(p_tline2_upper, p_tline2_lower, color=showTLine2 ? tline2_fill_color : na, title="T-Line 2 Fill")

// ─────────────────────────────── Entry Signals ────────────────────────────────
plotshape(showSignals and longSignal, "Long Entry", 
     style=shape.triangleup, location=location.belowbar, 
     color=long_signal_color, size=size.normal, text="L")

plotshape(showSignals and shortSignal, "Short Entry", 
     style=shape.triangledown, location=location.abovebar, 
     color=short_signal_color, size=size.normal, text="S")

// ─────────────────────────────── Background ───────────────────────────────────
ribbon_bg_color = rsi_bullish ? color.new(ribbon_bull_color, ribbon_transparency) : 
     rsi_bearish ? color.new(ribbon_bear_color, ribbon_transparency) : 
     color.new(color.gray, 90)

bgcolor(ribbon_bg_color, title="RSI Momentum Ribbon")
bgcolor(bbChopActive ? color.new(color.gray, 90) : na, title="BB Chop Zone")
bgcolor(not inTradingSession and useSessionFilter ? color.new(color.red, 95) : na, title="No Trade Session")

// ─────────────────────────────── DStoch Signals ───────────────────────────────
plotshape(showDStochSignals and stoch_buy_signal and inTradingSession, "DStoch BUY", 
     shape.labelup, location.belowbar, dstoch_buy_color, 
     size=size.tiny, text="DS▲", textcolor=color.white)

plotshape(showDStochSignals and stoch_sell_signal and inTradingSession, "DStoch SELL", 
     shape.labeldown, location.abovebar, dstoch_sell_color, 
     size=size.tiny, text="DS▼", textcolor=color.white)

// ─────────────────────────────── Alerts ───────────────────────────────────────
alertcondition(longSignal, "Long Entry", "EMA River: Long Entry Signal")
alertcondition(shortSignal, "Short Entry", "EMA River: Short Entry Signal")
alertcondition(longExitSignal and strategy.position_size > 0, "Long Exit", "EMA River: Long Exit - HMA Bearish Cross")
alertcondition(shortExitSignal and strategy.position_size < 0, "Short Exit", "EMA River: Short Exit - HMA Bullish Cross")

// ─────────────────────────────── Debug Table ──────────────────────────────────
var table debugTable = table.new(position.top_right, 2, 16, bgcolor=color.new(color.black, 80), border_width=1)

if showDebug and barstate.islast
    table.cell(debugTable, 0, 0, "Condition", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 0, "Status", text_color=color.white, text_size=size.small)
    
    table.cell(debugTable, 0, 1, "RSI Ribbon", text_color=color.white, text_size=size.small)
    rsi_status = rsi_bullish ? "BULL" : rsi_bearish ? "BEAR" : "NEUTRAL"
    table.cell(debugTable, 1, 1, rsi_status, text_color=rsi_bullish ? color.lime : rsi_bearish ? color.red : color.gray, text_size=size.small)
    
    table.cell(debugTable, 0, 2, "9 EMA", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 2, ema9_bullish ? "BULL" : "BEAR", text_color=ema9_bullish ? color.lime : color.red, text_size=size.small)
    
    table.cell(debugTable, 0, 3, "20 HMA", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 3, hma20_bullish ? "BULL" : "BEAR", text_color=hma20_bullish ? color.lime : color.red, text_size=size.small)
    
    table.cell(debugTable, 0, 4, "20 EMA High", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 4, ema20_high_bullish ? "BULL" : "BEAR", text_color=ema20_high_bullish ? color.lime : color.red, text_size=size.small)
    
    table.cell(debugTable, 0, 5, "20 EMA Low", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 5, ema20_low_bearish ? "BEAR" : "BULL", text_color=ema20_low_bearish ? color.red : color.lime, text_size=size.small)
    
    table.cell(debugTable, 0, 6, "HMA Exit", text_color=color.white, text_size=size.small)
    hma_exit_status = hmaFast > hmaSlow ? "BULL" : "BEAR"
    table.cell(debugTable, 1, 6, hma_exit_status, text_color=hmaFast > hmaSlow ? color.lime : color.red, text_size=size.small)
    
    table.cell(debugTable, 0, 7, "BB Chop", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 7, bbChopActive ? "CHOP" : "OK", text_color=bbChopActive ? color.red : color.lime, text_size=size.small)
    
    table.cell(debugTable, 0, 8, "T-Line 1", text_color=color.white, text_size=size.small)
    tline1_status = insideTLine1 ? "INSIDE" : tline1_cooldownActive ? "COOLDOWN" : not tline1_clearance_met ? "TOO CLOSE" : "OK"
    tline1_col = insideTLine1 ? color.red : tline1_cooldownActive ? color.yellow : not tline1_clearance_met ? color.orange : color.lime
    table.cell(debugTable, 1, 8, tline1_status, text_color=tline1_col, text_size=size.small)
    
    table.cell(debugTable, 0, 9, "T-Line 2", text_color=color.white, text_size=size.small)
    tline2_status = insideTLine2 ? "INSIDE" : tline2_cooldownActive ? "COOLDOWN" : not tline2_clearance_met ? "TOO CLOSE" : "OK"
    tline2_col = insideTLine2 ? color.red : tline2_cooldownActive ? color.yellow : not tline2_clearance_met ? color.orange : color.lime
    table.cell(debugTable, 1, 9, tline2_status, text_color=tline2_col, text_size=size.small)
    
    table.cell(debugTable, 0, 10, "In Session", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 10, inTradingSession ? "YES" : "NO", text_color=inTradingSession ? color.lime : color.red, text_size=size.small)
    
    table.cell(debugTable, 0, 11, "Can Trade", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 11, canTrade ? "YES" : "NO", text_color=canTrade ? color.lime : color.red, text_size=size.small)
    
    table.cell(debugTable, 0, 12, "Position", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 12, str.tostring(strategy.position_size), text_color=color.white, text_size=size.small)
    
    table.cell(debugTable, 0, 13, "Signal", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 13, longSignal ? "LONG" : shortSignal ? "SHORT" : "NONE", text_color=longSignal ? color.lime : shortSignal ? color.red : color.gray, text_size=size.small)
    
    table.cell(debugTable, 0, 14, "DStoch", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 14, str.tostring(db_stoch, "0.0"), text_color=db_stoch > 50 ? color.lime : color.red, text_size=size.small)
