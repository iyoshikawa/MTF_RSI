// EMA River Strategy v1.0.9

//@version=6
strategy("EMA River Strategy v1.0.9", 
     overlay=true, 
     initial_capital=1000000,
     currency=currency.USD,
     default_qty_type=strategy.fixed, 
     default_qty_value=1,
     pyramiding=0,
     calc_on_order_fills=true,
     calc_on_every_tick=false,
     process_orders_on_close=true)

// ══════════════════════════════════════════════════════════════════════════════
// ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ INPUTS ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// ══════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────── Moving Averages ──────────────────────────────
grpMA = "═══ Moving Averages ═══"

ema9_len    = input.int(9, "Fast EMA Length", minval=1, group=grpMA, tooltip="Signal line EMA")
ema9_src    = input.source(ohlc4, "Fast EMA Source", group=grpMA)

ema20_len   = input.int(20, "EMA River Length", minval=1, group=grpMA, tooltip="EMA River (High/HL2/Low)")

hma20_len   = input.int(20, "HMA Length", minval=1, group=grpMA)
hma20_src   = input.source(close, "HMA Source", group=grpMA)

// ─────────────────────────────── Trend Confirmation ───────────────────────────
grpTrend = "═══ Trend Confirmation ═══"

trendLookback = input.int(7, "HA Candle Lookback", minval=1, group=grpTrend, tooltip="Minimum HA candles confirming trend direction")

// ─────────────────────────────── Chop Filter: Bollinger Bands ─────────────────
grpBB = "═══ Chop Filter: Bollinger Bands ═══"

useBBChop       = input.bool(true, "Enable BB Chop Filter", group=grpBB)
bbLength        = input.int(10, "BB Length", minval=1, group=grpBB)
bbStdDev        = input.float(1.2, "BB StdDev", minval=0.1, step=0.1, group=grpBB)
bbTimeframe     = input.timeframe("3", "BB Timeframe", group=grpBB)

// ─────────────────────────────── Chop Filter: T-Line Channel ──────────────────
grpTLine = "═══ Chop Filter: T-Line Channel ═══"

useTLineChop    = input.bool(true, "Enable T-Line Chop Filter", group=grpTLine)
tlineLength     = input.int(55, "T-Line EMA Length", minval=1, group=grpTLine)
tlineWidth      = input.int(34, "T-Line Channel Width (points)", minval=1, group=grpTLine)
tlineCooldownBars = input.int(10, "Cooldown Bars After Exit", minval=1, group=grpTLine, tooltip="Suppress signals for X bars after leaving T-Line chop zone")
tlineCooldownPts  = input.float(20, "Cooldown Distance (points)", minval=1, group=grpTLine, tooltip="OR allow signals if price moves this far from chop zone boundary")

// ─────────────────────────────── Session Filters ──────────────────────────────
grpSession = "═══ Session Filters ═══"

useSessionFilter = input.bool(true, "Enable Session Filter", group=grpSession)
sess_globex      = input.session("1801-2000", "Globex Evening", group=grpSession)
sess_premarket   = input.session("0700-0815", "Pre-Market", group=grpSession)
sess_ny          = input.session("0930-1600", "NY Session", group=grpSession)
sessionTZ        = input.string("America/New_York", "Timezone", group=grpSession)

// ─────────────────────────────── Position Management ──────────────────────────
grpExit = "═══ Position Management ═══"

tpPoints        = input.float(40, "Take Profit (points)", minval=1, group=grpExit)
slPoints        = input.float(40, "Stop Loss (points)", minval=1, group=grpExit)
trailPoints     = input.float(20, "Trail Distance (points)", minval=1, group=grpExit)
beActivation    = input.float(75, "BE Activation (%)", minval=1, maxval=100, group=grpExit, tooltip="Move SL to BE+offset when this % of TP reached")
beOffset        = input.float(3, "BE Offset (points)", minval=0, group=grpExit, tooltip="Points above/below entry for BE stop")

// ─────────────────────────────── Display ──────────────────────────────────────
grpDisplay = "═══ Display ═══"

showEMA9        = input.bool(true, "Show 9 EMA", group=grpDisplay)
showRiver       = input.bool(true, "Show EMA River", group=grpDisplay)
showHMA         = input.bool(true, "Show 20 HMA", group=grpDisplay)
showTLine       = input.bool(true, "Show T-Line Channel", group=grpDisplay)
showSignals     = input.bool(true, "Show Entry Arrows", group=grpDisplay)
showDebug       = input.bool(true, "Show Debug Table", group=grpDisplay)
testMode        = input.bool(false, "⚠️ TEST MODE (bypass all filters)", group=grpDisplay, tooltip="Enable to test if entries work at all - enters on simple EMA cross")

// ─────────────────────────────── Background Shading ───────────────────────────
grpBG = "═══ Background Shading ═══"

showChopBG      = input.bool(true, "Show Chop Zone Background", group=grpBG, tooltip="Gray background when in chop zone")
showSessionBG   = input.bool(true, "Show No-Trade Session Background", group=grpBG, tooltip="Red tint when outside trading session")

// ─────────────────────────────── Double Stochastic ────────────────────────────
grpDStoch = "═══ Double Stochastic ═══"

useDStoch       = input.bool(true, "Enable DStoch Signals", group=grpDStoch)
stochLen        = input.int(10, "DStoch Period", minval=1, group=grpDStoch, tooltip="Lookback period for Double Stochastic")
stochSmth       = input.int(3, "DStoch Smoothing", minval=1, group=grpDStoch, tooltip="Double-EMA smoothing")
stoch_sell_level = input.float(85, "Sell Signal Level", minval=50, maxval=100, group=grpDStoch, tooltip="DStoch crosses DOWN through this = sell signal")
stoch_buy_level  = input.float(12, "Buy Signal Level", minval=0, maxval=50, group=grpDStoch, tooltip="DStoch crosses UP through this = buy signal")

// ─────────────────────────────── RSI Ribbon ───────────────────────────────────
grpRibbon = "═══ RSI Momentum Ribbon ═══"

useRSIRibbon        = input.bool(true, "Enable RSI Ribbon Background", group=grpRibbon)
rsi_short_len       = input.int(5, "Short RSI Period", minval=1, group=grpRibbon)
rsi_long_len        = input.int(13, "Long RSI Period", minval=1, group=grpRibbon)
rsi_short_smooth    = input.int(2, "Short RSI Smoothing", minval=1, group=grpRibbon)
rsi_long_smooth     = input.int(3, "Long RSI Smoothing", minval=1, group=grpRibbon)
rsi_threshold       = input.float(1.0, "RSI Neutral Zone", minval=0.1, step=0.1, group=grpRibbon, tooltip="Min RSI diff to register direction")
ribbon_bull_color   = input.color(#00ffbb, "Ribbon Bullish Color", group=grpRibbon)
ribbon_bear_color   = input.color(#ff0055, "Ribbon Bearish Color", group=grpRibbon)
ribbon_consol_color = input.color(#000000, "Ribbon Consolidation Color", group=grpRibbon)
ribbon_transparency = input.int(85, "Ribbon Transparency", minval=0, maxval=95, step=5, group=grpRibbon)
brighten_on_confluence = input.bool(true, "Brighten When DStoch + RSI Align", group=grpRibbon, tooltip="Reduce transparency by 20 when both agree")

// ─────────────────────────────── Consolidation Filter ─────────────────────────
grpConsol = "═══ Consolidation Detection ═══"

enable_consol_filter = input.bool(false, "Gray Ribbon During Consolidation", group=grpConsol)
consol_range_pts     = input.float(10.0, "Consolidation Range (pts)", minval=1, group=grpConsol, tooltip="If range < this over lookback, price is consolidating")
consol_bars          = input.int(20, "Consolidation Lookback (bars)", minval=5, group=grpConsol)

// ══════════════════════════════════════════════════════════════════════════════
// ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ CALCULATIONS ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// ══════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────── Moving Averages ──────────────────────────────
// 9 EMA on OHLC4
ema9 = ta.ema(ema9_src, ema9_len)

// 20 EMA River (High / HL2 / Low)
ema20_high = ta.ema(high, ema20_len)
ema20_hl2  = ta.ema(hl2, ema20_len)
ema20_low  = ta.ema(low, ema20_len)

// 20 HMA on Close
f_hma(_src, _len) =>
    _halfLen = math.floor(_len / 2)
    _sqrtLen = math.floor(math.sqrt(_len))
    _wma1 = ta.wma(_src, _halfLen)
    _wma2 = ta.wma(_src, _len)
    ta.wma(2 * _wma1 - _wma2, _sqrtLen)

hma20 = f_hma(hma20_src, hma20_len)

// ─────────────────────────────── Double Stochastic ────────────────────────────
f_double_stoch(_len, _smooth) =>
    raw_stoch = ta.stoch(close, high, low, _len)
    ta.ema(ta.ema(raw_stoch, _smooth), _smooth)

db_stoch = f_double_stoch(stochLen, stochSmth)

stoch_momentum_bull = db_stoch > 50
stoch_momentum_bear = db_stoch < 50

stoch_sell_signal = ta.crossunder(db_stoch, stoch_sell_level)
stoch_buy_signal  = ta.crossover(db_stoch, stoch_buy_level)

stoch_signal_dir = stoch_sell_signal ? -1 : stoch_buy_signal ? 1 : 0

// ─────────────────────────────── RSI Momentum ─────────────────────────────────
f_double_rsi(_src, _short_len, _long_len, _short_smooth, _long_smooth) =>
    rsiS = ta.ema(ta.rsi(_src, _short_len), _short_smooth)
    rsiL = ta.ema(ta.rsi(_src, _long_len), _long_smooth)
    rsiS - rsiL

rsi_diff = f_double_rsi(close, rsi_short_len, rsi_long_len, rsi_short_smooth, rsi_long_smooth)
rsi_dir = rsi_diff > rsi_threshold ? 1 : rsi_diff < -rsi_threshold ? -1 : 0

// DStoch + RSI confluence
dstoch_rsi_confluence = (stoch_signal_dir == 1 and rsi_dir == 1) or (stoch_signal_dir == -1 and rsi_dir == -1)

// ─────────────────────────────── Heiken Ashi ──────────────────────────────────
haClose = (open + high + low + close) / 4
var float haOpen = na
haOpen := na(haOpen[1]) ? (open + close) / 2 : (haOpen[1] + haClose[1]) / 2
haHigh = math.max(high, math.max(haOpen, haClose))
haLow  = math.min(low, math.min(haOpen, haClose))

haBullish = haClose > haOpen
haBearish = haClose < haOpen

// ─────────────────────────────── Trend Detection ──────────────────────────────
// Count consecutive HA candles in same direction
var int bullCount = 0
var int bearCount = 0

if haBullish
    bullCount := bullCount + 1
    bearCount := 0
else if haBearish
    bearCount := bearCount + 1
    bullCount := 0
else
    bullCount := 0
    bearCount := 0

// EMA River direction confirmation
riverBullish = ema20_low > ema20_low[1] and ema20_hl2 > ema20_hl2[1]
riverBearish = ema20_high < ema20_high[1] and ema20_hl2 < ema20_hl2[1]

// Combined trend signals
uptrendConfirmed   = bullCount >= trendLookback and riverBullish
downtrendConfirmed = bearCount >= trendLookback and riverBearish

// Track prior trend for flip detection
var int priorTrend = 0  // 1 = up, -1 = down, 0 = neutral
if uptrendConfirmed
    priorTrend := 1
else if downtrendConfirmed
    priorTrend := -1

// ─────────────────────────────── Chop Filter: Bollinger Bands ─────────────────
[bbMiddle, bbUpper, bbLower] = request.security(syminfo.tickerid, bbTimeframe, 
     ta.bb(close, bbLength, bbStdDev), lookahead=barmerge.lookahead_off)

insideBB = close < bbUpper and close > bbLower
bbChopActive = useBBChop and insideBB

// ─────────────────────────────── Chop Filter: T-Line Channel ──────────────────
tlineEMA = ta.ema(close, tlineLength)
tlineUpper = tlineEMA + tlineWidth * syminfo.mintick
tlineLower = tlineEMA - tlineWidth * syminfo.mintick

insideTLine = close < tlineUpper and close > tlineLower
tlineChopActive = useTLineChop and insideTLine

// T-Line cooldown after exiting chop zone
var int barsSinceTLineExit = 999
justExitedTLine = insideTLine[1] and not insideTLine

if insideTLine
    barsSinceTLineExit := 0
else if justExitedTLine
    barsSinceTLineExit := 1
else
    barsSinceTLineExit := barsSinceTLineExit + 1

// Distance from nearest T-Line boundary
distFromTLineUpper = close - tlineUpper
distFromTLineLower = tlineLower - close
distFromTLine = close > tlineUpper ? distFromTLineUpper : (close < tlineLower ? distFromTLineLower : 0)
distFromTLinePts = distFromTLine / syminfo.mintick

// Cooldown active: suppress signals until bars OR distance threshold met
tlineCooldownActive = useTLineChop and (barsSinceTLineExit < tlineCooldownBars) and (distFromTLinePts < tlineCooldownPts)

// Combined chop filter
inChopZone = bbChopActive or tlineChopActive or tlineCooldownActive

// ─────────────────────────────── Session Filter ───────────────────────────────
inGlobex    = not na(time(timeframe.period, sess_globex, sessionTZ))
inPremarket = not na(time(timeframe.period, sess_premarket, sessionTZ))
inNY        = not na(time(timeframe.period, sess_ny, sessionTZ))

inTradingSession = not useSessionFilter or (inGlobex or inPremarket or inNY)

// ─────────────────────────────── Entry Conditions ─────────────────────────────
// Entry Type 1: Continuation
// Long: Uptrend → close between HMA and 9 EMA → break above HMA
// Short: Downtrend → close between HMA and 9 EMA → close below 9 EMA

inPullbackZoneLong  = close > math.min(hma20, ema9) and close < math.max(hma20, ema9)
inPullbackZoneShort = close > math.min(hma20, ema9) and close < math.max(hma20, ema9)

// Track if we were in pullback zone
var bool wasPullbackLong  = false
var bool wasPullbackShort = false

if uptrendConfirmed and inPullbackZoneLong
    wasPullbackLong := true
if downtrendConfirmed and inPullbackZoneShort
    wasPullbackShort := true

// Reset if trend changes
if downtrendConfirmed
    wasPullbackLong := false
if uptrendConfirmed
    wasPullbackShort := false

// Continuation triggers
contLongTrigger  = wasPullbackLong and close > hma20 and close > ema9
contShortTrigger = wasPullbackShort and close < ema9 and close < hma20

// Reset after trigger
if contLongTrigger
    wasPullbackLong := false
if contShortTrigger
    wasPullbackShort := false

// Entry Type 2: Flip (counter-trend reversal)
// Long Flip: Was trending DOWN → closes above BOTH HMA and 9 EMA
// Short Flip: Was trending UP → closes below BOTH HMA and 9 EMA

flipLongTrigger  = priorTrend == -1 and close > hma20 and close > ema9
flipShortTrigger = priorTrend == 1 and close < hma20 and close < ema9

// Bonus: Also outside EMA river
flipLongBonus  = flipLongTrigger and close > ema20_high
flipShortBonus = flipShortTrigger and close < ema20_low

// ─────────────────────────────── Signal Generation ────────────────────────────
canTrade = inTradingSession and not inChopZone and strategy.position_size == 0

longContinuation  = canTrade and contLongTrigger
shortContinuation = canTrade and contShortTrigger
longFlip          = canTrade and flipLongTrigger and not contLongTrigger
shortFlip         = canTrade and flipShortTrigger and not contShortTrigger

longSignal  = longContinuation or longFlip
shortSignal = shortContinuation or shortFlip

// ══════════════════════════════════════════════════════════════════════════════
// ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ POSITION MANAGEMENT ░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// ══════════════════════════════════════════════════════════════════════════════

// Convert points to ticks
tpTicks = tpPoints / syminfo.mintick
slTicks = slPoints / syminfo.mintick
trailTicks = trailPoints / syminfo.mintick

// ─────────────────────────────── TEST MODE ────────────────────────────────────
// Simple EMA cross entries to verify strategy can execute trades
testLong  = testMode and ta.crossover(ema9, hma20) and strategy.position_size == 0
testShort = testMode and ta.crossunder(ema9, hma20) and strategy.position_size == 0

if testLong
    strategy.entry("Test Long", strategy.long)

if testShort
    strategy.entry("Test Short", strategy.short)

// ─────────────────────────────── NORMAL ENTRIES ───────────────────────────────
if not testMode and longSignal
    strategy.entry("Long", strategy.long)

if not testMode and shortSignal
    strategy.entry("Short", strategy.short)

// Exit with simple TP/SL/Trail
strategy.exit("Long Exit", "Long", profit=tpTicks, loss=slTicks, trail_points=tpTicks * 0.5, trail_offset=trailTicks)
strategy.exit("Short Exit", "Short", profit=tpTicks, loss=slTicks, trail_points=tpTicks * 0.5, trail_offset=trailTicks)
strategy.exit("Test Long Exit", "Test Long", profit=tpTicks, loss=slTicks, trail_points=tpTicks * 0.5, trail_offset=trailTicks)
strategy.exit("Test Short Exit", "Test Short", profit=tpTicks, loss=slTicks, trail_points=tpTicks * 0.5, trail_offset=trailTicks)

// Flatten in chop zone (exit existing positions) - disabled in test mode
if not testMode and inChopZone and strategy.position_size != 0
    strategy.close_all("Chop Zone Exit")

// ══════════════════════════════════════════════════════════════════════════════
// ░░░░░░░░░░░░░░░░░░░░░░░░░░░░ PLOTTING ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// ══════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────── Moving Averages ──────────────────────────────
// Dynamic colors based on price position relative to MA
ema9_color      = close > ema9 ? color.lime : color.red
ema20_high_color = close > ema20_high ? color.lime : color.red
ema20_hl2_color  = close > ema20_hl2 ? color.lime : color.red
ema20_low_color  = close > ema20_low ? color.lime : color.red
hma20_color      = close > hma20 ? color.lime : color.red

plot(showEMA9 ? ema9 : na, "9 EMA", color=ema9_color, linewidth=2)

plot(showRiver ? ema20_high : na, "20 EMA High", color=ema20_high_color, linewidth=1)
plot(showRiver ? ema20_hl2 : na, "20 EMA HL2", color=ema20_hl2_color, linewidth=2)
plot(showRiver ? ema20_low : na, "20 EMA Low", color=ema20_low_color, linewidth=1)

plot(showHMA ? hma20 : na, "20 HMA", color=hma20_color, linewidth=2)

// ─────────────────────────────── T-Line Channel ───────────────────────────────
plot(showTLine ? tlineUpper : na, "T-Line Upper", color=color.new(color.purple, 50), linewidth=1)
plot(showTLine ? tlineEMA : na, "T-Line EMA", color=color.purple, linewidth=1)
plot(showTLine ? tlineLower : na, "T-Line Lower", color=color.new(color.purple, 50), linewidth=1)

// ─────────────────────────────── Entry Signals ────────────────────────────────
plotshape(showSignals and longContinuation, "Long Continuation", 
     style=shape.triangleup, location=location.belowbar, 
     color=color.green, size=size.normal, text="LC")

plotshape(showSignals and shortContinuation, "Short Continuation", 
     style=shape.triangledown, location=location.abovebar, 
     color=color.red, size=size.normal, text="SC")

plotshape(showSignals and longFlip, "Long Flip", 
     style=shape.triangleup, location=location.belowbar, 
     color=color.aqua, size=size.normal, text="LF")

plotshape(showSignals and shortFlip, "Short Flip", 
     style=shape.triangledown, location=location.abovebar, 
     color=color.fuchsia, size=size.normal, text="SF")

// ─────────────────────────────── Background ───────────────────────────────────
// Consolidation detection
var int consol_count = 0
var float consol_hi = na
var float consol_lo = na
var int breakout_count = 0

if consol_count == 0 or na(consol_hi)
    consol_hi := high
    consol_lo := low
    consol_count := 1
    breakout_count := 0
else
    new_hi = math.max(consol_hi, high)
    new_lo = math.min(consol_lo, low)
    new_range = new_hi - new_lo
    if new_range >= consol_range_pts
        breakout_count := breakout_count + 1
        if breakout_count >= 4
            consol_hi := high
            consol_lo := low
            consol_count := 1
            breakout_count := 0
        else
            consol_hi := new_hi
            consol_lo := new_lo
            consol_count := consol_count + 1
    else
        breakout_count := 0
        consol_hi := new_hi
        consol_lo := new_lo
        consol_count := consol_count + 1

is_consolidating = enable_consol_filter and consol_count >= consol_bars

// RSI Ribbon background
bg_transparency = (brighten_on_confluence and dstoch_rsi_confluence) ? math.max(0, ribbon_transparency - 20) : ribbon_transparency

ribbon_bg_color = not useRSIRibbon ? na : 
     is_consolidating ? color.new(ribbon_consol_color, 90) : 
     rsi_diff > rsi_threshold ? color.new(ribbon_bull_color, bg_transparency) : 
     rsi_diff < -rsi_threshold ? color.new(ribbon_bear_color, bg_transparency) : 
     color.new(color.gray, 90)

bgcolor(ribbon_bg_color, title="RSI Momentum Ribbon")

// Chop zone background (toggleable)
bgcolor(showChopBG and inChopZone ? color.new(color.gray, 90) : na, title="Chop Zone")

// No-trade session background (toggleable)
bgcolor(showSessionBG and not inTradingSession and useSessionFilter ? color.new(color.red, 95) : na, title="No Trade Session")

// ─────────────────────────────── DStoch Crossover Signals ─────────────────────
plotshape(useDStoch and stoch_buy_signal and inTradingSession, "DStoch BUY", 
     shape.labelup, location.belowbar, color.new(color.aqua, 0), 
     size=size.tiny, text="DS▲", textcolor=color.white)

plotshape(useDStoch and stoch_sell_signal and inTradingSession, "DStoch SELL", 
     shape.labeldown, location.abovebar, color.new(color.fuchsia, 0), 
     size=size.tiny, text="DS▼", textcolor=color.white)

// ─────────────────────────────── Alerts ───────────────────────────────────────
alertcondition(longContinuation, "Long Continuation", "EMA River: Long Continuation Entry")
alertcondition(shortContinuation, "Short Continuation", "EMA River: Short Continuation Entry")
alertcondition(longFlip, "Long Flip", "EMA River: Long Flip Entry")
alertcondition(shortFlip, "Short Flip", "EMA River: Short Flip Entry")
alertcondition(inChopZone and strategy.position_size != 0, "Flatten Warning", "EMA River: In Chop Zone - Consider Flattening")

// ─────────────────────────────── Debug Table ──────────────────────────────────
var table debugTable = table.new(position.top_right, 2, 15, bgcolor=color.new(color.black, 80), border_width=1)

if showDebug and barstate.islast
    table.cell(debugTable, 0, 0, "Condition", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 0, "Status", text_color=color.white, text_size=size.small)
    
    table.cell(debugTable, 0, 1, "In Session", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 1, str.tostring(inTradingSession), text_color=inTradingSession ? color.lime : color.red, text_size=size.small)
    
    table.cell(debugTable, 0, 2, "BB Chop", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 2, str.tostring(bbChopActive), text_color=bbChopActive ? color.red : color.lime, text_size=size.small)
    
    table.cell(debugTable, 0, 3, "T-Line Chop", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 3, str.tostring(tlineChopActive), text_color=tlineChopActive ? color.red : color.lime, text_size=size.small)
    
    table.cell(debugTable, 0, 4, "T-Line Cooldown", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 4, str.tostring(tlineCooldownActive), text_color=tlineCooldownActive ? color.red : color.lime, text_size=size.small)
    
    table.cell(debugTable, 0, 5, "In Chop Zone", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 5, str.tostring(inChopZone), text_color=inChopZone ? color.red : color.lime, text_size=size.small)
    
    table.cell(debugTable, 0, 6, "Position Size", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 6, str.tostring(strategy.position_size), text_color=color.white, text_size=size.small)
    
    table.cell(debugTable, 0, 7, "Can Trade", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 7, str.tostring(canTrade), text_color=canTrade ? color.lime : color.red, text_size=size.small)
    
    table.cell(debugTable, 0, 8, "Bull Count", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 8, str.tostring(bullCount), text_color=color.white, text_size=size.small)
    
    table.cell(debugTable, 0, 9, "Bear Count", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 9, str.tostring(bearCount), text_color=color.white, text_size=size.small)
    
    table.cell(debugTable, 0, 10, "Prior Trend", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 10, str.tostring(priorTrend), text_color=color.white, text_size=size.small)
    
    table.cell(debugTable, 0, 11, "Long/Short Signal", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 11, longSignal ? "LONG" : shortSignal ? "SHORT" : "NONE", text_color=longSignal ? color.lime : shortSignal ? color.red : color.gray, text_size=size.small)
    
    // DStoch info
    dstoch_status = stoch_momentum_bull ? "BULL" : stoch_momentum_bear ? "BEAR" : "NEUTRAL"
    dstoch_col = stoch_momentum_bull ? color.lime : stoch_momentum_bear ? color.red : color.gray
    table.cell(debugTable, 0, 12, "DStoch", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 12, str.tostring(db_stoch, "0.0") + " " + dstoch_status, text_color=dstoch_col, text_size=size.small)
    
    // RSI Ribbon info
    rsi_status = rsi_dir == 1 ? "BULL" : rsi_dir == -1 ? "BEAR" : "NEUTRAL"
    rsi_col = rsi_dir == 1 ? color.lime : rsi_dir == -1 ? color.red : color.gray
    table.cell(debugTable, 0, 13, "RSI Ribbon", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 13, str.tostring(rsi_diff, "0.00") + " " + rsi_status, text_color=rsi_col, text_size=size.small)
    
    // Confluence
    table.cell(debugTable, 0, 14, "DStoch+RSI", text_color=color.white, text_size=size.small)
    table.cell(debugTable, 1, 14, dstoch_rsi_confluence ? "✓ ALIGNED" : "✗ NO", text_color=dstoch_rsi_confluence ? color.lime : color.gray, text_size=size.small)