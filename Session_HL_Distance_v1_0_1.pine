// ============================================================================
// Session H/L Distance Tracker v1.0.1
// Tracks session highest high / lowest low in points.
// Displays distance from H/L to current price in points.
// Compatible with Renko, standard candles, and all chart types.
// Changelog:
//   v1.0.1 — Removed price labels, removed session BG shading,
//             removed session status row from dashboard table.
// ============================================================================
//@version=6
indicator("Session H/L Distance v1.0.1", overlay=true, max_lines_count=10)

// ============================================================================
// INPUTS
// ============================================================================
grp_session = "Session Settings"

session_preset = input.string("NY AM  09:30–12:00",
     title     = "Session Preset",
     options   = ["London  02:00–05:00",
                  "London  03:00–08:30",
                  "NY AM  09:30–12:00",
                  "NY PM  13:30–16:00",
                  "Custom"],
     group     = grp_session,
     tooltip   = "Select a named session window or use Custom to define your own. Times are ET (UTC-5 / UTC-4 in DST).")

custom_session_start = input.string("0930-1200",
     title   = "Custom Session (exchange TZ, HHMM-HHMM)",
     group   = grp_session,
     tooltip = "Only used when Session Preset = Custom. Enter in TradingView session string format, e.g. 0930-1200.")

grp_display = "Display"
show_lines     = input.bool(true,  "Show H/L Lines on Chart",  group=grp_display, tooltip="Extends horizontal lines across the chart for the session high and low.")
show_table     = input.bool(true,  "Show Dashboard Table",     group=grp_display, tooltip="Compact table showing session H/L, range, and distance from current price.")
table_position = input.string("Top Right",
     title   = "Table Position",
     options = ["Top Right", "Top Left", "Bottom Right", "Bottom Left"],
     group   = grp_display)

grp_style = "Style"
color_high    = input.color(color.new(color.lime,  0),  "Session High Color", group=grp_style)
color_low     = input.color(color.new(color.red,   0),  "Session Low Color",  group=grp_style)
color_tbl_bg  = input.color(color.new(color.black, 15), "Table BG",           group=grp_style)
color_tbl_hdr = input.color(color.new(color.gray,  30), "Table Header BG",    group=grp_style)
line_width     = input.int(1, "H/L Line Width", minval=1, maxval=4, group=grp_style)
line_style_sel = input.string("Dashed", "Line Style", options=["Solid","Dashed","Dotted"], group=grp_style)

// ============================================================================
// SESSION STRING RESOLUTION
// ============================================================================
// TradingView session strings use exchange timezone.
// CME futures = America/Chicago (CT). ET = CT+1h.
// London 02:00–05:00 ET = 01:00–04:00 CT
// London 03:00–08:30 ET = 02:00–07:30 CT
// NY AM  09:30–12:00 ET = 08:30–11:00 CT
// NY PM  13:30–16:00 ET = 12:30–15:00 CT

f_session_string() =>
    switch session_preset
        "London  02:00–05:00" => "0100-0400"
        "London  03:00–08:30" => "0200-0730"
        "NY AM  09:30–12:00"  => "0830-1100"
        "NY PM  13:30–16:00"  => "1230-1500"
        => custom_session_start

session_str = f_session_string()

// ============================================================================
// SESSION DETECTION
// ============================================================================
in_session    = not na(time(timeframe.period, session_str))
session_start = in_session and not in_session[1]

// ============================================================================
// SESSION H/L TRACKING
// ============================================================================
var float sess_high      = na
var float sess_low       = na
var int   sess_bar_start = na

if session_start
    sess_high      := high
    sess_low       := low
    sess_bar_start := bar_index

if in_session
    sess_high := math.max(sess_high, high)
    sess_low  := math.min(sess_low,  low)

// ============================================================================
// DISTANCE CALCULATIONS (in points)
// ============================================================================
current_price  = close

dist_from_high = in_session and not na(sess_high) ? sess_high - current_price : na
dist_from_low  = in_session and not na(sess_low)  ? current_price - sess_low  : na
sess_range     = in_session and not na(sess_high) and not na(sess_low) ? sess_high - sess_low : na

// Position within range (0% = at low, 100% = at high)
pct_in_range   = not na(sess_range) and sess_range > 0 ?
     (current_price - sess_low) / sess_range * 100 : na

// ============================================================================
// LINE STYLE HELPER
// ============================================================================
f_line_style() =>
    switch line_style_sel
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

// ============================================================================
// CHART LINES
// ============================================================================
var line line_high = na
var line line_low  = na

if show_lines and in_session and not na(sess_high)
    if not na(line_high)
        line.delete(line_high)
    if not na(line_low)
        line.delete(line_low)

    line_high := line.new(
         x1     = sess_bar_start,
         y1     = sess_high,
         x2     = bar_index + 3,
         y2     = sess_high,
         color  = color_high,
         width  = line_width,
         style  = f_line_style(),
         extend = extend.none)

    line_low := line.new(
         x1     = sess_bar_start,
         y1     = sess_low,
         x2     = bar_index + 3,
         y2     = sess_low,
         color  = color_low,
         width  = line_width,
         style  = f_line_style(),
         extend = extend.none)

// ============================================================================
// DASHBOARD TABLE  (8 rows: header + 7 data rows)
// ============================================================================
f_tbl_pos() =>
    switch table_position
        "Top Left"     => position.top_left
        "Bottom Right" => position.bottom_right
        "Bottom Left"  => position.bottom_left
        => position.top_right

var table tbl = na
if show_table and na(tbl)
    tbl := table.new(f_tbl_pos(), 2, 8,
         border_color = color.new(color.gray, 60),
         border_width = 1,
         frame_color  = color.new(color.gray, 40),
         frame_width  = 1)

if show_table and barstate.islast
    op = 10

    // ── Header (spans both columns) ──────────────────────────
    table.cell(tbl, 0, 0, "SESSION H/L TRACKER",
         text_color  = color.white,
         bgcolor     = color.new(color_tbl_hdr, op),
         text_halign = text.align_left,
         text_size   = size.small)
    table.cell(tbl, 1, 0, session_preset,
         text_color  = color.silver,
         bgcolor     = color.new(color_tbl_hdr, op),
         text_size   = size.small)

    // ── Session High ─────────────────────────────────────────
    table.cell(tbl, 0, 1, "Sess High",
         text_color = color.silver, bgcolor = color.new(color_tbl_bg, op),
         text_halign = text.align_left, text_size = size.small)
    table.cell(tbl, 1, 1, not na(sess_high) ? str.tostring(sess_high, format.mintick) : "—",
         text_color = color_high, bgcolor = color.new(color_tbl_bg, op), text_size = size.small)

    // ── Session Low ──────────────────────────────────────────
    table.cell(tbl, 0, 2, "Sess Low",
         text_color = color.silver, bgcolor = color.new(color_tbl_bg, op),
         text_halign = text.align_left, text_size = size.small)
    table.cell(tbl, 1, 2, not na(sess_low) ? str.tostring(sess_low, format.mintick) : "—",
         text_color = color_low, bgcolor = color.new(color_tbl_bg, op), text_size = size.small)

    // ── Session Range ────────────────────────────────────────
    table.cell(tbl, 0, 3, "Sess Range",
         text_color = color.silver, bgcolor = color.new(color_tbl_bg, op),
         text_halign = text.align_left, text_size = size.small)
    table.cell(tbl, 1, 3, not na(sess_range) ? str.tostring(sess_range, "#.##") + " pts" : "—",
         text_color = color.white, bgcolor = color.new(color_tbl_bg, op), text_size = size.small)

    // ── Current Price ────────────────────────────────────────
    table.cell(tbl, 0, 4, "Price",
         text_color = color.silver, bgcolor = color.new(color_tbl_bg, op),
         text_halign = text.align_left, text_size = size.small)
    table.cell(tbl, 1, 4, str.tostring(current_price, format.mintick),
         text_color = color.white, bgcolor = color.new(color_tbl_bg, op), text_size = size.small)

    // ── Distance from High ───────────────────────────────────
    dist_h_str   = not na(dist_from_high) ? str.tostring(dist_from_high, "#.##") + " pts  ▼H" : "—"
    dist_h_color = not na(dist_from_high) ?
         (dist_from_high <= 0 ? color.lime :
          dist_from_high <= sess_range * 0.1 ? color.yellow : color.orange) : color.gray
    table.cell(tbl, 0, 5, "From High",
         text_color = color.silver, bgcolor = color.new(color_tbl_bg, op),
         text_halign = text.align_left, text_size = size.small)
    table.cell(tbl, 1, 5, dist_h_str,
         text_color = dist_h_color, bgcolor = color.new(color_tbl_bg, op), text_size = size.small)

    // ── Distance from Low ────────────────────────────────────
    dist_l_str   = not na(dist_from_low) ? str.tostring(dist_from_low, "#.##") + " pts  ▲L" : "—"
    dist_l_color = not na(dist_from_low) ?
         (dist_from_low <= 0 ? color.red :
          dist_from_low <= sess_range * 0.1 ? color.yellow : color.aqua) : color.gray
    table.cell(tbl, 0, 6, "From Low",
         text_color = color.silver, bgcolor = color.new(color_tbl_bg, op),
         text_halign = text.align_left, text_size = size.small)
    table.cell(tbl, 1, 6, dist_l_str,
         text_color = dist_l_color, bgcolor = color.new(color_tbl_bg, op), text_size = size.small)

    // ── % Position in Range ──────────────────────────────────
    pct_str   = not na(pct_in_range) ? str.tostring(pct_in_range, "#.#") + "% in rng" : "—"
    pct_color = not na(pct_in_range) ?
         (pct_in_range >= 80 ? color.lime :
          pct_in_range <= 20 ? color.red  :
          pct_in_range >= 50 ? color.teal : color.orange) : color.gray
    table.cell(tbl, 0, 7, "Range %",
         text_color = color.silver, bgcolor = color.new(color_tbl_bg, op),
         text_halign = text.align_left, text_size = size.small)
    table.cell(tbl, 1, 7, pct_str,
         text_color = pct_color, bgcolor = color.new(color_tbl_bg, op), text_size = size.small)

// ============================================================================
// DATA WINDOW PLOTS
// ============================================================================
plot(sess_high,      "Session High",           color=color.new(color_high,       80), display=display.data_window)
plot(sess_low,       "Session Low",            color=color.new(color_low,        80), display=display.data_window)
plot(dist_from_high, "Distance from High (pts)", color=color.new(color.orange,   60), display=display.data_window)
plot(dist_from_low,  "Distance from Low (pts)",  color=color.new(color.aqua,     60), display=display.data_window)
plot(sess_range,     "Session Range (pts)",       color=color.new(color.white,    60), display=display.data_window)
