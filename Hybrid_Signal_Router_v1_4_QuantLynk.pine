//@version=6
strategy("Hybrid Signal Router v1.4 (QuantLynk ATM Multi-Target)",
     overlay=true,
     pyramiding=0,
     default_qty_type=strategy.fixed,
     default_qty_value=2,
     calc_on_every_tick=false,
     use_bar_magnifier=true,
     calc_on_order_fills=true,
     process_orders_on_close=true,
     fill_orders_on_standard_ohlc=true,
     initial_capital=1000000,
     max_labels_count=500)

// ============================================================================
// HYBRID SIGNAL ROUTER v1.4 (QuantLynk ATM Multi-Target)
// ============================================================================
// v1.4 CHANGES:
//   - EMA River Qualifier fully integrated into Slots 7/8 (Vol Ribbon Bull/Bear).
//     Dashboard now shows "~" suffix when EMA qualifier forces slot to neutral.
//   - All tooltips completed for Slots 1–8, plus entry gates (Marker, Qband, Chop).
//   - Consolidated codebase: no dangling variable declarations, all scope clean.
//   - Ready for production push to main branch after final testing.
// ============================================================================
// v1.3 CHANGES:
//   - NEW: EMA River Qualifier for Vol Ribbon slots (7/8).
//     Computes 20 EMA High, 20 EMA Low, and 34 EMA internally.
//     Vol Ribbon Bull (Slot 7) bullish state only counts when
//     close > EMA(high, 20) AND close > EMA(ohlc4, 34).
//     Vol Ribbon Bear (Slot 8) bearish state only counts when
//     close < EMA(low, 20) AND close < EMA(ohlc4, 34).
//     When EMA position disagrees, slot raw state forced to 0 —
//     scoring, required, extend, AND veto all cascade correctly.
//   - New input group: "04i-b) EMA River Qualifier" with toggle,
//     configurable lengths (20/34), 34 EMA source, and optional
//     EMA river plot overlay.
//   - Dashboard: Slot 7/8 rows show "~" suffix when EMA qualifier
//     overrides the raw Vol Ribbon state to neutral.
// ============================================================================
// Signal Detection + Pine Script Entry/Exit + QuantLynk Integration
//
// Architecture:
// 1. VOL PEAK/BOTTOM fires → marker memory captures event
// 2. Qband side validation (correct side of centerline)
// 3. Chop/Neutral gate (Internal OR External)
// 4. Scoring engine (8 slots with weights, required, veto)
// 5. Session filter
// 6. Entry signal → strategy.entry() + QuantLynk JSON alert
// 7. Exit engine: trailing stops, static TP/SL, session flatten
// 8. QuantLynk OSO brackets available as alternative execution
//
// Configuration (YM):
// Entry: 2 contracts (1 lot × 2)
// Target 1: 50pt TP, 40pt SL | Label: YM Con 1
// Target 2: 125pt TP, 40pt SL | Label: YM Con 2 (auto-trail enabled)
// Auto Breakeven: 30pt trigger, +10pt offset
// Auto Trail (T2): 1-Step, 20pt distance, 30pt profit trigger
//
// Pine execution handles backtesting & live trading
// QuantLynk integration available for webhook-driven execution
// ============================================================================


// ============================================================================
// 01) ENTRY CONTROL
// ============================================================================
gEntry = "01) Entry Control"

allow_longs = input.bool(true, "Allow Longs", group=gEntry,
     tooltip="Enable long entries. OFF blocks all long trades.")
allow_shorts = input.bool(true, "Allow Shorts", group=gEntry,
     tooltip="Enable short entries. OFF blocks all short trades.")
flip_on_opposite = input.bool(true, "Flip On Opposite Signal", group=gEntry,
     tooltip="If long signal fires while short is open, close short first then open long.")
allow_reentry_same_bar = input.bool(false, "Allow Re-Entry Same Bar", group=gEntry,
     tooltip="OFF means opposite signal closes first, new entry waits for next bar.")


// ============================================================================
// 02) MARKER GATE (VOL PEAK / VOL BOTTOM)
// ============================================================================
gMarker = "02) Marker Gate"

// Marker Sources
peak_src = input.source(close, "VOL PEAK Source", group=gMarker,
     tooltip="Source for bearish exhaustion marker (VOL PEAK). Typically from Q_Pilot Volume Peak indicator.")
peak_mode = input.string("Rise > 0", "VOL PEAK Event Mode",
     options=["Rise > 0", "Change", "Appear (NA→value)", "Fall < 0", "Any Activity"],
     group=gMarker,
     tooltip="Rise > 0: Source increases (from negative/zero to positive). Change: Source value changes. Appear: Source transitions from NA to a value. Fall < 0: Source decreases below zero. Any Activity: Source changes in any direction.")
peak_threshold = input.float(0.5, "VOL PEAK Threshold", step=0.1, group=gMarker,
     tooltip="Sensitivity threshold. Larger values = harder to trigger, fewer false signals.")

bottom_src = input.source(close, "VOL BOTTOM Source", group=gMarker,
     tooltip="Source for bullish exhaustion marker (VOL BOTTOM). Typically from Q_Pilot Volume Bottom indicator.")
bottom_mode = input.string("Rise > 0", "VOL BOTTOM Event Mode",
     options=["Rise > 0", "Change", "Appear (NA→value)", "Fall < 0", "Any Activity"],
     group=gMarker,
     tooltip="Same modes as VOL PEAK: Rise > 0, Change, Appear, Fall < 0, Any Activity.")
bottom_threshold = input.float(0.5, "VOL BOTTOM Threshold", step=0.1, group=gMarker,
     tooltip="Sensitivity threshold. Larger values = harder to trigger, fewer false signals.")

// Marker Gate Settings
marker_hold_bars = input.int(3, "Marker Hold Bars", minval=1, maxval=20, group=gMarker,
     tooltip="Hold window includes marker bar. 3 = marker bar + 2 follow-up bars.")
marker_extend_bars = input.int(0, "Extend Trigger Window (bars)", minval=0, maxval=10, group=gMarker,
     tooltip="Keep trigger window active for N extra bars after hold window closes.")
require_marker_gate = input.bool(true, "Require Marker Gate For Entry", group=gMarker,
     tooltip="OFF = entries can fire without a marker (scoring only mode).")

// Qband / Cloud Sources
gQband = "02b) Qband / Cloud"
qband_upper_src = input.source(close, "Qband Upper Source (Cloud Top)", group=gQband,
     tooltip="Upper boundary of Qband cloud. Typically Q_Range upper band or Ichimoku Senkou A/B max.")
qband_center_src = input.source(close, "Qband Centerline Source", group=gQband,
     tooltip="Center/midline of Qband. Used to validate PEAK above / BOTTOM below requirement.")
qband_lower_src = input.source(close, "Qband Lower Source (Cloud Bottom)", group=gQband,
     tooltip="Lower boundary of Qband cloud. Typically Q_Range lower band or Ichimoku Senkou A/B min.")
require_correct_side = input.bool(true, "Require Correct Side Of Centerline", group=gQband,
     tooltip="VOL PEAK must be above centerline, VOL BOTTOM below. Prevents entries against trend.")
require_outer_band = input.bool(false, "Require Marker Near Outer Band", group=gQband,
     tooltip="ON: Marker must be in outer third (distance from center ≥ min_outer_fraction × band_width).")
min_outer_fraction = input.float(0.35, "Min Outer Fraction", minval=0.0, maxval=1.0, step=0.05, group=gQband,
     tooltip="0.35 = marker must be 35% of the way from centerline to outer edge to qualify as 'near outer band'.")
min_qband_width = input.float(0.0, "Min Qband Width", minval=0.0, step=0.25, group=gQband,
     tooltip="Minimum Qband width (upper - lower). 0.0 = no width requirement. Higher = wider cloud needed.")

// Minimal Gate Mode
enable_minimal_gate = input.bool(true, "Enable Minimal Gate Mode", group=gQband,
     tooltip="When all scoring slots are OFF, allow entry on exhaustion + Qband side alone.")


// ============================================================================
// 03) CHOP / NEUTRAL GATE
// ============================================================================
gChopMain = "03) Chop / Neutral Gate"

chop_gate_mode = input.string("Internal", "Chop Gate Mode",
     options=["Internal", "External", "Disabled"],
     group=gChopMain,
     tooltip="Internal: Detects chop via scoring conflicts (bull_votes vs bear_votes ≥ threshold). External: Uses external source (ribbon). Disabled: No chop filtering.")

// Internal Chop Settings
gChopInternal = "03a) Internal Chop Detection"
chop_max_abs_score = input.float(1.75, "Max Abs Score For Chop", minval=0.0, step=0.25, group=gChopInternal,
     tooltip="If |total_score| ≤ this AND opposing votes exist → chop lockout.")
chop_min_opposing_votes = input.int(1, "Min Opposing Votes For Chop", minval=1, maxval=8, group=gChopInternal,
     tooltip="Both bull and bear must have at least this many votes to trigger chop.")

// External Neutral Settings
gChopExternal = "03b) External Neutral Source"
neutral_src = input.source(close, "Neutral Source (e.g. Ribbon)", group=gChopExternal,
     tooltip="External source that indicates neutral/chop condition.")
neutral_active_mode = input.string("Source = 0", "Neutral Active When",
     options=["Source = 0", "Source ≤ 0", "Source < 0", "Source > 0", "NA or 0"],
     group=gChopExternal,
     tooltip="Source = 0: Exact zero. Source ≤ 0: Zero or below. Source < 0: Strictly negative. Source > 0: Strictly positive. NA or 0: Missing or zero.")
neutral_latch = input.bool(false, "Latch Until Fresh Marker", group=gChopExternal,
     tooltip="When neutral fires, stay locked until a new VOL PEAK/BOTTOM fires.")


// ============================================================================
// 04) SCORING ENGINE (8 SLOTS)
// ============================================================================

// --- Helper Functions ---
f_state(_src, _mode, _bull, _bear, _mid, _invert) =>
    float prev = nz(_src[1], _src)
    int raw = switch _mode
        "binary" => _src >= 1 ? 1 : _src <= -1 ? -1 : 0
        "sign" => _src > _bull ? 1 : _src < _bear ? -1 : 0
        "midline" => _src > _mid ? 1 : _src < _mid ? -1 : 0
        "cross" => ta.crossover(_src, _mid) ? 1 : ta.crossunder(_src, _mid) ? -1 : 0
        "risingfalling" => _src > prev ? 1 : _src < prev ? -1 : 0
        => 0
    _invert ? raw * -1 : raw

f_score(_enabled, _state, _weight) =>
    _enabled ? _state * _weight : 0.0

f_event(_src, _mode, _th) =>
    bool pulse_up = _src > _th and nz(_src[1]) <= _th
    bool non_na = not na(_src) and na(_src[1])
    bool value_change = not na(_src) and _src != nz(_src[1])
    bool fall_neg = _src < 0 and nz(_src[1]) >= 0
    bool ev = switch _mode
        "Rise > 0" => pulse_up
        "Change" => value_change
        "Appear (NA→value)" => non_na
        "Fall < 0" => fall_neg
        "Any Activity" => pulse_up or non_na or value_change
        => false
    ev

// --- SLOT 1: RSI ---
gS1 = "04a) Slot 1 - RSI"
s1_enabled = input.bool(true, "Use Slot 1", group=gS1,
     tooltip="Enable/disable this slot in scoring. OFF slots contribute 0 to score.")
s1_name = input.string("RSI", "Slot 1 Name", group=gS1,
     tooltip="Display name on dashboard.")
s1_src = input.source(close, "Slot 1 Source", group=gS1,
     tooltip="Indicator source (RSI, MACD, custom oscillator, etc.). Evaluate using selected mode.")
s1_mode = input.string("binary", "Slot 1 Mode", options=["binary", "sign", "midline", "cross", "risingfalling"], group=gS1,
     tooltip="binary: > bull_th = bull, < bear_th = bear. sign: pos = bull, neg = bear. midline: > mid = bull, < mid = bear. cross: crosses midline. risingfalling: rising = bull, falling = bear.")
s1_bull = input.float(0.5, "Slot 1 Bull Threshold", step=0.1, group=gS1,
     tooltip="Value above which source is bullish (binary/midline modes).")
s1_bear = input.float(-0.5, "Slot 1 Bear Threshold", step=0.1, group=gS1,
     tooltip="Value below which source is bearish (binary/midline modes).")
s1_mid = input.float(0.0, "Slot 1 Midline", step=0.1, group=gS1,
     tooltip="Centerline for midline/cross/risingfalling modes. Source > mid = bull, < mid = bear.")
s1_invert = input.bool(false, "Invert Slot 1", group=gS1,
     tooltip="ON: Flip signal polarity. Bull becomes bear, vice versa.")
s1_weight = input.float(1.50, "Slot 1 Weight", step=0.25, group=gS1,
     tooltip="Importance multiplier. Higher = more impact on score. Bull adds +weight, bear subtracts -weight.")
s1_req_l = input.bool(true, "Required For Long", group=gS1,
     tooltip="ON: Long entries blocked unless this slot is bullish (or disabled).")
s1_req_s = input.bool(true, "Required For Short", group=gS1,
     tooltip="ON: Short entries blocked unless this slot is bearish (or disabled).")
s1_veto_l = input.bool(false, "Veto Long When Bearish", group=gS1,
     tooltip="ON: Block long entries if this slot is bearish, regardless of other votes.")
s1_veto_s = input.bool(false, "Veto Short When Bullish", group=gS1,
     tooltip="ON: Block short entries if this slot is bullish, regardless of other votes.")
s1_extend = input.int(0, "Extend Bars", minval=0, maxval=10, group=gS1,
     tooltip="Keep slot signal active for N extra bars after it would normally flip.")

