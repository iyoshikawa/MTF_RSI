s7_src = input.source(close, "Slot 7 Source", group=gS7,
     tooltip="Q_Pilot Volume Ribbon Bull source. When EMA River Qualifier is ON, bullish state only counts when price is above 20 EMA High AND 34 EMA.")
s7_mode = input.string("binary", "Slot 7 Mode", options=["binary", "sign", "midline", "cross", "risingfalling"], group=gS7,
     tooltip="binary: > bull_th = bull, < bear_th = bear. sign: pos = bull, neg = bear. midline: > mid = bull, < mid = bear. cross: crosses midline. risingfalling: rising = bull, falling = bear.")
s7_bull = input.float(0.5, "Slot 7 Bull Threshold", step=0.1, group=gS7,
     tooltip="Value above which source is bullish (binary/midline modes).")
s7_bear = input.float(-0.5, "Slot 7 Bear Threshold", step=0.1, group=gS7,
     tooltip="Value below which source is bearish (binary/midline modes).")
s7_mid = input.float(0.0, "Slot 7 Midline", step=0.1, group=gS7,
     tooltip="Centerline for midline/cross/risingfalling modes. Source > mid = bull, < mid = bear.")
s7_invert = input.bool(false, "Invert Slot 7", group=gS7,
     tooltip="ON: Flip signal polarity. Bull becomes bear, vice versa.")
s7_weight = input.float(1.25, "Slot 7 Weight", step=0.25, group=gS7,
     tooltip="Importance multiplier. Higher = more impact on score. Bull adds +weight, bear subtracts -weight.")
