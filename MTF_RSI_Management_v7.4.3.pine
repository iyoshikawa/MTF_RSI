//@version=5
indicator("MTF RSI Management [v7.4.3]", overlay=true, max_labels_count=500)

// Clean ticker for request.security (avoids session/extended hours issues)
cleanTicker = ticker.new(syminfo.prefix, syminfo.ticker)

// ==========================================
// --- SHARED SETTINGS (must match Signals indicator) ---
// ==========================================
grp_preset = "⚡ Quick Instrument Presets"
instrument_preset = input.string("DEFAULT", "Instrument", options=["DEFAULT", "🛢️ CL (Crude Oil)", "📈 NQ/MNQ (NASDAQ)", "📊 ES/MES (S&P 500)", "🔷 YM/MYM (Dow)"], group=grp_preset, tooltip="Select your instrument. Must match Signals indicator.")

use_cl_preset = instrument_preset == "🛢️ CL (Crude Oil)"
use_nq_preset = instrument_preset == "📈 NQ/MNQ (NASDAQ)"
use_es_preset = instrument_preset == "📊 ES/MES (S&P 500)"
use_ym_preset = instrument_preset == "🔷 YM/MYM (Dow)"

grp_core = "Core Settings (match Signals)"
ema_length_in = input.int(34, "EMA Length", group=grp_core, tooltip="Primary EMA for trend direction. Must match Signals indicator. Overridden by instrument preset.")
rsi_speed = input.string("Standard", "RSI Speed", options=["Standard", "Fast", "Ultra-Fast"], group=grp_core, tooltip="Must match Signals indicator setting.\n\nStandard (5/13, smooth 2/3, zone 1.0): Balanced defaults.\nFast (4/10, smooth 1/2, zone 0.75): ~2-3 bars earlier reversals.\nUltra-Fast (3/8, smooth 1/1, zone 0.5, hlc3): Earliest signals — enable consolidation filter for chop.")
shortLen    = input.int(5, "Short RSI Period", group=grp_core, tooltip="Lookback for the fast RSI. Lower = more responsive but noisier. Range: 3-7. Overridden by RSI Speed preset.")
longLen     = input.int(13, "Long RSI Period", group=grp_core, tooltip="Lookback for the slow RSI anchor. Keep at least 2x Short RSI Period. Range: 8-21. Overridden by RSI Speed preset.")
shortSmooth = input.int(2, "Short Smoothing", group=grp_core, tooltip="EMA smoothing on Short RSI. 1 = no smoothing. Range: 1-5. Overridden by RSI Speed preset.")
longSmooth  = input.int(3, "Long Smoothing", group=grp_core, tooltip="EMA smoothing on Long RSI. 1 = no smoothing. Range: 1-5. Overridden by RSI Speed preset.")
threshold   = input.float(1.0, "RSI Neutral Zone", group=grp_core, tooltip="Min RSI diff to register direction. Lower = more sensitive. Range: 0.3-2.0. Overridden by RSI Speed preset.")
stochLen  = input.int(10, "Stoch Period", group=grp_core, tooltip="Double Stochastic lookback. Must match Signals indicator.")
stochSmth = input.int(3, "Stoch Smoothing", group=grp_core, tooltip="Double-EMA smoothing on stochastic. Must match Signals.")
adx_length = input.int(14, "ADX Length", group=grp_core, tooltip="ADX lookback period. Must match Signals.")
use_adx = input.bool(true, "Enable ADX Filter", group=grp_core, tooltip="Require ADX above threshold for A+/A grades. Must match Signals.")
adx_threshold_a_plus_in = input.float(25, "ADX Threshold A+", group=grp_core, tooltip="Min ADX for A+ grade. Overridden by instrument preset. Must match Signals.")
adx_threshold_a_in = input.float(20, "ADX Threshold A", group=grp_core, tooltip="Min ADX for A grade. Overridden by instrument preset. Must match Signals.")
adx_floor_bb = input.float(15.0, "ADX Floor B/B+", group=grp_core, tooltip="Min ADX for B/B+ grades. 0 = disabled. Must match Signals.")
vol_ma_len = input.int(20, "Volume MA Length", group=grp_core, tooltip="SMA period for volume baseline. Must match Signals.")
vol_mult_in   = input.float(1.1, "Volume Multiplier", group=grp_core, tooltip="Volume must be this × MA to qualify for A+. Overridden by instrument preset. Must match Signals.")
use_vol_filter = input.bool(true, "Enable Volume Filter", group=grp_core, tooltip="Require above-average volume for A+ grade. Must match Signals.")
suppress_low_vol_bb = input.bool(false, "Suppress B/B+ LOW Vol", group=grp_core, tooltip="Block B/B+ in low volume. Auto-enabled for CL. Must match Signals.")
macro_trend_filter = input.bool(true, "Block Counter-Trend B/B+/A-", group=grp_core, tooltip="Prevent weaker grades from firing against the 233 EMA trend. Must match Signals.")
require_ribbon_bb = input.bool(false, "Require RSI Ribbon B/B+", group=grp_core, tooltip="B/B+ only fire when RSI ribbon is active. Must match Signals.")
cooldown_bars = input.int(5, "Signal Cooldown (bars)", group=grp_core, minval=1, maxval=30, tooltip="Bars to wait between signals. Must match Signals.")
persist_bars = input.int(2, "Grade Persistence (bars)", group=grp_core, minval=1, maxval=5, tooltip="Hold grade for this many bars minimum. Must match Signals.")

// Management-specific settings
grp_emas = "Additional EMAs"
show_ema_21 = input.bool(false, "Show 21 EMA", group=grp_emas, tooltip="Plots the 21-period EMA. Fast-moving average useful for scalp entries and runner trail reference.")
show_ema_50 = input.bool(false, "Show 50 EMA", group=grp_emas, tooltip="Plots the 50-period EMA. Intermediate trend reference — often acts as dynamic support/resistance.")
show_ema_233 = input.bool(false, "Show 233 EMA", group=grp_emas, tooltip="Plots the 233-period EMA. Macro trend direction — the macro trend filter uses this to block counter-trend B/B+/A- signals.")

grp_adx_adv = "📊 ADX Advanced"
enable_adx_adv = input.bool(false, "Enable ADX Advanced Features", group=grp_adx_adv, tooltip="Master toggle for all ADX Advanced features below. When off, none of the advanced ADX features apply.")
adx_sizing_mode = input.bool(false, "Dynamic Sizing by ADX", group=grp_adx_adv, tooltip="Adjusts suggested position size based on ADX strength. Higher ADX = larger size, lower ADX = smaller. Shown in the sizing dashboard.")
adx_runner_gate = input.float(20.0, "Runner ADX Gate", group=grp_adx_adv, minval=0, tooltip="ADX must be above this to show the runner trail stop. Prevents trailing in weak trends. 0 = always show runner.")
adx_pyramid_rising = input.bool(true, "Pyramid Only When ADX Rising", group=grp_adx_adv, tooltip="Only allow pyramid adds when ADX is increasing (trend strengthening). Prevents adding into a weakening trend.")
adx_breakout_detect = input.bool(true, "Show Breakout Detection", group=grp_adx_adv, tooltip="Plots a BRK marker when ADX surges from low to high range, signaling a breakout from consolidation.")
adx_breakout_low = input.float(12.0, "Breakout: ADX Low", group=grp_adx_adv, tooltip="ADX must have been below this recently to qualify as a breakout. Lower = stricter (requires deeper consolidation).")
adx_breakout_high = input.float(20.0, "Breakout: ADX High", group=grp_adx_adv, tooltip="ADX must cross above this to confirm the breakout. The jump from Low to High signals a new trend emerging.")


grp_adr = "📏 ADR (Average Daily Range)"
show_adr_dash = input.bool(false, "Show ADR on Dashboard", group=grp_adr, tooltip="Displays average daily range and remaining range on the management dashboard. Helps gauge how much move is left in the day.")
adr_length = input.int(10, "ADR Lookback (days)", group=grp_adr, minval=1, maxval=50, tooltip="Number of trading days to average for the daily range. 10 = ~2 weeks. Lower = more responsive to recent volatility.")

grp_levels = "📊 Globex Levels"
show_globex_hl = input.bool(false, "Show Previous 2 Globex High/Low", group=grp_levels, tooltip="Plots the high and low of the previous two Globex (overnight) sessions as horizontal levels. Key support/resistance for the RTH session.")
show_globex_poc = input.bool(false, "Show Previous Globex POC", group=grp_levels, tooltip="Plots the Point of Control (price with most volume) from the prior Globex session. Acts as a magnet/pivot for price.")
globex_hl_color_1 = input.color(color.new(#FF9800, 30), "Day -1 H/L Color", group=grp_levels, inline="c1", tooltip="Color for the most recent Globex session's high/low lines.")
globex_hl_color_2 = input.color(color.new(#FF9800, 60), "Day -2 H/L Color", group=grp_levels, inline="c1", tooltip="Color for the second prior Globex session's high/low lines. Fainter by default.")
globex_poc_color = input.color(color.new(#E040FB, 30), "POC Color", group=grp_levels, inline="c2", tooltip="Color for the Globex POC level line.")
globex_line_style = input.string("Dashed", "Line Style", options=["Solid", "Dashed", "Dotted"], group=grp_levels, tooltip="Visual style for all Globex level lines.")

grp_time = "⏰ Time & Session (match Signals)"
sessionConfig = input.string("0930-1145,1330-1600:23456", "Session Config", group=grp_time, tooltip="Must match the Signals indicator session config exactly.")

grp_mgmt = "Dashboard & Management"
showContextPanel = input.bool(true, "Show Trade Context Panel", group=grp_mgmt, tooltip="Shows a panel with current grade, direction, MTF alignment, ADX, stochastic, and key context for trade decisions.")
showSizingDash = input.bool(false, "Show Volatility/Sizing Dashboard", group=grp_mgmt, tooltip="Displays ATR, suggested position size based on max pain, stop distances, and TP levels. Essential for risk management.")
showATRStops = input.bool(false, "Show ATR Stop Reference (A grades)", group=grp_mgmt, tooltip="Plots ATR-based stop-loss reference marks (orange crosses) below/above price for A-grade signals. Distance = ATR × 1.5.")
showATRTP = input.bool(false, "Show ATR Take Profit (A grades)", group=grp_mgmt, tooltip="Plots ATR-based TP markers for A+, A, and A- grades. Adapts to daily volatility — wider targets on big days, tighter on slow days. B/B+ keep fixed-point TPs.")
atr_tp_mult = input.float(2.0, "ATR TP Multiplier", group=grp_mgmt, minval=0.5, maxval=5.0, step=0.5, tooltip="TP distance = ATR × this multiplier. 1.5 = conservative, 2.0 = moderate, 2.5 = aggressive.")
atr_period = input.int(14, "ATR Period", group=grp_mgmt, tooltip="Lookback for Average True Range. Used for stop distances, TP calculations, and position sizing. Standard: 14.")
max_pain_dollars = input.float(400.0, "Max Pain ($)", group=grp_mgmt, tooltip="Maximum dollar amount you're willing to lose per trade. The sizing dashboard divides this by stop distance to suggest contract count.")
max_contracts = input.int(10, "Max Contracts Cap", group=grp_mgmt, minval=1, maxval=50, tooltip="Hard cap on suggested contract count. Prevents unrealistic sizing on micro contracts. Set to your broker's max or your comfort level.")
dollar_per_point_in = input.float(5.0, "$ Per Point Per Contract", group=grp_mgmt, tooltip="Dollar value of 1 point move per contract. ES/MES=5/0.50, NQ/MNQ=20/2, CL=10, YM/MYM=5/0.50. Preset auto-sets to MYM ($0.50) — change to $5.00 for full YM. Overridden by instrument preset.")
sizing_dash_pos = input.string("Bottom Right", "Sizing Dashboard Position", options=["Top Right", "Bottom Right", "Top Left", "Bottom Left"], group=grp_mgmt, tooltip="Corner of the chart where the volatility/sizing dashboard is placed.")

grp_runner = "🏃 Runner Trail Stop"
showRunnerTrail = input.bool(false, "Show Runner Trail Stop", group=grp_runner, tooltip="Plots a trailing stop line based on the selected EMA. Use for managing a 'runner' position — exit when price closes below/above the trail.")
runner_ema_source = input.string("34 EMA", "Trail Source", options=["34 EMA", "21 HMA", "21 EMA"], group=grp_runner, tooltip="Which moving average to use as the runner trail. 34 EMA = wider (more room), 21 HMA = faster/smoother, 21 EMA = tightest trail.")

grp_pyramid = "📈 Pyramid Adds"
enablePyramid = input.bool(false, "Enable Pyramid Add Signals", group=grp_pyramid, tooltip="Plots add-on entry arrows when price bounces off the trail EMA during an active grade. Uses the same EMA selected in Runner Trail Source.")
max_adds = input.int(2, "Max Adds Per Trend", group=grp_pyramid, minval=1, maxval=5, tooltip="Maximum pyramid adds per trend direction. Resets on direction change. 2 = conservative, 4+ = aggressive.")
pyramid_trail_source = input.string("Runner Trail", "Pyramid EMA Source", options=["Runner Trail", "34 EMA", "Dual Confirm"], group=grp_pyramid, tooltip="Runner Trail: Syncs to your Runner Trail Stop EMA.\n34 EMA: Always uses 34 EMA.\nDual Confirm: Uses Runner Trail EMA for pullback + requires a custom HMA to confirm trend direction. Highest quality adds.")
dual_hma_len = input.int(21, "Dual Confirm HMA Length", group=grp_pyramid, minval=5, maxval=100, tooltip="HMA length for dual confirmation. Must confirm trend direction before an add triggers. 21 = responsive, 34 = smoother, 50 = conservative.")
ema_pullback_pct = input.float(0.15, "Pullback Zone (%)", group=grp_pyramid, minval=0.01, maxval=1.0, step=0.05, tooltip="How close price must get to the trail EMA (as % of price) to qualify as a pullback. 0.10% = tight, 0.20% = moderate, 0.30% = generous. Default 0.15%.")
require_bounce = input.bool(true, "Require Bounce Confirmation", group=grp_pyramid, tooltip="When on, price must touch the pullback zone AND the next bar must close back in the trend direction. Prevents triggering on a bar that slices through the EMA.")

// ==========================================
// --- PRESET OVERRIDES ---
// ==========================================
ema_length = use_cl_preset ? 21 : use_ym_preset ? 34 : use_nq_preset ? 34 : ema_length_in
stoch_ob = use_cl_preset ? 72.0 : use_ym_preset ? 62.0 : use_nq_preset ? 65.0 : 60.0
stoch_os = use_cl_preset ? 30.0 : use_ym_preset ? 38.0 : use_nq_preset ? 35.0 : 35.0
vol_mult = use_cl_preset ? 1.4 : use_ym_preset ? 1.2 : use_nq_preset ? 1.2 : vol_mult_in
adx_threshold_a_plus = use_cl_preset ? 28.0 : use_ym_preset ? 23.0 : use_nq_preset ? 23.0 : adx_threshold_a_plus_in
adx_threshold_a = use_cl_preset ? 22.0 : use_ym_preset ? 18.0 : use_nq_preset ? 18.0 : adx_threshold_a_in
dollar_per_point = use_cl_preset ? 10.0 : use_ym_preset ? 0.50 : use_nq_preset ? 2.0 : use_es_preset ? 5.0 : dollar_per_point_in
use_low_vol_suppress = use_cl_preset ? true : suppress_low_vol_bb

// RSI Speed overrides
rsi_short_len = rsi_speed == "Ultra-Fast" ? 3 : rsi_speed == "Fast" ? 4 : shortLen
rsi_long_len  = rsi_speed == "Ultra-Fast" ? 8 : rsi_speed == "Fast" ? 10 : longLen
rsi_short_sm  = rsi_speed == "Ultra-Fast" ? 1 : rsi_speed == "Fast" ? 1 : shortSmooth
rsi_long_sm   = rsi_speed == "Ultra-Fast" ? 1 : rsi_speed == "Fast" ? 2 : longSmooth
rsi_thresh    = rsi_speed == "Ultra-Fast" ? 0.5 : rsi_speed == "Fast" ? 0.75 : threshold
rsi_src       = rsi_speed == "Ultra-Fast" ? hlc3 : close

// ==========================================
// --- SESSION PARSING ---
// ==========================================
config_parts = str.split(sessionConfig, ":")
times_str = array.get(config_parts, 0)
days_str = array.size(config_parts) > 1 ? array.get(config_parts, 1) : "23456"
time_windows = str.split(times_str, ",")
num_windows = array.size(time_windows)
day_suffix = ":" + days_str
in_w1 = num_windows >= 1 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 0)) + day_suffix, "America/New_York")) : false
in_w2 = num_windows >= 2 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 1)) + day_suffix, "America/New_York")) : false
in_w3 = num_windows >= 3 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 2)) + day_suffix, "America/New_York")) : false
in_w4 = num_windows >= 4 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 3)) + day_suffix, "America/New_York")) : false
in_w5 = num_windows >= 5 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 4)) + day_suffix, "America/New_York")) : false
in_w6 = num_windows >= 6 ? not na(time(timeframe.period, str.trim(array.get(time_windows, 5)) + day_suffix, "America/New_York")) : false
inSession_multi = in_w1 or in_w2 or in_w3 or in_w4 or in_w5 or in_w6
inSession_cl = not na(time(timeframe.period, "0900-1430:23456", "America/New_York"))
inSession = use_cl_preset ? inSession_cl : inSession_multi
tradeAllowed = inSession

// ==========================================
// --- RECALCULATE GRADE (must match Signals) ---
// ==========================================
calc_double_rsi(src, short_len, long_len, short_smooth, long_smooth) =>
    rsiS = ta.ema(ta.rsi(src, short_len), short_smooth)
    rsiL = ta.ema(ta.rsi(src, long_len), long_smooth)
    diff = rsiS - rsiL
    [rsiS, rsiL, diff]

calc_double_stoch(len, smooth) =>
    raw_stoch = ta.stoch(close, high, low, len)
    db_stoch = ta.ema(ta.ema(raw_stoch, smooth), smooth)
    db_stoch

get_rsi_direction(diff, thresh) =>
    diff > thresh ? 1 : diff < -thresh ? -1 : 0

[rsiS_curr, rsiL_curr, diff_curr] = calc_double_rsi(rsi_src, rsi_short_len, rsi_long_len, rsi_short_sm, rsi_long_sm)
rsi_dir_curr = get_rsi_direction(diff_curr, rsi_thresh)
db_stoch_curr = calc_double_stoch(stochLen, stochSmth)
stoch_momentum_bull = db_stoch_curr > 50
stoch_momentum_bear = db_stoch_curr < 50

ema_34 = ta.ema(close, ema_length)
ema_bull = close > ema_34
ema_bear = close < ema_34

ema_21 = ta.ema(close, 21)
ema_50 = ta.ema(close, 50)
ema_233 = ta.ema(close, 233)

hma_21 = ta.hma(close, 21)
hma_34 = ta.hma(close, 34)
hma_50 = ta.hma(close, 50)
hma_pyramid = ta.hma(close, dual_hma_len)
hma_primary_bull = (close > hma_21) and (hma_21 > hma_34)
hma_primary_bear = (close < hma_21) and (hma_21 < hma_34)
hma_50_confirms_bull = hma_34 > hma_50
hma_50_confirms_bear = hma_34 < hma_50
hma_trend = hma_primary_bull and hma_50_confirms_bull ? "STRONG LONG" :hma_primary_bull ? "LONG" :hma_primary_bear and hma_50_confirms_bear ? "STRONG SHORT" :hma_primary_bear ? "SHORT" : "NEUTRAL"
hma_macro_long = hma_trend == "LONG" or hma_trend == "STRONG LONG"
hma_macro_short = hma_trend == "SHORT" or hma_trend == "STRONG SHORT"

vwap_val = ta.vwap(close)
vwap_bull = close > vwap_val
vwap_bear = close < vwap_val

hasVolume = not na(volume) and volume > 0
vol_ma = ta.sma(hasVolume ? volume : 1, vol_ma_len)
vol_filter = use_vol_filter ? (hasVolume ? volume / vol_ma > vol_mult : true) : true

[diPlus, diMinus, adx_value] = ta.dmi(adx_length, adx_length)
adx_filter_a_plus = not use_adx or adx_value >= adx_threshold_a_plus
adx_filter_a = not use_adx or adx_value >= adx_threshold_a
adx_rising = adx_value > adx_value[1]
adx_falling = adx_value < adx_value[1]

atr_val = ta.atr(atr_period)
atr_sma = ta.sma(atr_val, 50)
atr_ratio = atr_val / (atr_sma > 0 ? atr_sma : atr_val)
vol_class = atr_ratio >= 2.0 ? "EXTREME" : atr_ratio >= 1.4 ? "HIGH" : atr_ratio >= 0.8 ? "NORMAL" : "LOW"
vol_class_color = vol_class == "EXTREME" ? color.new(color.red, 0) : vol_class == "HIGH" ? color.new(color.orange, 0) : vol_class == "NORMAL" ? color.new(color.green, 0) : color.new(color.blue, 0)

// MTF
chart_minutes = timeframe.in_seconds() / 60
mtf_fast = chart_minutes <= 3 ? "5" : chart_minutes <= 5 ? "15" : chart_minutes <= 15 ? "60" : "240"
mtf_mid  = chart_minutes <= 3 ? "15" : chart_minutes <= 5 ? "60" : chart_minutes <= 15 ? "240" : "D"
mtf_slow = chart_minutes <= 3 ? "60" : chart_minutes <= 5 ? "240" : chart_minutes <= 15 ? "D" : "W"

get_mtf_rsi_dir(tf) =>
    [_, _, diff_raw] = request.security(cleanTicker, tf, calc_double_rsi(rsi_src, rsi_short_len, rsi_long_len, rsi_short_sm, rsi_long_sm), lookahead = barmerge.lookahead_on)
    get_rsi_direction(diff_raw[1], rsi_thresh)

rsi_dir_fast = get_mtf_rsi_dir(mtf_fast)
rsi_dir_mid  = get_mtf_rsi_dir(mtf_mid)
rsi_dir_slow = get_mtf_rsi_dir(mtf_slow)

mtf_3tf_bull = (rsi_dir_fast == 1) and (rsi_dir_mid == 1) and (rsi_dir_slow == 1)
mtf_3tf_bear = (rsi_dir_fast == -1) and (rsi_dir_mid == -1) and (rsi_dir_slow == -1)
mtf_2tf_bull = (rsi_dir_fast == 1) and (rsi_dir_mid == 1)
mtf_2tf_bear = (rsi_dir_fast == -1) and (rsi_dir_mid == -1)
mtf_1tf_bull = (rsi_dir_fast == 1)
mtf_1tf_bear = (rsi_dir_fast == -1)

// Grade (identical logic to Signals indicator)
is_a_plus_long = mtf_3tf_bull and (rsi_dir_curr == 1) and ema_bull and vwap_bull and stoch_momentum_bull and vol_filter and adx_filter_a_plus
is_a_plus_short = mtf_3tf_bear and (rsi_dir_curr == -1) and ema_bear and vwap_bear and stoch_momentum_bear and vol_filter and adx_filter_a_plus
is_a_long = mtf_3tf_bull and (rsi_dir_curr == 1) and ema_bull and stoch_momentum_bull and adx_filter_a and not is_a_plus_long
is_a_short = mtf_3tf_bear and (rsi_dir_curr == -1) and ema_bear and stoch_momentum_bear and adx_filter_a and not is_a_plus_short

macro_ok_long = not macro_trend_filter or not hma_macro_short
macro_ok_short = not macro_trend_filter or not hma_macro_long

is_a_minus_long = mtf_2tf_bull and (rsi_dir_curr == 1) and ema_bull and stoch_momentum_bull and macro_ok_long and not is_a_long and not is_a_plus_long
is_a_minus_short = mtf_2tf_bear and (rsi_dir_curr == -1) and ema_bear and stoch_momentum_bear and macro_ok_short and not is_a_short and not is_a_plus_short

adx_floor_ok = adx_floor_bb <= 0 or adx_value >= adx_floor_bb
low_vol_ok = not use_low_vol_suppress or vol_class != "LOW"
bb_chop_filter = adx_floor_ok and low_vol_ok
ribbon_ok_long = not require_ribbon_bb or rsi_dir_curr == 1
ribbon_ok_short = not require_ribbon_bb or rsi_dir_curr == -1

// HMA 34 trend for B/B+ (must match Signals indicator)
hma_bull = close > hma_34
hma_bear = close < hma_34

is_b_plus_long = mtf_2tf_bull and hma_bull and bb_chop_filter and macro_ok_long and ribbon_ok_long and not is_a_minus_long and not is_a_long and not is_a_plus_long
is_b_plus_short = mtf_2tf_bear and hma_bear and bb_chop_filter and macro_ok_short and ribbon_ok_short and not is_a_minus_short and not is_a_short and not is_a_plus_short
is_b_long = mtf_1tf_bull and hma_bull and bb_chop_filter and macro_ok_long and ribbon_ok_long and not is_b_plus_long and not is_a_minus_long and not is_a_long and not is_a_plus_long
is_b_short = mtf_1tf_bear and hma_bear and bb_chop_filter and macro_ok_short and ribbon_ok_short and not is_b_plus_short and not is_a_minus_short and not is_a_short and not is_a_plus_short

grade = is_a_plus_long or is_a_plus_short ? "A+" :is_a_long or is_a_short ? "A" :is_a_minus_long or is_a_minus_short ? "A-" :is_b_plus_long or is_b_plus_short ? "B+" :is_b_long or is_b_short ? "B" : "NONE"
is_long_setup = is_a_plus_long or is_a_long or is_a_minus_long or is_b_plus_long or is_b_long
is_short_setup = is_a_plus_short or is_a_short or is_a_minus_short or is_b_plus_short or is_b_short
direction = is_long_setup ? "LONG" : is_short_setup ? "SHORT" : "NEUTRAL"

// ==========================================
// --- ADX ADVANCED ---
// ==========================================
adx_size_mult = (enable_adx_adv and adx_sizing_mode) ? (adx_value >= 30 ? 1.0 : adx_value >= 20 ? 0.75 : 0.50) : 1.0
runner_adx_ok = not enable_adx_adv or adx_runner_gate <= 0 or adx_value >= adx_runner_gate
pyramid_adx_ok = not enable_adx_adv or not adx_pyramid_rising or adx_rising

var bool adx_was_low = false
adx_was_low := adx_value < adx_breakout_low ? true : (adx_value > adx_breakout_high ? false : adx_was_low)
adx_breakout_signal = enable_adx_adv and adx_breakout_detect and adx_was_low[1] and adx_value >= adx_breakout_high and adx_value[1] < adx_breakout_high

// SL values (NQ: backtested CONS-TIGHT | YM: 1pt = 1tick)
sl_aplus = use_cl_preset ? 0.40 : use_nq_preset ? 13.0 : use_ym_preset ? 15.0 : 15.0
sl_a     = use_cl_preset ? 0.40 : use_nq_preset ? 13.0 : use_ym_preset ? 15.0 : 15.0
sl_aminus = use_cl_preset ? 0.30 : use_nq_preset ? 10.0 : use_ym_preset ? 12.0 : 15.0
sl_bplus  = use_cl_preset ? 0.30 : use_nq_preset ? 10.0 : use_ym_preset ? 10.0 : 15.0
sl_b      = use_cl_preset ? 0.30 : use_nq_preset ? 8.0 : use_ym_preset ? 8.0 : 15.0

stop_dist = grade == "A+" ? sl_aplus : grade == "A" ? sl_a : grade == "A-" ? sl_aminus : grade == "B+" ? sl_bplus : grade == "B" ? sl_b : atr_val

// TP values (NQ: backtested CONS-TIGHT | YM: wider targets for runners)
tp_aplus = use_cl_preset ? 0.20 : use_nq_preset ? 25.0 : use_ym_preset ? 35.0 : 6.0
tp_a     = use_cl_preset ? 0.20 : use_nq_preset ? 20.0 : use_ym_preset ? 25.0 : 6.0
tp_aminus = use_cl_preset ? 0.15 : use_nq_preset ? 15.0 : use_ym_preset ? 18.0 : 4.0
tp_bplus  = use_cl_preset ? 0.10 : use_nq_preset ? 15.0 : use_ym_preset ? 15.0 : 3.0
tp_b      = use_cl_preset ? 0.08 : use_nq_preset ? 12.0 : use_ym_preset ? 10.0 : 2.0

// ==========================================
// --- ADR ---
// ==========================================
// Use current day's running high/low for intraday range consumed
daily_high = request.security(cleanTicker, "D", high, lookahead = barmerge.lookahead_off)
daily_low  = request.security(cleanTicker, "D", low, lookahead = barmerge.lookahead_off)
adr_val = request.security(cleanTicker, "D", ta.sma(high - low, adr_length)[1], lookahead = barmerge.lookahead_on)
today_range = daily_high - daily_low
adr_pct_used = adr_val > 0 ? (today_range / adr_val) * 100 : 0

// ==========================================
// --- GLOBEX LEVELS ---
// ==========================================
globex_lstyle = globex_line_style == "Solid" ? line.style_solid : globex_line_style == "Dotted" ? line.style_dotted : line.style_dashed
prev1_globex_high = request.security(cleanTicker, "D", high[2], lookahead = barmerge.lookahead_on)
prev1_globex_low  = request.security(cleanTicker, "D", low[2], lookahead = barmerge.lookahead_on)
prev2_globex_high = request.security(cleanTicker, "D", high[3], lookahead = barmerge.lookahead_on)
prev2_globex_low  = request.security(cleanTicker, "D", low[3], lookahead = barmerge.lookahead_on)

globex_session = not na(time(timeframe.period, "1800-1700:123456", "America/New_York"))
globex_new_session = globex_session and not globex_session[1]

var int POC_BINS = 50
var float[] vol_bins = array.new_float(POC_BINS, 0.0)
var float session_low_anchor = na
var float session_high_anchor = na
var float prev1_globex_poc = na

if globex_new_session
    if not na(session_high_anchor) and not na(session_low_anchor) and session_high_anchor > session_low_anchor
        max_vol = 0.0
        poc_price = (session_high_anchor + session_low_anchor) / 2
        bin_size = (session_high_anchor - session_low_anchor) / POC_BINS
        for i = 0 to POC_BINS - 1
            if array.get(vol_bins, i) > max_vol
                max_vol := array.get(vol_bins, i)
                poc_price := session_low_anchor + (i + 0.5) * bin_size
        prev1_globex_poc := poc_price
    session_low_anchor := low
    session_high_anchor := high
    for i = 0 to POC_BINS - 1
        array.set(vol_bins, i, 0.0)

if globex_session
    session_high_anchor := math.max(nz(session_high_anchor, high), high)
    session_low_anchor  := math.min(nz(session_low_anchor, low), low)
    if session_high_anchor > session_low_anchor
        bin_size_curr = (session_high_anchor - session_low_anchor) / POC_BINS
        if bin_size_curr > 0
            bin_idx = math.floor((close - session_low_anchor) / bin_size_curr)
            bin_idx := math.max(0, math.min(bin_idx, POC_BINS - 1))
            array.set(vol_bins, bin_idx, array.get(vol_bins, bin_idx) + volume)

// ==========================================
// --- SIZING (per-grade, capped) ---
// ==========================================
max_pain_pts = dollar_per_point > 0 ? max_pain_dollars / dollar_per_point : 0

// Per-grade sizing: each grade uses its OWN SL for contract calculation
// Formula: floor(max_pain / (grade_sl * dollar_per_point)), capped at max_contracts
calc_cts(sl_val, dpp, mp, cap) =>
    raw = sl_val > 0 and dpp > 0 ? math.floor(mp / (sl_val * dpp)) : 0
    math.min(raw, cap)

cts_a_plus = calc_cts(sl_aplus, dollar_per_point, max_pain_dollars, max_contracts)
cts_a      = calc_cts(sl_a, dollar_per_point, max_pain_dollars, max_contracts)
cts_a_minus = calc_cts(sl_aminus, dollar_per_point, max_pain_dollars, max_contracts)
cts_b_plus  = calc_cts(sl_bplus, dollar_per_point, max_pain_dollars, max_contracts)
cts_b       = calc_cts(sl_b, dollar_per_point, max_pain_dollars, max_contracts)

// ATR-based alternative (for reference column)
atr_stop_dist = atr_val * 1.5
cts_atr = calc_cts(atr_stop_dist, dollar_per_point, max_pain_dollars, max_contracts)

// ==========================================
// --- PYRAMID LOGIC ---
// ==========================================
// Persistence (simplified — just need grade_changed and filtered_new_signal)
var int persist_count = 0
grade_changed = grade != grade[1] or direction != direction[1]
persist_count := grade_changed ? 1 : (grade != "NONE" ? persist_count + 1 : 0)

var int bars_since_signal = 999
grade_persisted = persist_count >= persist_bars
raw_new_signal = grade_persisted and grade != "NONE" and (grade_changed or not grade_persisted[1])
cooldown_ok = bars_since_signal >= cooldown_bars
filtered_new_signal = raw_new_signal and cooldown_ok
bars_since_signal := filtered_new_signal ? 0 : bars_since_signal + 1

grade_num = grade == "A+" ? 5 : grade == "A" ? 4 : grade == "A-" ? 3 : grade == "B+" ? 2 : grade == "B" ? 1 : 0
var int prev_grade_num = 0
var int add_count = 0
var int pyramid_dir = 0
var bool just_added = false

pyramid_reset = (direction == "NEUTRAL") or (direction == "LONG" and pyramid_dir == -1) or (direction == "SHORT" and pyramid_dir == 1)
if pyramid_reset
    add_count := 0
    pyramid_dir := 0

if filtered_new_signal and grade_num > 0
    pyramid_dir := direction == "LONG" ? 1 : direction == "SHORT" ? -1 : 0
    prev_grade_num := grade_num
    add_count := 0

grade_upgraded = grade_num > prev_grade_num and grade_num > 0 and prev_grade_num > 0 and ((direction == "LONG" and pyramid_dir == 1) or (direction == "SHORT" and pyramid_dir == -1))

// Pyramid pullback — uses runner trail EMA, 34 EMA, or runner trail + HMA dual confirm
pyramid_ema = pyramid_trail_source == "34 EMA" ? ema_34 : runner_trail_val
pyr_dist_pct = math.abs(close - pyramid_ema) / pyramid_ema * 100
near_trail = pyr_dist_pct <= ema_pullback_pct
was_away_from_trail = pyr_dist_pct[1] > ema_pullback_pct or pyr_dist_pct[2] > ema_pullback_pct
// Bounce: current bar closed back in trend direction after touching the zone
bounce_long = not require_bounce or (close > open and close > pyramid_ema)
bounce_short = not require_bounce or (close < open and close < pyramid_ema)
// Touch zone: low dipped into zone (long) or high poked into zone (short)
touch_long = low <= pyramid_ema * (1 + ema_pullback_pct / 100)
touch_short = high >= pyramid_ema * (1 - ema_pullback_pct / 100)
ema_pullback_long = touch_long and was_away_from_trail and bounce_long and is_long_setup and pyramid_dir == 1 and close > pyramid_ema
ema_pullback_short = touch_short and was_away_from_trail and bounce_short and is_short_setup and pyramid_dir == -1 and close < pyramid_ema
// Dual confirm: custom HMA must agree with trend direction
dual_hma_bull = hma_pyramid > hma_pyramid[1] and close > hma_pyramid
dual_hma_bear = hma_pyramid < hma_pyramid[1] and close < hma_pyramid
dual_confirm_ok = pyramid_trail_source != "Dual Confirm" or (pyramid_dir == 1 and dual_hma_bull) or (pyramid_dir == -1 and dual_hma_bear)
ema_pullback_add = (ema_pullback_long or ema_pullback_short) and dual_confirm_ok

can_add = enablePyramid and add_count < max_adds and pyramid_dir != 0 and pyramid_adx_ok
add_trigger = can_add and (grade_upgraded or ema_pullback_add) and not filtered_new_signal

just_added := add_trigger
if add_trigger
    add_count := add_count + 1
    prev_grade_num := grade_num

pyramid_status = pyramid_dir == 0 ? "—" : str.tostring(add_count) + "/" + str.tostring(max_adds)

// HA calculation (for context panel)
haClose = (open + high + low + close) / 4
var float haOpen = na
haOpen := na(haOpen[1]) ? (open + close) / 2 : (nz(haOpen[1]) + nz(haClose[1])) / 2
ha_bull = haClose >= haOpen

// ==========================================
// --- VISUAL ELEMENTS ---
// ==========================================
// Additional EMAs
plot(show_ema_21 ? ema_21 : na, "21 EMA", color=close > ema_21 ? color.new(color.green, 0) : color.new(color.red, 0), linewidth=2)
plot(show_ema_50 ? ema_50 : na, "50 EMA", color=close > ema_50 ? color.new(color.green, 0) : color.new(color.red, 0), linewidth=2)
plot(show_ema_233 ? ema_233 : na, "233 EMA", color=close > ema_233 ? color.new(color.green, 0) : color.new(color.red, 0), linewidth=3)

// ATR Stop Reference (A grades only)
is_a_grade_long = is_a_plus_long or is_a_long or is_a_minus_long
is_a_grade_short = is_a_plus_short or is_a_short or is_a_minus_short
atr_stop_long = close - atr_val * 1.5
atr_stop_short = close + atr_val * 1.5
plot(showATRStops and tradeAllowed and is_a_grade_long ? atr_stop_long : na, "ATR Stop Long", color=color.new(#FF6B00, 20), linewidth=3, style=plot.style_cross)
plot(showATRStops and tradeAllowed and is_a_grade_short ? atr_stop_short : na, "ATR Stop Short", color=color.new(#FF6B00, 20), linewidth=3, style=plot.style_cross)

// ATR-based TP (A grades only when enabled)
atr_tp_long = close + atr_val * atr_tp_mult
atr_tp_short = close - atr_val * atr_tp_mult

// TP Levels: ATR-based for A grades (when toggled), fixed for B grades always
tp_level_long = showATRTP and is_a_grade_long ? atr_tp_long : is_a_plus_long ? close + tp_aplus : is_a_long ? close + tp_a : is_a_minus_long ? close + tp_aminus : is_b_plus_long ? close + tp_bplus : is_b_long ? close + tp_b : na
tp_level_short = showATRTP and is_a_grade_short ? atr_tp_short : is_a_plus_short ? close - tp_aplus : is_a_short ? close - tp_a : is_a_minus_short ? close - tp_aminus : is_b_plus_short ? close - tp_bplus : is_b_short ? close - tp_b : na
show_any_tp = showSizingDash or showATRTP
plot(show_any_tp and tradeAllowed and is_long_setup ? tp_level_long : na, "Long TP", color=color.new(#00BFFF, 20), linewidth=2, style=plot.style_cross)
plot(show_any_tp and tradeAllowed and is_short_setup ? tp_level_short : na, "Short TP", color=color.new(#00BFFF, 20), linewidth=2, style=plot.style_cross)

// Runner Trail
runner_trail_val = runner_ema_source == "21 HMA" ? hma_21 : runner_ema_source == "21 EMA" ? ema_21 : ema_34
runner_active = grade != "NONE" and showRunnerTrail and runner_adx_ok
plot(runner_active and tradeAllowed and is_long_setup ? runner_trail_val : na, "Runner Trail (Long)", color=color.new(#00E5FF, 20), linewidth=2, style=plot.style_stepline)
plot(runner_active and tradeAllowed and is_short_setup ? runner_trail_val : na, "Runner Trail (Short)", color=color.new(#00E5FF, 20), linewidth=2, style=plot.style_stepline)

// Pyramid Add Signals
plotshape(add_trigger and tradeAllowed and pyramid_dir == 1, "Pyramid Add Long", shape.arrowup, location.belowbar, color.new(#00E5FF, 30), size=size.auto, text="+")
plotshape(add_trigger and tradeAllowed and pyramid_dir == -1, "Pyramid Add Short", shape.arrowdown, location.abovebar, color.new(#00E5FF, 30), size=size.auto, text="+")

// ADX Breakout
plotshape(adx_breakout_signal and tradeAllowed, "ADX Breakout", shape.square, location.belowbar, color.new(#FFD700, 0), size=size.auto, text="BRK")


// ==========================================
// --- TRADE CONTEXT PANEL ---
// ==========================================
var table ctx_table = table.new(position.bottom_left, 2, 6, border_width=1, frame_color=color.new(color.white, 80), border_color=color.new(color.gray, 80))

if showContextPanel and tradeAllowed and barstate.islast
    table.cell(ctx_table, 0, 0, "TRADE CONTEXT", bgcolor=color.new(#1a1a2e, 60), text_color=color.white, text_size=size.small)
    table.cell(ctx_table, 1, 0, "", bgcolor=color.new(#1a1a2e, 60))

    // HA Momentum
    ha_consec = 0
    for i = 0 to 19
        if ha_bull[i] == ha_bull
            ha_consec += 1
        else
            break
    ha_mom_text = (ha_bull ? "BULL " : "BEAR ") + str.tostring(ha_consec) + " bars"
    ha_mom_col = ha_bull ? color.new(color.green, 65) : color.new(color.red, 65)
    table.cell(ctx_table, 0, 1, "HA MOMENTUM", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(ctx_table, 1, 1, ha_mom_text, bgcolor=ha_mom_col, text_color=color.white, text_size=size.small)

    // Macro Alignment
    macro_aligned = (is_long_setup and hma_macro_long) or (is_short_setup and hma_macro_short)
    macro_against = (is_long_setup and hma_macro_short) or (is_short_setup and hma_macro_long)
    macro_text = grade == "NONE" ? "—" : macro_aligned ? "✓ WITH TREND" : macro_against ? "✗ COUNTER" : "— NEUTRAL"
    macro_col = grade == "NONE" ? color.new(color.gray, 85) : macro_aligned ? color.new(color.green, 65) : macro_against ? color.new(color.red, 55) : color.new(color.gray, 80)
    table.cell(ctx_table, 0, 2, "MACRO ALIGN", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(ctx_table, 1, 2, macro_text, bgcolor=macro_col, text_color=color.white, text_size=size.small)

    // ADR Remaining
    adr_remaining = adr_val > 0 ? math.max(0, adr_val - today_range) : 0
    adr_remain_pct = adr_val > 0 ? 100 - adr_pct_used : 0
    adr_remain_text = not show_adr_dash ? "—" : (use_cl_preset ? "$" + str.tostring(adr_remaining, "0.00") : str.tostring(adr_remaining, "0.1") + " pts") + " (" + str.tostring(adr_remain_pct, "0") + "%)"
    adr_remain_col = not show_adr_dash ? color.new(color.gray, 90) : adr_remain_pct > 50 ? color.new(color.green, 65) : adr_remain_pct > 20 ? color.new(color.yellow, 65) : color.new(color.red, 55)
    table.cell(ctx_table, 0, 3, "ADR LEFT", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(ctx_table, 1, 3, adr_remain_text, bgcolor=adr_remain_col, text_color=color.white, text_size=size.small)

    // Runner Status
    runner_text = grade == "NONE" ? "—" : not showRunnerTrail ? "OFF" : not runner_adx_ok ? "✗ NO RUN (ADX)" : runner_active ? "✓ TRAILING" : "✓ ELIGIBLE"
    runner_col = grade == "NONE" or not showRunnerTrail ? color.new(color.gray, 90) : not runner_adx_ok ? color.new(color.red, 65) : color.new(color.green, 65)
    table.cell(ctx_table, 0, 4, "RUNNER", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(ctx_table, 1, 4, runner_text, bgcolor=runner_col, text_color=color.white, text_size=size.small)

    // MTF RSI compact
    mtf_all_bull = rsi_dir_fast == 1 and rsi_dir_mid == 1 and rsi_dir_slow == 1
    mtf_all_bear = rsi_dir_fast == -1 and rsi_dir_mid == -1 and rsi_dir_slow == -1
    mtf_bull_count = (rsi_dir_fast == 1 ? 1 : 0) + (rsi_dir_mid == 1 ? 1 : 0) + (rsi_dir_slow == 1 ? 1 : 0)
    mtf_bear_count = (rsi_dir_fast == -1 ? 1 : 0) + (rsi_dir_mid == -1 ? 1 : 0) + (rsi_dir_slow == -1 ? 1 : 0)
    mtf_text = mtf_all_bull ? "3/3 BULL ▲" : mtf_all_bear ? "3/3 BEAR ▼" : str.tostring(mtf_bull_count) + "▲ " + str.tostring(mtf_bear_count) + "▼ MIXED"
    mtf_col = mtf_all_bull ? color.new(color.green, 60) : mtf_all_bear ? color.new(color.red, 60) : color.new(color.yellow, 65)
    table.cell(ctx_table, 0, 5, "MTF RSI", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(ctx_table, 1, 5, mtf_text, bgcolor=mtf_col, text_color=color.white, text_size=size.small)

// ==========================================
// --- VOLATILITY & SIZING DASHBOARD ---
// ==========================================
s_pos = switch sizing_dash_pos
    "Top Right"    => position.top_right
    "Bottom Right" => position.bottom_right
    "Top Left"     => position.top_left
    "Bottom Left"  => position.bottom_left
    => position.bottom_right

var table size_table = table.new(s_pos, 3, 10, border_width=1, frame_color=color.new(color.white, 80), border_color=color.new(color.gray, 80))

if showSizingDash and tradeAllowed and barstate.islast
    table.cell(size_table, 0, 0, "📐 VOLATILITY & SIZING", bgcolor=color.new(#1a1a2e, 60), text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(size_table, 1, 0, "", bgcolor=color.new(#1a1a2e, 60))
    table.cell(size_table, 2, 0, "$" + str.tostring(max_pain_dollars, "0") + " MAX PAIN", bgcolor=color.new(#1a1a2e, 60), text_color=color.new(color.red, 0), text_size=size.small, text_halign=text.align_right)

    atr_display = use_cl_preset ? "$" + str.tostring(atr_val, "0.00") : str.tostring(atr_val, "0.2")
    table.cell(size_table, 0, 1, "ATR(" + str.tostring(atr_period) + ")", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(size_table, 1, 1, atr_display, bgcolor=color.new(color.gray, 88), text_color=color.white, text_size=size.small)
    table.cell(size_table, 2, 1, "", bgcolor=color.new(color.gray, 88))

    vol_emoji = vol_class == "EXTREME" ? "🔴 " : vol_class == "HIGH" ? "🟠 " : vol_class == "NORMAL" ? "🟢 " : "🔵 "
    table.cell(size_table, 0, 2, "VOLATILITY", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(size_table, 1, 2, vol_emoji + vol_class, bgcolor=color.new(color.gray, 88), text_color=vol_class_color, text_size=size.small)
    vol_ratio_display = str.tostring(atr_ratio, "0.0") + "x avg"
    table.cell(size_table, 2, 2, vol_ratio_display, bgcolor=color.new(color.gray, 88), text_color=color.new(color.gray, 30), text_size=size.small)

    stop_ticks = use_cl_preset ? stop_dist * 100 : use_ym_preset ? stop_dist * 1 : stop_dist * 4
    stop_display = use_cl_preset ? "$" + str.tostring(stop_dist, "0.00") + " (" + str.tostring(stop_ticks, "0") + "t)" : str.tostring(stop_dist, "0.1") + " pts (" + str.tostring(stop_ticks, "0") + "t)"
    stop_dollars = str.tostring(stop_dist * dollar_per_point, "0.0") + "/ct"
    table.cell(size_table, 0, 3, "STOP DIST", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(size_table, 1, 3, stop_display, bgcolor=color.new(color.gray, 88), text_color=color.white, text_size=size.small)
    table.cell(size_table, 2, 3, "$" + stop_dollars, bgcolor=color.new(color.gray, 88), text_color=color.new(color.gray, 30), text_size=size.small)

    adx_mult_text = not enable_adx_adv ? "OFF" : adx_sizing_mode ? str.tostring(math.round(adx_size_mult * 100)) + "%" + (adx_rising ? " ▲" : " ▼") : "—"
    adx_mult_col = not enable_adx_adv ? color.new(color.gray, 90) : not adx_sizing_mode ? color.new(color.gray, 90) : adx_size_mult >= 1.0 ? color.new(color.green, 70) : adx_size_mult >= 0.75 ? color.new(color.yellow, 70) : color.new(color.red, 70)
    runner_status = not enable_adx_adv ? "—" : runner_adx_ok ? "✓ RUN" : "✗ NO RUN"
    runner_ok_col = not enable_adx_adv ? color.new(color.gray, 90) : runner_adx_ok ? color.new(color.green, 75) : color.new(color.red, 70)
    table.cell(size_table, 0, 4, "ADX SIZING", bgcolor=color.new(color.gray, 85), text_color=color.white, text_size=size.small)
    table.cell(size_table, 1, 4, adx_mult_text, bgcolor=adx_mult_col, text_color=color.white, text_size=size.small)
    table.cell(size_table, 2, 4, runner_status, bgcolor=runner_ok_col, text_color=color.white, text_size=size.small)

    table.cell(size_table, 0, 5, "MAX CTS (cap: " + str.tostring(max_contracts) + ")", bgcolor=color.new(#1a1a2e, 60), text_color=color.new(color.yellow, 0), text_size=size.small, text_halign=text.align_left)
    table.cell(size_table, 1, 5, "Grade SL", bgcolor=color.new(#1a1a2e, 60), text_color=color.new(color.gray, 30), text_size=size.small)
    table.cell(size_table, 2, 5, "ATR Stop", bgcolor=color.new(#1a1a2e, 60), text_color=color.new(color.gray, 30), text_size=size.small)

    // Each row uses THAT GRADE's own SL for sizing — no percentage scaling
    sl_fmt = use_cl_preset ? "0.00" : "0"
    aplus_col = cts_a_plus >= 1 ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(size_table, 0, 6, "A+ / A (" + str.tostring(sl_aplus, sl_fmt) + " SL)", bgcolor=color.new(color.gray, 85), text_color=color.new(#00ff00, 0), text_size=size.small)
    table.cell(size_table, 1, 6, str.tostring(cts_a_plus) + " cts", bgcolor=aplus_col, text_color=color.white, text_size=size.small)
    table.cell(size_table, 2, 6, str.tostring(cts_atr) + " cts", bgcolor=aplus_col, text_color=color.white, text_size=size.small)

    am_col = cts_a_minus >= 1 ? color.new(#4488FF, 70) : color.new(color.red, 70)
    table.cell(size_table, 0, 7, "A- (" + str.tostring(sl_aminus, sl_fmt) + " SL)", bgcolor=color.new(color.gray, 85), text_color=color.new(#66ff66, 0), text_size=size.small)
    table.cell(size_table, 1, 7, str.tostring(cts_a_minus) + " cts", bgcolor=am_col, text_color=color.white, text_size=size.small)
    table.cell(size_table, 2, 7, str.tostring(cts_atr) + " cts", bgcolor=am_col, text_color=color.white, text_size=size.small)

    bp_col = cts_b_plus >= 1 ? color.new(#FF9900, 70) : color.new(color.red, 70)
    table.cell(size_table, 0, 8, "B+ (" + str.tostring(sl_bplus, sl_fmt) + " SL)", bgcolor=color.new(color.gray, 85), text_color=color.new(#ffaa00, 0), text_size=size.small)
    table.cell(size_table, 1, 8, str.tostring(cts_b_plus) + " cts", bgcolor=bp_col, text_color=color.white, text_size=size.small)
    table.cell(size_table, 2, 8, str.tostring(cts_atr) + " cts", bgcolor=bp_col, text_color=color.white, text_size=size.small)

    b_col = cts_b >= 1 ? color.new(color.red, 75) : color.new(color.red, 65)
    table.cell(size_table, 0, 9, "B (" + str.tostring(sl_b, sl_fmt) + " SL)", bgcolor=color.new(color.gray, 85), text_color=color.new(#ff6600, 0), text_size=size.small)
    table.cell(size_table, 1, 9, str.tostring(cts_b) + " cts", bgcolor=b_col, text_color=color.white, text_size=size.small)
    table.cell(size_table, 2, 9, str.tostring(cts_atr) + " cts", bgcolor=b_col, text_color=color.white, text_size=size.small)

// ==========================================
// --- GLOBEX LEVEL LINES ---
// ==========================================
var line ln_prev1_high = na
var line ln_prev1_low  = na
var line ln_prev2_high = na
var line ln_prev2_low  = na
var line ln_prev1_poc  = na
var label lbl_prev1_high = na
var label lbl_prev1_low  = na
var label lbl_prev2_high = na
var label lbl_prev2_low  = na
var label lbl_prev1_poc  = na

if barstate.islast and tradeAllowed
    line.delete(ln_prev1_high)
    line.delete(ln_prev1_low)
    line.delete(ln_prev2_high)
    line.delete(ln_prev2_low)
    line.delete(ln_prev1_poc)
    label.delete(lbl_prev1_high)
    label.delete(lbl_prev1_low)
    label.delete(lbl_prev2_high)
    label.delete(lbl_prev2_low)
    label.delete(lbl_prev1_poc)

    left_offset = bar_index - 200
    right_offset = bar_index + 20

    if show_globex_hl and not na(prev1_globex_high)
        ln_prev1_high := line.new(left_offset, prev1_globex_high, right_offset, prev1_globex_high, color=globex_hl_color_1, style=globex_lstyle, width=2, extend=extend.none)
        ln_prev1_low  := line.new(left_offset, prev1_globex_low, right_offset, prev1_globex_low, color=globex_hl_color_1, style=globex_lstyle, width=2, extend=extend.none)
        lbl_prev1_high := label.new(right_offset, prev1_globex_high, "p1High", style=label.style_none, textcolor=globex_hl_color_1, size=size.tiny)
        lbl_prev1_low  := label.new(right_offset, prev1_globex_low, "p1Low", style=label.style_none, textcolor=globex_hl_color_1, size=size.tiny)

    if show_globex_hl and not na(prev2_globex_high)
        ln_prev2_high := line.new(left_offset, prev2_globex_high, right_offset, prev2_globex_high, color=globex_hl_color_2, style=globex_lstyle, width=1, extend=extend.none)
        ln_prev2_low  := line.new(left_offset, prev2_globex_low, right_offset, prev2_globex_low, color=globex_hl_color_2, style=globex_lstyle, width=1, extend=extend.none)
        lbl_prev2_high := label.new(right_offset, prev2_globex_high, "p2High", style=label.style_none, textcolor=globex_hl_color_2, size=size.tiny)
        lbl_prev2_low  := label.new(right_offset, prev2_globex_low, "p2Low", style=label.style_none, textcolor=globex_hl_color_2, size=size.tiny)

    if show_globex_poc and not na(prev1_globex_poc)
        ln_prev1_poc := line.new(left_offset, prev1_globex_poc, right_offset, prev1_globex_poc, color=globex_poc_color, style=globex_lstyle, width=2, extend=extend.none)
        lbl_prev1_poc := label.new(right_offset, prev1_globex_poc, "PriorPoC", style=label.style_none, textcolor=globex_poc_color, size=size.tiny)

// Alerts
alertcondition(add_trigger and pyramid_dir == 1, title="📈 PYRAMID ADD LONG", message="ADD LONG: Grade upgraded or EMA pullback!")
alertcondition(add_trigger and pyramid_dir == -1, title="📈 PYRAMID ADD SHORT", message="ADD SHORT: Grade upgraded or EMA pullback!")
alertcondition(adx_breakout_signal, title="💥 ADX BREAKOUT", message="ADX BREAKOUT: Range breakout detected!")
